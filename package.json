    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vercel": "^53.4.0"
  }
