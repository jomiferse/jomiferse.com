---
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>
			José Miguel Fernández | Desarrollo web freelance, automatización y backend
		</title>
		<meta
			name="description"
			content="Desarrollador full-stack freelance en España para desarrollo web, WordPress, automatización, integraciones API y backend Spring Boot."
		/>
		<meta name="robots" content="index,follow" />
		<link rel="canonical" href={new URL("/es/", site).toString()} />
		<link
			rel="alternate"
			hreflang="en"
			href={new URL("/en/", site).toString()}
		/>
		<link
			rel="alternate"
			hreflang="es"
			href={new URL("/es/", site).toString()}
		/>
		<link
			rel="alternate"
			hreflang="x-default"
			href={new URL("/es/", site).toString()}
		/>
	</head>
	<body>
		<main>
			<h1>José Miguel Fernández</h1>
			<p>
				Desarrollador full-stack freelance para desarrollo web, WordPress,
				automatización, integraciones API y backend Spring Boot.
			</p>
			<nav aria-label="Seleccion de idioma">
				<ul>
					<li><a href="/es/">Español</a></li>
					<li><a href="/es/services/">Servicios en español</a></li>
					<li><a href="/en/">English</a></li>
					<li><a href="/en/services/">Services in English</a></li>
				</ul>
			</nav>
		</main>

		<script>
			window.location.replace("/es/");
		</script>

		<noscript>
			<p>
				<a href="/es/">Continuar en español</a> or
				<a href="/en/">continue in English</a>.
			</p>
		</noscript>
	</body>
</html>
