---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getServices } from "@/lib/services";
import { getLocaleStaticPaths, getTranslations, t } from "@/i18n";
import {
	buildBreadcrumbList,
	buildCollectionPage,
	buildProfessionalService,
} from "@/lib/seo";
import { getCv } from "@cv";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const cv = getCv(locale);
const services = getServices(locale);
const page = getTranslations(locale).services.hub;
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const structuredData = [
	buildProfessionalService({
		site,
		path: `/${locale}/services`,
		name: page.schema.name,
		description: page.schema.description,
		providerName: cv.name,
		providerUrl: new URL(`/${locale}`, site).toString(),
		areaServed: page.schema.areaServed,
		sameAs: [cv.links.linkedin, cv.links.github],
		services: services.map((service) => ({
			name: service.title,
			description: service.description,
			path: `/${locale}/services/${service.slug}`,
		})),
	}),
	buildCollectionPage(
		site,
		`/${locale}/services`,
		page.meta.title,
		page.meta.description,
	),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}` },
		{ name: t(locale, "nav.services"), path: `/${locale}/services` },
	]),
];
---

<BaseLayout
	title={page.meta.title}
	description={page.meta.description}
	structuredData={structuredData}
	keywords={[
		"Freelance Web Development",
		"Full-Stack Development",
		"Business Website",
		"Internal Tools",
		"API Integrations",
	]}
>
	<section class="section-reveal py-10 md:py-20">
		<p class="eyebrow">{page.eyebrow}</p>
		<h1
			class="mt-5 max-w-4xl text-5xl font-black text-[var(--text)] md:text-7xl"
		>
			{page.title}
			<span class="accent-text">{page.titleAccent}</span>
		</h1>
		<p class="muted-copy mt-6 max-w-2xl text-lg leading-8">{page.intro}</p>
	</section>

	<section class="section-band section-reveal py-16">
		<p class="muted-copy text-lg leading-8">
			<span class="font-bold text-[var(--text)]">{page.bestForLead}</span>
			{" "}
			{page.bestForText}
		</p>
	</section>

	<section class="section-reveal py-20 md:py-28">
		<div class="stagger-children grid gap-5 md:grid-cols-2">
			{
				services.map((service) => (
					<article class="dark-card hover-card p-6">
						<p class="font-black text-[var(--accent-strong)] dark:text-[var(--accent)]">
							{service.number}
						</p>
						<h2 class="mt-6 text-3xl font-black text-[var(--text)]">
							{service.title}
						</h2>
						<p class="muted-copy mt-4 leading-7">{service.description}</p>
						<div class="hairline mt-7 border-t pt-5">
							<p class="eyebrow">{page.included}</p>
							<ul class="mt-4 space-y-3">
								{service.builds.slice(0, 4).map((item) => (
									<li class="flex gap-3 text-sm text-[var(--text-muted)]">
										<span class="text-[var(--accent-strong)] dark:text-[var(--accent)]">
											✓
										</span>
										<span>{item}</span>
									</li>
								))}
							</ul>
						</div>
						<div class="hairline mt-7 rounded-2xl border p-4">
							<p class="eyebrow">{page.bestFor}</p>
							<p class="mt-3 text-sm leading-6 text-[var(--text)]">
								{service.whoFor[0]}
							</p>
						</div>
						<a
							href={`/${locale}/services/${service.slug}`}
							class="button-secondary mt-7 w-full justify-center sm:w-fit"
						>
							{page.viewService}
						</a>
					</article>
				))
			}
		</div>
	</section>

	<section class="section-band section-reveal py-20 md:py-28">
		<div class="grid gap-10 lg:grid-cols-[0.75fr_1.25fr]">
			<div>
				<p class="eyebrow">{page.processEyebrow}</p>
				<h2
					class="mt-4 text-3xl font-black text-[var(--text)] sm:text-4xl md:text-5xl"
				>
					{page.processTitle}
				</h2>
			</div>
			<div class="stagger-children grid gap-4 sm:grid-cols-2">
				{
					page.process.map((step, index) => (
						<article class="dark-card p-5">
							<p class="font-black text-[var(--accent-strong)] dark:text-[var(--accent)]">
								{String(index + 1).padStart(2, "0")}
							</p>
							<h3 class="mt-5 text-xl font-black text-[var(--text)]">
								{step.title}
							</h3>
							<p class="muted-copy mt-3 leading-7">{step.body}</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="section-reveal py-20 md:py-28">
		<div class="grid gap-10 lg:grid-cols-[1fr_1fr]">
			<div>
				<p class="eyebrow">{page.useCasesEyebrow}</p>
				<h2
					class="mt-4 text-3xl font-black text-[var(--text)] sm:text-4xl md:text-5xl"
				>
					{page.useCasesTitle}
				</h2>
				<ul class="mt-8 space-y-4">
					{
						page.useCases.map((item) => (
							<li class="flex gap-3 leading-7 text-[var(--text-muted)]">
								<span class="text-[var(--accent-strong)] dark:text-[var(--accent)]">
									✓
								</span>
								<span>{item}</span>
							</li>
						))
					}
				</ul>
			</div>

			<article class="dark-card p-6 md:p-8">
				<p class="eyebrow">{page.contentEyebrow}</p>
				<h2 class="mt-4 text-2xl font-black text-[var(--text)] md:text-3xl">
					{page.contentTitle}
				</h2>
				<div class="mt-7 grid gap-3">
					{
						page.contentLinks.map((link) => (
							<a
								href={`/${locale}${link.href}`}
								class="rounded-2xl border border-[var(--surface-border)] bg-[var(--surface)] p-4 font-bold text-[var(--text)] transition hover:border-[var(--accent-strong)]"
							>
								{link.label}
							</a>
						))
					}
				</div>
			</article>
		</div>
	</section>

	<section class="section-band section-reveal py-20 md:py-28">
		<p class="eyebrow">{page.recommendationEyebrow}</p>
		<h2
			class="mt-4 max-w-4xl text-3xl font-black text-[var(--text)] sm:text-4xl md:text-5xl"
		>
			{page.recommendationTitle}
		</h2>
		<p class="muted-copy mt-5 max-w-2xl text-lg leading-8">
			{page.recommendationIntro}
		</p>
		<div class="mt-10 grid gap-5 lg:grid-cols-2">
			<article class="dark-card p-6">
				<h3 class="text-2xl font-black text-[var(--text)]">
					{page.recommendedForTitle}
				</h3>
				<ul class="mt-6 space-y-4">
					{
						page.recommendedFor.map((item) => (
							<li class="flex gap-3 leading-7 text-[var(--text-muted)]">
								<span class="text-[var(--accent-strong)] dark:text-[var(--accent)]">
									✓
								</span>
								<span>{item}</span>
							</li>
						))
					}
				</ul>
			</article>
			<article class="dark-card p-6">
				<h3 class="text-2xl font-black text-[var(--text)]">
					{page.notRecommendedForTitle}
				</h3>
				<ul class="mt-6 space-y-4">
					{
						page.notRecommendedFor.map((item) => (
							<li class="flex gap-3 leading-7 text-[var(--text-muted)]">
								<span class="text-[var(--accent-strong)] dark:text-[var(--accent)]">
									-
								</span>
								<span>{item}</span>
							</li>
						))
					}
				</ul>
			</article>
		</div>
	</section>

	<section class="section-band section-reveal py-20 text-center md:py-28">
		<h2 class="text-4xl font-black text-[var(--text)] md:text-6xl">
			{page.ctaTitle}
		</h2>
		<p class="muted-copy mx-auto mt-5 max-w-xl text-lg leading-8">
			{page.ctaText}
		</p>
		<a href={`/${locale}/contact`} class="button-primary mt-9">
			{page.ctaButton}
		</a>
	</section>
</BaseLayout>
