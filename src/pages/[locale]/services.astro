---
import { Icon } from "astro-icon/components";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ConversionCta from "@/components/common/ConversionCta.astro";
import ProjectArchiveCard from "@/components/projects/ProjectArchiveCard.astro";
import EngagementModels from "@/components/services/EngagementModels.astro";
import ServiceAreaCard from "@/components/services/ServiceAreaCard.astro";
import ServiceDirectory from "@/components/services/ServiceDirectory.astro";
import { getLocaleStaticPaths, getTranslations, t, type Locale } from "@/i18n";
import { getProjectPages } from "@/lib/projects";
import { getCanonicalServicePages, getServiceAreas } from "@/lib/services";
import {
	buildBreadcrumbList,
	buildCollectionPage,
	buildFaqPage,
	buildProfessionalService,
} from "@/lib/seo";
import { getCv } from "@cv";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const locale = Astro.params.locale as Locale;
const page = getTranslations(locale).services.hub;
const commercial = getTranslations(locale).services.commercial;
const cv = getCv(locale);
const areas = getServiceAreas(locale);
const services = getCanonicalServicePages(locale);
const selectedProjectIds = new Set([
	"cv-studio",
	"educash-affiliate-platform",
	"realtime-websocket-gateway",
]);
const proofProjects = getProjectPages(locale).filter((project) =>
	selectedProjectIds.has(project.id),
);
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const pagePath = `/${locale}/services/`;
const contactHref = `/${locale}/contact?service=assessment`;
const localWebDesignHref =
	locale === "es" ? "/es/diseno-web-granada/" : "/en/web-design-granada/";
const getServiceHref = (service: (typeof services)[number]) =>
	service.canonicalPath ?? `/${locale}/services/${service.slug}/`;
const structuredData = [
	buildProfessionalService({
		site,
		path: pagePath,
		name: page.schema.name,
		description: page.schema.description,
		providerName: cv.name,
		providerUrl: new URL(`/${locale}/`, site).toString(),
		areaServed: page.schema.areaServed,
		sameAs: [cv.links.linkedin, cv.links.github],
		services: areas.map((area) => ({
			name: area.title,
			description: area.description,
			path: getServiceHref(area.primaryService),
			offers: area.primaryService.pricingOptions.map((option) => ({
				key: option.key,
				name: option.label,
				description: option.description,
				price: option.amount,
				currency: option.currency,
				billingUnit: option.billingUnit,
				path: getServiceHref(area.primaryService),
				priceNote: page.schema.priceNote,
			})),
		})),
	}),
	buildCollectionPage(site, pagePath, page.meta.title, page.meta.description),
	buildFaqPage(page.faq),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}/` },
		{ name: t(locale, "nav.services"), path: pagePath },
	]),
];
---

<BaseLayout
	title={page.meta.title}
	description={page.meta.description}
	canonicalPath={pagePath}
	structuredData={structuredData}
>
	<div class="services-page">
		<section
			data-services-hero
			class="services-hero section-reveal"
			aria-labelledby="services-title"
		>
			<div class="services-hero__copy">
				<p class="eyebrow">{page.eyebrow}</p>
				<h1 id="services-title">
					{page.title}
					<span>{page.titleAccent}</span>
				</h1>
				<p class="services-hero__intro">{page.intro}</p>
				<div class="services-hero__actions">
					<a href={contactHref} class="button-action">
						{page.heroPrimaryCta}
						<Icon name="arrow-right" class="h-4 w-4" aria-hidden="true" />
					</a>
					<a href={localWebDesignHref} class="button-secondary">
						{page.heroSecondaryCta}
					</a>
				</div>
			</div>

			<aside class="services-hero__signals" aria-label={page.bestForLead}>
				<div class="services-hero__signal-heading">
					<span aria-hidden="true">01</span>
					<Icon name="badge-check" class="h-7 w-7" aria-hidden="true" />
				</div>
				<p><strong>{page.bestForLead}</strong> {page.bestForText}</p>
				<ul>
					{
						page.heroSignals.map((signal) => (
							<li>
								<Icon name="check" class="h-4 w-4" aria-hidden="true" />
								<span>{signal}</span>
							</li>
						))
					}
				</ul>
			</aside>
		</section>

		<section
			data-services-areas
			class="services-areas section-reveal"
			aria-labelledby="services-areas-title"
		>
			<header class="services-section-heading">
				<div>
					<p class="eyebrow">{page.areasEyebrow}</p>
					<h2 id="services-areas-title">{page.areasTitle}</h2>
				</div>
				<p>{page.areasIntro}</p>
			</header>

			<div class="services-areas__grid stagger-children">
				{
					areas.map((area, index) => (
						<ServiceAreaCard
							locale={locale}
							area={area}
							number={String(index + 1).padStart(2, "0")}
							copy={commercial.common}
						/>
					))
				}
			</div>
		</section>

		<div data-engagement-models>
			<EngagementModels
				content={commercial.engagement}
				mostCommonLabel={commercial.common.mostCommon}
			/>
		</div>

		<section
			data-services-proof
			class="services-proof section-reveal"
			aria-labelledby="services-proof-title"
		>
			<header class="services-section-heading">
				<div>
					<p class="eyebrow">{page.proofEyebrow}</p>
					<h2 id="services-proof-title">{page.proofShowcaseTitle}</h2>
				</div>
				<p>{page.proofShowcaseIntro}</p>
			</header>

			<div class="services-proof__grid stagger-children">
				{
					proofProjects.map((project) => (
						<ProjectArchiveCard
							project={project}
							locale={locale}
							viewLabel={page.viewProject}
						/>
					))
				}
			</div>
		</section>

		<section
			data-services-process
			class="services-process section-reveal"
			aria-labelledby="services-process-title"
		>
			<header class="services-section-heading">
				<div>
					<p class="eyebrow">{page.processEyebrow}</p>
					<h2 id="services-process-title">{page.processTitle}</h2>
				</div>
				<p>{page.processIntro}</p>
			</header>

			<ol class="services-process__steps">
				{
					page.process.map((step, index) => (
						<li>
							<span aria-hidden="true">
								{String(index + 1).padStart(2, "0")}
							</span>
							<h3>{step.title}</h3>
							<p>{step.body}</p>
						</li>
					))
				}
			</ol>
		</section>

		<div data-service-directory>
			<ServiceDirectory
				locale={locale}
				areas={areas}
				content={commercial.directory}
			/>
		</div>

		<section
			data-services-faq
			class="services-faq section-reveal"
			aria-labelledby="services-faq-title"
		>
			<header class="services-section-heading">
				<div>
					<p class="eyebrow">{page.faqEyebrow}</p>
					<h2 id="services-faq-title">{page.faqTitle}</h2>
				</div>
				<p>{page.faqIntro}</p>
			</header>

			<div class="services-faq__list">
				{
					page.faq.map((item, index) => (
						<details open={index === 0}>
							<summary>
								<span>{item.question}</span>
								<Icon name="plus" class="h-5 w-5" aria-hidden="true" />
							</summary>
							<p>{item.answer}</p>
						</details>
					))
				}
			</div>
		</section>

		<ConversionCta
			eyebrow={page.ctaEyebrow}
			title={page.ctaTitle}
			text={page.ctaText}
			primary={{ label: page.ctaButton, href: contactHref }}
			secondary={{
				label: page.heroSecondaryCta,
				href: `/${locale}/projects/`,
			}}
			headingId="services-conversion-title"
		/>
	</div>
</BaseLayout>

<style>
	.services-page {
		--services-section-space: clamp(3.25rem, 5vw, 4.5rem);
		--services-content-gap: 2.25rem;
		--services-card-padding: clamp(1.35rem, 2vw, 1.75rem);
		--services-list-gap: 0.75rem;
		--services-heading: clamp(2.2rem, 4vw, 3.85rem);
	}

	.services-page .eyebrow {
		color: var(--action);
	}

	.services-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(19rem, 0.55fr);
		gap: clamp(2.5rem, 7vw, 7rem);
		align-items: end;
		padding-block: clamp(1.5rem, 3vw, 2.5rem) clamp(3.5rem, 5vw, 4.5rem);
	}

	.services-hero h1 {
		max-width: 56rem;
		margin-top: 1rem;
		color: var(--home-navy);
		font-size: clamp(3rem, 6.25vw, 6rem);
		font-weight: 950;
		letter-spacing: -0.07em;
		line-height: 0.93;
		text-wrap: balance;
	}

	.services-hero h1 span {
		display: block;
		color: var(--action);
	}

	.services-hero__intro {
		max-width: 45rem;
		margin-top: 1.6rem;
		color: var(--text-muted);
		font-size: clamp(1rem, 1.5vw, 1.18rem);
		line-height: 1.75;
	}

	.services-hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 2rem;
	}

	.services-hero__signals {
		padding: 1.6rem;
		border: 1px solid var(--surface-border);
		border-radius: 1.25rem;
		background:
			radial-gradient(
				circle at 100% 0%,
				color-mix(in srgb, var(--action) 12%, transparent),
				transparent 12rem
			),
			var(--surface);
		box-shadow: var(--shadow-card);
	}

	.services-hero__signal-heading {
		display: flex;
		align-items: center;
		justify-content: space-between;
		color: var(--action);
	}

	.services-hero__signal-heading span {
		font-size: 0.7rem;
		font-weight: 900;
		letter-spacing: 0.18em;
	}

	.services-hero__signals > p {
		margin-top: 1.5rem;
		color: var(--text-muted);
		font-size: 0.86rem;
		line-height: 1.65;
	}

	.services-hero__signals > p strong {
		color: var(--text);
	}

	.services-hero__signals ul {
		display: grid;
		gap: 0.8rem;
		margin-top: 1.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--surface-border);
	}

	.services-hero__signals li {
		display: flex;
		gap: 0.7rem;
		align-items: start;
		color: var(--text);
		font-size: 0.8rem;
		font-weight: 750;
		line-height: 1.5;
	}

	.services-hero__signals li :global(svg) {
		flex: none;
		margin-top: 0.15rem;
		color: var(--action);
	}

	.services-areas,
	.services-process,
	.services-faq {
		padding-block: var(--services-section-space);
	}

	.services-section-heading {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.72fr);
		gap: 2rem 5rem;
		align-items: end;
	}

	.services-section-heading h2 {
		max-width: 18ch;
		margin-top: 0.9rem;
		color: var(--home-navy);
		font-size: var(--services-heading);
		font-weight: 950;
		letter-spacing: -0.06em;
		line-height: 0.98;
		text-wrap: balance;
	}

	.services-section-heading > p {
		color: var(--text-muted);
		line-height: 1.75;
	}

	.services-areas__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.25rem;
		margin-top: var(--services-content-gap);
	}

	.services-proof {
		width: 100vw;
		margin-inline: calc(50% - 50vw);
		padding: var(--services-section-space) max(1rem, calc((100vw - 88rem) / 2));
		background: var(--bg-band);
	}

	.services-proof__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: var(--services-content-gap);
	}

	.services-process__steps {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		margin-top: var(--services-content-gap);
		border-block: 1px solid var(--surface-border);
	}

	.services-process__steps li {
		padding: 2rem;
	}

	.services-process__steps li + li {
		border-left: 1px solid var(--surface-border);
	}

	.services-process__steps span {
		color: var(--action);
		font-size: 0.7rem;
		font-weight: 900;
		letter-spacing: 0.18em;
	}

	.services-process__steps h3 {
		margin-top: 1.5rem;
		color: var(--text);
		font-size: 1.25rem;
		font-weight: 900;
	}

	.services-process__steps p {
		margin-top: 0.75rem;
		color: var(--text-muted);
		font-size: 0.88rem;
		line-height: 1.65;
	}

	.services-faq__list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0 2.5rem;
		margin-top: var(--services-content-gap);
		border-top: 1px solid var(--surface-border);
	}

	.services-faq details {
		border-bottom: 1px solid var(--surface-border);
	}

	.services-faq summary {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1rem;
		align-items: center;
		min-height: 5.25rem;
		padding-block: 1rem;
		color: var(--text);
		font-size: 1rem;
		font-weight: 850;
		line-height: 1.45;
		cursor: pointer;
		list-style: none;
	}

	.services-faq summary::-webkit-details-marker {
		display: none;
	}

	.services-faq summary:focus-visible {
		border-radius: 0.75rem;
		outline: 2px solid var(--action);
		outline-offset: 4px;
	}

	.services-faq summary :global(svg) {
		color: var(--action);
		transition: transform 180ms ease;
	}

	.services-faq details[open] summary :global(svg) {
		transform: rotate(45deg);
	}

	.services-faq details p {
		max-width: 45rem;
		padding: 0 2.5rem 1.5rem 0;
		color: var(--text-muted);
		font-size: 1rem;
		line-height: 1.7;
	}

	@media (max-width: 900px) {
		.services-hero,
		.services-section-heading {
			grid-template-columns: 1fr;
		}

		.services-hero {
			gap: 2rem;
		}

		.services-hero__signals {
			max-width: 42rem;
		}

		.services-proof__grid,
		.services-process__steps {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.services-process__steps li:nth-child(3) {
			border-top: 1px solid var(--surface-border);
			border-left: 0;
		}

		.services-process__steps li:nth-child(4) {
			border-top: 1px solid var(--surface-border);
		}
	}

	@media (max-width: 680px) {
		.services-page {
			--services-content-gap: 1.75rem;
		}

		.services-hero {
			padding-top: 1.25rem;
		}

		.services-hero h1 {
			font-size: clamp(2.6rem, 12vw, 3.6rem);
		}

		.services-hero__actions,
		.services-hero__actions a {
			width: 100%;
		}

		.services-areas__grid,
		.services-proof__grid,
		.services-process__steps,
		.services-faq__list {
			grid-template-columns: 1fr;
		}

		.services-process__steps li {
			padding-inline: 0;
		}

		.services-process__steps li + li,
		.services-process__steps li:nth-child(4) {
			border-top: 1px solid var(--surface-border);
			border-left: 0;
		}
	}
</style>
