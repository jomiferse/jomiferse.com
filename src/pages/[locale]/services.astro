---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ServicesExitIntent from "@/components/common/ServicesExitIntent.astro";
import { getCommercialLandingPages } from "@/lib/commercial-landings";
import { getServiceGroups, getServicePages } from "@/lib/services";
import { getLocaleStaticPaths, getTranslations, t } from "@/i18n";
import {
	buildBreadcrumbList,
	buildCollectionPage,
	buildFaqPage,
	buildProfessionalService,
} from "@/lib/seo";
import { getCv } from "@cv";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const cv = getCv(locale);
const services = getServicePages(locale);
const serviceGroups = getServiceGroups(locale);
const commercialLandings = getCommercialLandingPages(locale);
const page = getTranslations(locale).services.hub;
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const contactHref = `/${locale}/contact`;
const exitIntentWhatsappMessage =
	locale === "es"
		? "Hola José Miguel, estaba revisando tus servicios y me gustaría contarte mi caso."
		: "Hi José Miguel, I was reviewing your services and would like to tell you about my case.";
const exitIntentWhatsappHref = `https://wa.me/34609221290?text=${encodeURIComponent(
	exitIntentWhatsappMessage,
)}`;
const getServiceHref = (service: (typeof services)[number]) =>
	service.canonicalPath ?? `/${locale}/services/${service.slug}/`;
const schemaServices = services.filter((service) => !service.canonicalPath);
const keywords =
	locale === "es"
		? [
				"Consultoría informática freelance",
				"Diseño web WordPress",
				"Software a medida",
				"Automatización de procesos",
				"Integraciones API",
				"Desarrollador full-stack freelance",
			]
		: [
				"Freelance IT Consulting",
				"WordPress Web Design",
				"Custom Software",
				"Process Automation",
				"API Integrations",
				"Freelance Full-Stack Developer",
			];
const commercialLandingCopy =
	locale === "es"
		? {
				eyebrow: "Búsquedas concretas",
				title: "Páginas para problemas concretos",
				intro:
					"Algunas necesidades no empiezan con el nombre técnico del servicio, sino con un problema claro: ordenar un proceso, automatizar tareas o elegir bien antes de invertir.",
			}
		: {
				eyebrow: "Specific searches",
				title: "Pages for concrete problems",
				intro:
					"Some needs do not start with the technical name of the service, but with a clear problem: organizing a workflow, automating tasks or making a better decision before investing.",
			};
const structuredData = [
	buildProfessionalService({
		site,
		path: `/${locale}/services`,
		name: page.schema.name,
		description: page.schema.description,
		providerName: cv.name,
		providerUrl: new URL(`/${locale}`, site).toString(),
		areaServed: page.schema.areaServed,
		sameAs: [cv.links.linkedin, cv.links.github],
		services: schemaServices.map((service) => ({
			name: service.title,
			description: service.description,
			path: getServiceHref(service),
		})),
	}),
	buildCollectionPage(
		site,
		`/${locale}/services`,
		page.meta.title,
		page.meta.description,
	),
	buildFaqPage(page.faq),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}` },
		{ name: t(locale, "nav.services"), path: `/${locale}/services` },
	]),
];
---

<BaseLayout
	title={page.meta.title}
	description={page.meta.description}
	structuredData={structuredData}
	keywords={keywords}
>
	<section class="section-reveal py-10 md:py-20">
		<p class="eyebrow">{page.eyebrow}</p>
		<h1
			class="mt-5 max-w-4xl text-5xl font-black text-[var(--text)] md:text-7xl"
		>
			{page.title}
			<span class="accent-text">{page.titleAccent}</span>
		</h1>
		<p class="muted-copy mt-6 max-w-2xl text-lg leading-8">{page.intro}</p>
		<div class="mt-9 flex flex-col gap-3 sm:flex-row">
			<a href={`/${locale}/contact`} class="button-primary w-full sm:w-auto">
				{page.heroPrimaryCta}
			</a>
			<a href={`/${locale}/projects`} class="button-secondary w-full sm:w-auto">
				{page.heroSecondaryCta}
			</a>
		</div>
	</section>

	<section class="section-band section-reveal py-16">
		<p class="muted-copy text-lg leading-8">
			<span class="font-bold text-[var(--text)]">{page.bestForLead}</span>
			{" "}
			{page.bestForText}
		</p>
	</section>

	<section class="section-reveal py-16 md:py-24">
		<div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
			<div>
				<p class="eyebrow">{page.definitionEyebrow}</p>
				<h2
					class="mt-4 text-3xl font-black text-[var(--text)] sm:text-4xl md:text-5xl"
				>
					{page.definitionTitle}
				</h2>
				<div class="mt-6 space-y-4">
					{
						page.definitionBody.map((paragraph) => (
							<p class="muted-copy text-lg leading-8">{paragraph}</p>
						))
					}
				</div>
			</div>

			<div>
				<p class="eyebrow">{page.advantagesEyebrow}</p>
				<h2 class="mt-4 text-2xl font-black text-[var(--text)] md:text-3xl">
					{page.advantagesTitle}
				</h2>
				<div class="mt-7 grid gap-4 sm:grid-cols-2">
					{
						page.advantages.map((advantage) => (
							<article class="dark-card p-5">
								<h3 class="text-lg font-black text-[var(--text)]">
									{advantage.title}
								</h3>
								<p class="muted-copy mt-3 leading-7">{advantage.body}</p>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section class="section-reveal py-16 md:py-24">
		<div class="mb-12 max-w-3xl">
			<p class="eyebrow">{page.servicesEyebrow}</p>
			<h2
				class="mt-4 text-3xl font-black text-[var(--text)] sm:text-4xl md:text-5xl"
			>
				{page.servicesTitle}
			</h2>
			<p class="muted-copy mt-5 text-lg leading-8">{page.servicesIntro}</p>
		</div>

		<div class="stagger-children space-y-6">
			{
				serviceGroups.map((group) => (
					<article class="hairline border-t pt-8 first:border-t-0 first:pt-0">
						<div class="grid gap-7 lg:grid-cols-[0.38fr_0.62fr]">
							<div>
								<p class="font-black text-[var(--accent-strong)] dark:text-[var(--accent)]">
									{group.number}
								</p>
								<h3 class="mt-5 text-3xl font-black text-[var(--text)] md:text-4xl">
									{group.title}
								</h3>
								<p class="muted-copy mt-4 leading-7">{group.description}</p>
								<ul class="mt-6 space-y-3">
									{group.bullets.map((item) => (
										<li class="flex gap-3 text-sm leading-6 text-[var(--text-muted)]">
											<span class="text-[var(--accent-strong)] dark:text-[var(--accent)]">
												✓
											</span>
											<span>{item}</span>
										</li>
									))}
								</ul>
								<a
									href={getServiceHref(group.primaryService)}
									class="button-secondary mt-7 w-full justify-center sm:w-fit"
								>
									{page.viewService}
								</a>
							</div>

							<div>
								<p class="eyebrow">{page.included}</p>
								<div class="mt-4 grid gap-3 sm:grid-cols-2">
									{group.offerings.map((offering) => (
										<a
											href={`/${locale}/services/${offering.slug}/`}
											class="group rounded-lg border border-[var(--surface-border)] bg-[var(--surface-strong)] p-4 transition hover:-translate-y-0.5 hover:border-[var(--accent-line)] dark:bg-white/[0.03]"
										>
											<h3 class="text-base font-black text-[var(--text)] group-hover:text-[var(--accent-strong)] dark:group-hover:text-[var(--accent)]">
												{offering.title}
											</h3>
											<p class="muted-copy mt-2 text-sm leading-6">
												{offering.description}
											</p>
										</a>
									))}
								</div>
								<div class="hairline mt-6 border-t pt-5">
									<p class="eyebrow">{page.serviceLinks}</p>
									<div class="mt-4 flex flex-wrap gap-3">
										{group.services.map((service) => (
											<a
												href={getServiceHref(service)}
												class="tag-pill hover:border-[var(--accent-strong)]"
											>
												{service.shortTitle}
											</a>
										))}
									</div>
								</div>
							</div>
						</div>
					</article>
				))
			}
		</div>
	</section>

	<section class="section-band section-reveal py-16 md:py-24">
		<div class="mb-10 max-w-3xl">
			<p class="eyebrow">{commercialLandingCopy.eyebrow}</p>
			<h2
				class="mt-4 text-3xl font-black text-[var(--text)] sm:text-4xl md:text-5xl"
			>
				{commercialLandingCopy.title}
			</h2>
			<p class="muted-copy mt-5 text-lg leading-8">
				{commercialLandingCopy.intro}
			</p>
		</div>
		<div class="stagger-children grid gap-4 md:grid-cols-2 lg:grid-cols-3">
			{
				commercialLandings.map((landing) => (
					<a
						href={`/${locale}/${landing.slug}/`}
						class="group rounded-lg border border-[var(--surface-border)] bg-[var(--surface)] p-5 transition hover:-translate-y-0.5 hover:border-[var(--accent-line)] md:p-6"
					>
						<p class="text-sm font-black text-[var(--accent-strong)] dark:text-[var(--accent)]">
							{landing.eyebrow}
						</p>
						<h3 class="mt-4 text-xl font-black text-[var(--text)] group-hover:text-[var(--accent-strong)] dark:group-hover:text-[var(--accent)]">
							{landing.title}
						</h3>
						<p class="muted-copy mt-3 text-sm leading-6">
							{landing.metaDescription}
						</p>
					</a>
				))
			}
		</div>
	</section>

	<section class="section-reveal py-20 md:py-28">
		<div class="grid gap-10 lg:grid-cols-[0.75fr_1.25fr]">
			<div>
				<p class="eyebrow">{page.recommendationEyebrow}</p>
				<h2
					class="mt-4 text-3xl font-black text-[var(--text)] sm:text-4xl md:text-5xl"
				>
					{page.recommendationTitle}
				</h2>
				<p class="muted-copy mt-5 text-lg leading-8">
					{page.recommendationIntro}
				</p>
			</div>
			<div class="grid gap-5">
				<article class="dark-card p-6">
					<h3 class="text-2xl font-black text-[var(--text)]">
						{page.recommendedForTitle}
					</h3>
					<ul class="mt-6 space-y-4">
						{
							page.recommendedFor.map((item) => (
								<li class="flex gap-3 leading-7 text-[var(--text-muted)]">
									<span class="text-[var(--accent-strong)] dark:text-[var(--accent)]">
										✓
									</span>
									<span>{item}</span>
								</li>
							))
						}
					</ul>
				</article>
				<article class="dark-card p-6">
					<h3 class="text-2xl font-black text-[var(--text)]">
						{page.notRecommendedForTitle}
					</h3>
					<ul class="mt-6 space-y-4">
						{
							page.notRecommendedFor.map((item) => (
								<li class="flex gap-3 leading-7 text-[var(--text-muted)]">
									<span class="text-[var(--accent-strong)] dark:text-[var(--accent)]">
										-
									</span>
									<span>{item}</span>
								</li>
							))
						}
					</ul>
				</article>
			</div>
		</div>
	</section>

	<section class="section-band section-reveal py-20 md:py-28">
		<div class="grid gap-10 lg:grid-cols-[0.75fr_1.25fr]">
			<div>
				<p class="eyebrow">{page.processEyebrow}</p>
				<h2
					class="mt-4 text-3xl font-black text-[var(--text)] sm:text-4xl md:text-5xl"
				>
					{page.processTitle}
				</h2>
			</div>
			<div class="stagger-children grid gap-4 sm:grid-cols-2">
				{
					page.process.map((step, index) => (
						<article class="dark-card p-5">
							<p class="font-black text-[var(--accent-strong)] dark:text-[var(--accent)]">
								{String(index + 1).padStart(2, "0")}
							</p>
							<h3 class="mt-5 text-xl font-black text-[var(--text)]">
								{step.title}
							</h3>
							<p class="muted-copy mt-3 leading-7">{step.body}</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="section-reveal py-20 md:py-28">
		<div class="grid gap-10 lg:grid-cols-[1fr_1fr]">
			<div>
				<p class="eyebrow">{page.useCasesEyebrow}</p>
				<h2
					class="mt-4 text-3xl font-black text-[var(--text)] sm:text-4xl md:text-5xl"
				>
					{page.useCasesTitle}
				</h2>
				<ul class="mt-8 space-y-4">
					{
						page.useCases.map((item) => (
							<li class="flex gap-3 leading-7 text-[var(--text-muted)]">
								<span class="text-[var(--accent-strong)] dark:text-[var(--accent)]">
									✓
								</span>
								<span>{item}</span>
							</li>
						))
					}
				</ul>
			</div>

			<article class="dark-card p-6 md:p-8">
				<p class="eyebrow">{page.contentEyebrow}</p>
				<h2 class="mt-4 text-2xl font-black text-[var(--text)] md:text-3xl">
					{page.contentTitle}
				</h2>
				<div class="mt-7 grid gap-3">
					{
						page.contentLinks.map((link) => (
							<a
								href={`/${locale}${link.href}`}
								class="rounded-2xl border border-[var(--surface-border)] bg-[var(--surface)] p-4 font-bold text-[var(--text)] transition hover:border-[var(--accent-strong)]"
							>
								{link.label}
							</a>
						))
					}
				</div>
			</article>
		</div>
	</section>

	<section class="section-band section-reveal py-20 md:py-28">
		<div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
			<div>
				<p class="eyebrow">{page.proofEyebrow}</p>
				<h2
					class="mt-4 text-3xl font-black text-[var(--text)] sm:text-4xl md:text-5xl"
				>
					{page.proofTitle}
				</h2>
				<p class="muted-copy mt-5 text-lg leading-8">{page.proofText}</p>
				<div class="mt-8 flex flex-wrap gap-3">
					{
						page.proofLinks.map((link) => (
							<a
								href={`/${locale}${link.href}`}
								class="tag-pill hover:border-[var(--accent-strong)]"
							>
								{link.label}
							</a>
						))
					}
				</div>
			</div>
			<div class="grid gap-4 sm:grid-cols-2">
				{
					page.proofPoints.map((item) => (
						<article class="dark-card p-5">
							<p class="muted-copy leading-7">{item}</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="section-reveal py-20 md:py-28">
		<div class="mb-10 max-w-3xl">
			<p class="eyebrow">{page.faqEyebrow}</p>
			<h2
				class="mt-4 text-3xl font-black text-[var(--text)] sm:text-4xl md:text-5xl"
			>
				{page.faqTitle}
			</h2>
		</div>
		<div class="grid gap-4 lg:grid-cols-2">
			{
				page.faq.map((item) => (
					<article class="hairline border-t pt-6">
						<h3 class="text-xl font-black text-[var(--text)]">
							{item.question}
						</h3>
						<p class="muted-copy mt-3 leading-7">{item.answer}</p>
					</article>
				))
			}
		</div>
	</section>

	<section class="section-band section-reveal py-20 text-center md:py-28">
		<h2 class="text-4xl font-black text-[var(--text)] md:text-6xl">
			{page.ctaTitle}
		</h2>
		<p class="muted-copy mx-auto mt-5 max-w-xl text-lg leading-8">
			{page.ctaText}
		</p>
		<a href={contactHref} class="button-primary mt-9">
			{page.ctaButton}
		</a>
	</section>

	<ServicesExitIntent
		locale={locale}
		contactHref={contactHref}
		whatsappHref={exitIntentWhatsappHref}
	/>
</BaseLayout>
