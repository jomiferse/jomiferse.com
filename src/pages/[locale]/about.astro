---
import { Icon } from "astro-icon/components";
import AboutExperience from "@/components/about/AboutExperience.astro";
import AboutHelp from "@/components/about/AboutHelp.astro";
import ConversionCta from "@/components/common/ConversionCta.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLocaleStaticPaths, getTranslations, t } from "@/i18n";
import { getCv } from "@cv";
import { buildBreadcrumbList, buildCollectionPage } from "@/lib/seo";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const page = getTranslations(locale).about.page;
const cv = getCv(locale);
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const structuredData = [
	buildCollectionPage(
		site,
		`/${locale}/about`,
		page.meta.title,
		page.meta.description,
	),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}` },
		{ name: t(locale, "nav.about"), path: `/${locale}/about` },
	]),
];
---

<BaseLayout
	title={page.meta.title}
	description={page.meta.description}
	structuredData={structuredData}
	keywords={[
		"Consultor informático freelance",
		"Full-stack developer",
		"Automatización",
		"Software a medida",
		"Spring Boot",
	]}
>
	<div class="about-page">
		<section
			class="about-hero section-reveal grid gap-12 pt-6 pb-16 md:pt-10 md:pb-18 lg:grid-cols-[minmax(0,1.08fr)_minmax(19rem,0.72fr)] lg:items-center lg:gap-18"
		>
			<div>
				<p class="eyebrow">{page.eyebrow}</p>
				<h1
					class="mt-5 max-w-4xl text-5xl leading-[0.98] font-black sm:text-6xl md:text-7xl"
				>
					{page.title}
					<span class="block">{page.titleAccent}</span>
				</h1>
				<p class="muted-copy mt-7 max-w-3xl text-lg leading-8 md:text-xl">
					{page.intro}
				</p>
				<div class="mt-9 flex flex-col gap-3 sm:flex-row">
					<a
						href={`/${locale}/contact?service=assessment`}
						class="button-action w-full sm:w-auto"
					>
						{page.primaryCta}
						<Icon name="arrow-right" class="h-4 w-4" />
					</a>
					<a
						href={`/${locale}/services`}
						class="button-secondary w-full sm:w-auto"
					>
						{page.secondaryCta}
					</a>
				</div>
			</div>

			<figure
				class="about-portrait relative mx-auto w-full max-w-[23rem] lg:mr-2"
			>
				<div class="about-portrait__frame" aria-hidden="true"></div>
				<img
					src="/images/avatar.avif"
					alt={page.avatarAlt}
					width="640"
					height="760"
					class="relative aspect-[4/5] w-full rounded-[1.15rem] border border-[var(--surface-border)] object-cover shadow-[var(--shadow-card)]"
					decoding="async"
					fetchpriority="high"
				/>
				<figcaption class="about-portrait__note">
					{page.portraitNote}
				</figcaption>
			</figure>
		</section>

		<section class="about-trust" aria-label={page.eyebrow}>
			{
				page.trustSignals.map((signal) => (
					<div class="about-trust__item">
						<p class="text-lg font-black text-[var(--text)]">{signal.value}</p>
						<p class="muted-copy mt-1 text-sm">{signal.label}</p>
					</div>
				))
			}
		</section>

		<AboutHelp content={page.help} />

		<AboutExperience
			locale={locale}
			content={page.experience}
			experience={cv.experience}
			yearsWorking={cv.yearsWorking}
		/>

		<section class="section-band section-reveal py-18 md:py-20">
			<div class="grid gap-10 lg:grid-cols-[0.4fr_0.6fr] lg:gap-16">
				<header>
					<p class="eyebrow">{page.workingStyle.eyebrow}</p>
					<h2 class="mt-4 text-4xl font-black md:text-5xl">
						{page.workingStyle.title}
					</h2>
					<p class="muted-copy mt-5 max-w-xl leading-8">
						{page.workingStyle.intro}
					</p>
				</header>
				<div
					class="divide-y divide-[var(--surface-border)] border-y border-[var(--surface-border)]"
				>
					{
						page.workingStyle.items.map((item) => (
							<article class="grid gap-3 py-6 sm:grid-cols-[3rem_1fr] md:py-7">
								<p class="font-black text-[var(--action)]">{item.number}</p>
								<div>
									<h3 class="text-xl font-black text-[var(--text)]">
										{item.title}
									</h3>
									<p class="muted-copy mt-2 leading-7">{item.body}</p>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section-reveal py-16 md:py-18">
			<div
				class="grid gap-7 border-y border-[var(--surface-border)] py-9 md:grid-cols-[0.34fr_1fr_auto] md:items-center md:py-11"
			>
				<p class="eyebrow">{page.educationSummary.eyebrow}</p>
				<div>
					<h2 class="text-2xl font-black md:text-3xl">
						{page.educationSummary.title}
					</h2>
					<p class="muted-copy mt-3 max-w-2xl leading-7">
						{page.educationSummary.body}
					</p>
				</div>
				<a
					href={`/${locale}/education`}
					class="button-secondary w-full md:w-auto"
				>
					{page.educationSummary.link}
					<Icon name="arrow-right" class="h-4 w-4" />
				</a>
			</div>
		</section>

		<ConversionCta
			eyebrow={page.cta.eyebrow}
			title={page.cta.title}
			text={page.cta.text}
			primary={{
				label: page.cta.primary,
				href: `/${locale}/contact?service=assessment`,
			}}
			secondary={{
				label: page.cta.secondary,
				href: `/${locale}/projects`,
			}}
			headingId="about-conversion-title"
		/>
	</div>
</BaseLayout>
