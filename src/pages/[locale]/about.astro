---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getLocaleStaticPaths, getTranslations, t } from "@/i18n";
import { buildBreadcrumbList, buildCollectionPage } from "@/lib/seo";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const page = getTranslations(locale).about.page;
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const keywords =
	locale === "es"
		? [
				"Desarrollador full-stack freelance",
				"Desarrollo backend",
				"Spring Boot",
				"Herramientas internas",
				"Integraciones API",
			]
		: [
				"Freelance Full-Stack Developer",
				"Backend Development",
				"Spring Boot",
				"Internal Tools",
				"API Integrations",
			];
const structuredData = [
	buildCollectionPage(
		site,
		`/${locale}/about`,
		page.meta.title,
		page.meta.description,
	),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}` },
		{ name: t(locale, "nav.about"), path: `/${locale}/about` },
	]),
];
---

<BaseLayout
	title={page.meta.title}
	description={page.meta.description}
	structuredData={structuredData}
	keywords={keywords}
>
	<section
		class="section-reveal grid gap-10 py-10 md:py-20 lg:grid-cols-[minmax(0,1fr)_minmax(18rem,24rem)] lg:items-center lg:gap-16"
	>
		<div>
			<p class="eyebrow">{page.eyebrow}</p>
			<h1
				class="mt-5 max-w-4xl text-5xl font-black text-[var(--text)] md:text-7xl"
			>
				{page.title}
				<span class="accent-text">{page.titleAccent}</span>
			</h1>
			<p class="muted-copy mt-6 max-w-2xl text-lg leading-8">{page.intro}</p>
			<div class="mt-9 flex flex-col gap-3 sm:flex-row">
				<a href={`/${locale}/services`} class="button-primary w-full sm:w-auto">
					{page.primaryCta}
					<Icon name="arrow-right" class="h-4 w-4" />
				</a>
				<a
					href={`/${locale}/contact`}
					class="button-secondary w-full sm:w-auto"
				>
					{page.secondaryCta}
				</a>
			</div>
		</div>
		<figure
			class="relative mx-auto w-full max-w-[21rem] justify-self-center lg:mx-0 lg:justify-self-end"
		>
			<div
				class="absolute -inset-3 rounded-[1.4rem] border border-[var(--accent-line)] bg-[var(--accent-soft)]"
				aria-hidden="true"
			>
			</div>
			<div
				class="relative overflow-hidden rounded-[1.1rem] border border-[var(--surface-border)] bg-[var(--surface)] shadow-[var(--shadow-card)]"
			>
				<img
					src="/images/avatar.avif"
					alt={page.avatarAlt}
					width="640"
					height="760"
					class="aspect-[4/5] w-full object-cover"
					decoding="async"
					fetchpriority="high"
				/>
			</div>
		</figure>
	</section>

	<section class="section-band section-reveal py-20 md:py-28">
		<p class="eyebrow">{page.what}</p>
		<div class="stagger-children mt-8 grid gap-5 md:grid-cols-2">
			{
				page.blocks.map((block) => (
					<article class="dark-card hover-card p-6">
						<h2 class="text-2xl font-black text-[var(--text)]">
							{block.title}
						</h2>
						<p class="muted-copy mt-4 leading-7">{block.body}</p>
					</article>
				))
			}
		</div>
	</section>

	<section class="section-reveal py-20 md:py-28">
		<h2 class="text-4xl font-black text-[var(--text)] md:text-5xl">
			{page.how}
		</h2>
		<div class="hairline mt-10 divide-y border-y">
			{
				page.steps.map((step) => (
					<div class="grid gap-4 py-6 md:grid-cols-[6rem_0.55fr_1fr] md:items-center">
						<p class="font-black text-[var(--accent-strong)] dark:text-[var(--accent)]">
							{step.number}
						</p>
						<h3 class="text-xl font-black text-[var(--text)]">{step.title}</h3>
						<p class="muted-copy leading-7">{step.body}</p>
					</div>
				))
			}
		</div>
	</section>

	<section class="section-band section-reveal py-20 md:py-28">
		<p class="eyebrow">{page.background}</p>
		<h2
			class="mt-4 max-w-3xl text-4xl font-black text-[var(--text)] md:text-5xl"
		>
			{page.backgroundTitle}
		</h2>
		<div class="muted-copy mt-8 max-w-3xl space-y-5 text-lg leading-8">
			<p>{page.backgroundP1}</p>
			<p>{page.backgroundP2}</p>
		</div>
		<a
			href={`/${locale}/education`}
			class="button-secondary mt-9 w-full sm:w-fit"
		>
			{page.educationLink}
			<Icon name="arrow-right" class="h-4 w-4" />
		</a>
		<div class="mt-5 flex flex-col gap-3 sm:flex-row">
			<a href={`/${locale}/services`} class="button-primary w-full sm:w-auto">
				{page.servicesLink}
			</a>
			<a href={`/${locale}/projects`} class="button-secondary w-full sm:w-auto">
				{page.projectsLink}
			</a>
			<a href={`/${locale}/contact`} class="button-secondary w-full sm:w-auto">
				{page.contactLink}
			</a>
		</div>
	</section>
</BaseLayout>
