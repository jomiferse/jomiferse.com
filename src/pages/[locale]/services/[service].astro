---
import { Icon } from "astro-icon/components";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/forms/ContactForm.astro";
import ConversionCta from "@/components/common/ConversionCta.astro";
import ServicesExitIntent from "@/components/common/ServicesExitIntent.astro";
import ServiceIconBadge from "@/components/services/ServiceIconBadge.astro";
import ServicePricingGrid from "@/components/services/ServicePricingGrid.astro";
import ServiceProofCard from "@/components/services/ServiceProofCard.astro";
import ServiceTrustStrip from "@/components/services/ServiceTrustStrip.astro";
import { getTranslations, locales, t, type Locale } from "@/i18n";
import { getProjectPages } from "@/lib/projects";
import {
	getRelatedServices,
	getService,
	getServiceAlternatePaths,
	getServicePages,
} from "@/lib/services";
import { buildBreadcrumbList, buildFaqPage, buildServicePage } from "@/lib/seo";
import { getCv } from "@cv";

export function getStaticPaths() {
	return locales.flatMap((locale) =>
		getServicePages(locale).map((service) => ({
			params: { locale, service: service.slug },
		})),
	);
}

const locale = Astro.params.locale as Locale;
const slug = Astro.params.service ?? "";
const service = getService(locale, slug);
if (!service) throw new Error(`Service not found: ${locale}/${slug}`);

const cv = getCv(locale);
const translations = getTranslations(locale);
const serviceCopy = translations.services.detail;
const commercial = translations.services.commercial;
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const servicePath = `/${locale}/services/${service.slug}/`;
const canonicalPath = service.canonicalPath ?? servicePath;
const alternatePaths = getServiceAlternatePaths(locale, service);
const contactHref = `/${locale}/contact`;
const assessmentHref = `${contactHref}?service=${encodeURIComponent(service.slug)}`;
const whatsappMessage = serviceCopy.whatsappMessage.replace(
	"{service}",
	service.title,
);
const whatsappHref = `https://wa.me/34609221290?text=${encodeURIComponent(whatsappMessage)}`;
const intervention = service.pricingOptions[0];
const formattedEntryPrice = new Intl.NumberFormat(
	locale === "es" ? "es-ES" : "en-GB",
	{
		style: "currency",
		currency: intervention.currency,
		maximumFractionDigits: 0,
	},
).format(intervention.amount);
const boundaries = [
	...new Set(service.pricingOptions.map((option) => option.boundary)),
];
const relatedServices = getRelatedServices(locale, service, 3);
const getServiceHref = (item: (typeof relatedServices)[number]) =>
	item.canonicalPath ?? `/${locale}/services/${item.slug}/`;
const project = getProjectPages(locale).find((item) => {
	const proofServiceHref = item.caseStudy?.serviceHref;
	return proofServiceHref === canonicalPath || proofServiceHref === servicePath;
});
const article = service.relatedPosts?.[0];
const projectImage = project?.img?.imgStatic;
const keywords =
	locale === "es"
		? [
				service.title,
				service.shortTitle,
				"servicio freelance",
				"consultoría informática",
				"desarrollador full-stack freelance",
			]
		: [
				service.title,
				service.shortTitle,
				"freelance service",
				"IT consulting",
				"freelance full-stack developer",
			];
const structuredData = [
	buildServicePage({
		site,
		path: canonicalPath,
		name: service.title,
		description: service.description,
		providerName: cv.name,
		providerUrl: new URL(`/${locale}/`, site).toString(),
		areaServed: serviceCopy.areaServed,
		audience: service.whoFor,
		serviceType: service.shortTitle,
		sameAs: [cv.links.linkedin, cv.links.github],
		offers: service.pricingOptions.map((option) => ({
			key: option.key,
			name: option.label,
			description: option.description,
			price: option.amount,
			currency: option.currency,
			billingUnit: option.billingUnit,
			path: canonicalPath,
			priceNote: serviceCopy.pricingNote,
		})),
	}),
	buildFaqPage(service.faq),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}/` },
		{ name: t(locale, "nav.services"), path: `/${locale}/services/` },
		{ name: service.title, path: canonicalPath },
	]),
];
---

<BaseLayout
	title={service.metaTitle}
	description={service.metaDescription}
	canonicalPath={canonicalPath}
	alternatePaths={alternatePaths}
	structuredData={structuredData}
	keywords={keywords}
>
	<div class="services-page service-detail-page">
		<section
			data-service-hero
			class="service-detail-hero section-reveal"
			aria-labelledby="service-title"
		>
			<div class="service-detail-hero__copy">
				<a href={`/${locale}/services/`} class="service-detail-hero__back">
					<Icon name="arrow-left" class="h-4 w-4" aria-hidden="true" />
					{serviceCopy.backToServices}
				</a>
				<div class="service-detail-hero__identity">
					<ServiceIconBadge name={service.icon} size="lg" />
					<p class="eyebrow">{serviceCopy.eyebrow}</p>
				</div>
				<h1 id="service-title">{service.title}</h1>
				<p class="service-detail-hero__intro">{service.description}</p>
				<div class="service-detail-hero__actions">
					<a
						href={assessmentHref}
						class="button-action"
						data-contact-modal-open
						data-service-selection={service.slug}
					>
						{serviceCopy.assessmentButton}
						<Icon name="arrow-right" class="h-4 w-4" aria-hidden="true" />
					</a>
					<a
						href={whatsappHref}
						target="_blank"
						rel="noopener noreferrer nofollow"
						class="button-secondary"
					>
						{serviceCopy.whatsappButton}
						<Icon name="move-up-right" class="h-4 w-4" aria-hidden="true" />
					</a>
				</div>
			</div>

			<aside
				class="service-detail-summary"
				aria-label={serviceCopy.summaryEyebrow}
			>
				<div class="service-detail-summary__topline">
					<p class="eyebrow">{serviceCopy.summaryEyebrow}</p>
					<span aria-hidden="true">01</span>
				</div>
				<div class="service-detail-summary__price">
					<span>{serviceCopy.summaryPrice}</span>
					<strong>{formattedEntryPrice}</strong>
					<small>{commercial.common.tax}</small>
				</div>
				{
					service.timeline ? (
						<div class="service-detail-summary__timeline">
							<Icon name="clock" class="h-5 w-5" aria-hidden="true" />
							<span>
								<small>{serviceCopy.summaryTimeline}</small>
								<strong>{service.timeline}</strong>
							</span>
						</div>
					) : null
				}
				<a href="#pricing-options" class="button-secondary">
					{serviceCopy.compareOptions}
					<Icon
						name="arrow-right"
						class="h-4 w-4 rotate-90"
						aria-hidden="true"
					/>
				</a>
			</aside>
		</section>

		<div data-service-trust>
			<ServiceTrustStrip items={commercial.trust} />
		</div>

		<section
			data-service-outcome
			class="service-outcome section-reveal"
			aria-labelledby="service-outcome-title"
		>
			<header class="service-detail-heading">
				<div>
					<p class="eyebrow">{serviceCopy.outcomeEyebrow}</p>
					<h2 id="service-outcome-title">{serviceCopy.outcomeTitle}</h2>
				</div>
				<p>{serviceCopy.outcomeIntro}</p>
			</header>

			<div class="service-outcome__content">
				<div class="service-outcome__problem">
					<p class="eyebrow">{serviceCopy.problem}</p>
					<strong>{service.problem}</strong>
					<div>
						{service.overview.map((paragraph) => <p>{paragraph}</p>)}
					</div>
				</div>
				<div class="service-outcome__benefits">
					{
						service.benefits.map((benefit, index) => (
							<article>
								<span aria-hidden="true">
									{String(index + 1).padStart(2, "0")}
								</span>
								<h3>{benefit.title}</h3>
								<p>{benefit.body}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section
			id="pricing-options"
			data-service-pricing
			class="service-pricing section-reveal"
			aria-labelledby="service-pricing-title"
		>
			<header class="service-detail-heading">
				<div>
					<p class="eyebrow">{serviceCopy.pricingEyebrow}</p>
					<h2 id="service-pricing-title">{serviceCopy.pricingTitle}</h2>
				</div>
				<p>{serviceCopy.pricingIntro}</p>
			</header>

			<ServicePricingGrid
				locale={locale}
				serviceSlug={service.slug}
				serviceTitle={service.title}
				options={service.pricingOptions}
				contactHref={contactHref}
				copy={commercial.common}
			/>
		</section>

		<section
			data-service-scope
			class="service-scope section-reveal"
			aria-labelledby="service-scope-title"
		>
			<header class="service-detail-heading">
				<div>
					<p class="eyebrow">{serviceCopy.scopeEyebrow}</p>
					<h2 id="service-scope-title">{serviceCopy.scopeTitle}</h2>
				</div>
				<p>{serviceCopy.pricingNote}</p>
			</header>

			<div class="service-scope__columns">
				<article>
					<div class="service-scope__icon">
						<Icon name="circle-check-big" class="h-6 w-6" aria-hidden="true" />
					</div>
					<h3>{serviceCopy.includedTitle}</h3>
					<ul>
						{
							service.builds.map((item) => (
								<li>
									<Icon name="check" class="h-4 w-4" aria-hidden="true" />
									<span>{item}</span>
								</li>
							))
						}
					</ul>
				</article>
				<article>
					<div class="service-scope__icon">
						<Icon name="info" class="h-6 w-6" aria-hidden="true" />
					</div>
					<h3>{serviceCopy.excludedTitle}</h3>
					<ul>
						{
							boundaries.map((item) => (
								<li>
									<Icon name="arrow-right" class="h-4 w-4" aria-hidden="true" />
									<span>{item}</span>
								</li>
							))
						}
					</ul>
				</article>
			</div>
		</section>

		<section
			data-service-process
			class="service-detail-process section-reveal"
			aria-labelledby="service-process-title"
		>
			<header class="service-detail-heading">
				<div>
					<p class="eyebrow">{serviceCopy.process}</p>
					<h2 id="service-process-title">{serviceCopy.processTitle}</h2>
				</div>
				<p>{service.whyMe[0]}</p>
			</header>

			<ol>
				{
					service.process.map((step, index) => (
						<li>
							<span aria-hidden="true">
								{String(index + 1).padStart(2, "0")}
							</span>
							<p>{step}</p>
						</li>
					))
				}
			</ol>
		</section>

		<section
			data-service-proof
			class="service-detail-proof section-reveal"
			aria-labelledby="service-proof-title"
		>
			<header class="service-detail-heading">
				<div>
					<p class="eyebrow">{serviceCopy.proofEyebrow}</p>
					<h2 id="service-proof-title">{serviceCopy.proofTitle}</h2>
				</div>
				<p>{serviceCopy.blogText}</p>
			</header>

			{
				project ? (
					<ServiceProofCard
						eyebrow={serviceCopy.proofProject}
						title={project.title}
						description={project.summary}
						href={`/${locale}/projects/${project.slug}/`}
						actionLabel={serviceCopy.viewCase}
						image={
							projectImage
								? { src: projectImage.src, alt: projectImage.alt }
								: undefined
						}
					/>
				) : article ? (
					<ServiceProofCard
						eyebrow={serviceCopy.proofArticle}
						title={article.title}
						description={article.description}
						href={article.href}
						actionLabel={serviceCopy.readArticle}
					/>
				) : (
					<ServiceProofCard
						eyebrow={serviceCopy.proofArticle}
						title={serviceCopy.blogTitle}
						description={serviceCopy.blogText}
						href={`/${locale}/blog/`}
						actionLabel={serviceCopy.blogButton}
					/>
				)
			}
		</section>

		<section
			data-related-services
			class="related-services section-reveal"
			aria-labelledby="related-services-title"
		>
			<header class="service-detail-heading">
				<div>
					<p class="eyebrow">{serviceCopy.relatedTitle}</p>
					<h2 id="related-services-title">
						{translations.services.commercial.areas[service.area].title}
					</h2>
				</div>
				<p>{serviceCopy.relatedIntro}</p>
			</header>

			<div class="related-services__grid">
				{
					relatedServices.map((item) => (
						<article>
							<ServiceIconBadge name={item.icon} size="md" />
							<h3>{item.title}</h3>
							<p>{item.description}</p>
							<a href={getServiceHref(item)} class="button-secondary">
								{serviceCopy.viewRelatedService}
								<Icon name="arrow-right" class="h-4 w-4" aria-hidden="true" />
							</a>
						</article>
					))
				}
			</div>
		</section>

		<section
			data-service-faq
			class="service-detail-faq section-reveal"
			aria-labelledby="service-faq-title"
		>
			<header class="service-detail-heading">
				<div>
					<p class="eyebrow">{serviceCopy.faq}</p>
					<h2 id="service-faq-title">{serviceCopy.faqIntro}</h2>
				</div>
			</header>

			<div class="service-detail-faq__list">
				{
					service.faq.map((item, index) => (
						<details open={index === 0}>
							<summary>
								<span>{item.question}</span>
								<Icon name="plus" class="h-5 w-5" aria-hidden="true" />
							</summary>
							<p>{item.answer}</p>
						</details>
					))
				}
			</div>
		</section>

		<ConversionCta
			eyebrow={serviceCopy.contactEyebrow}
			title={serviceCopy.contactTitle}
			text={serviceCopy.contactText}
			primary={{
				label: serviceCopy.assessmentButton,
				href: assessmentHref,
				opensContactModal: true,
			}}
			secondary={{
				label: serviceCopy.whatsappButton,
				href: whatsappHref,
				external: true,
			}}
			headingId="service-conversion-title"
		/>
	</div>

	<dialog
		id="service-contact-dialog"
		class="m-auto w-[min(760px,92vw)] rounded-[var(--radius-card)] border border-[var(--surface-border)] bg-[var(--surface)] p-0 text-[var(--text)] shadow-[var(--shadow-card)] backdrop:bg-slate-950/55 dark:backdrop:bg-black/70"
	>
		<div class="max-h-[min(86vh,920px)] overflow-y-auto">
			<header
				class="flex items-start justify-between gap-4 border-b border-[var(--surface-border)] p-5 md:p-6"
			>
				<div>
					<p class="eyebrow text-[var(--action)]">{service.title}</p>
					<h2
						class="mt-3 text-2xl font-black text-[var(--home-navy)] md:text-3xl"
					>
						{serviceCopy.contactModalTitle}
					</h2>
					<p class="muted-copy mt-3 max-w-xl leading-7">
						{serviceCopy.contactModalText}
					</p>
				</div>
				<form method="dialog">
					<button
						class="header-utility inline-flex min-h-11 min-w-11 items-center justify-center rounded-full"
						aria-label={serviceCopy.closeContactModal}
					>
						<Icon name="x" class="h-5 w-5" aria-hidden="true" />
					</button>
				</form>
			</header>

			<div class="p-5 md:p-6">
				<ContactForm
					locale={locale}
					sourceCategory="service"
					sourcePath={canonicalPath}
					idPrefix={`service-${service.slug}`}
					selectedService={service.slug}
				/>
				<a
					href={whatsappHref}
					target="_blank"
					rel="noopener noreferrer nofollow"
					class="button-secondary mt-4 w-full"
				>
					{serviceCopy.whatsappButton}
					<Icon name="move-up-right" class="h-4 w-4" aria-hidden="true" />
				</a>
			</div>
		</div>
	</dialog>

	<script>
		const contactDialog = document.getElementById("service-contact-dialog");
		const contactButtons = document.querySelectorAll(
			"[data-contact-modal-open]",
		);

		contactButtons.forEach((button) => {
			button.addEventListener("click", (event) => {
				if (!(contactDialog instanceof HTMLDialogElement)) return;
				event.preventDefault();
				contactDialog.showModal();
			});
		});

		contactDialog?.addEventListener("click", (event) => {
			if (
				event.target === contactDialog &&
				contactDialog instanceof HTMLDialogElement
			) {
				contactDialog.close();
			}
		});
	</script>

	<ServicesExitIntent
		locale={locale}
		serviceTitle={service.title}
		contactHref={assessmentHref}
		whatsappHref={whatsappHref}
		openContactModal
	/>
</BaseLayout>

<style>
	.service-detail-page {
		--services-section-space: clamp(3.25rem, 5vw, 4.5rem);
		--services-content-gap: 2.25rem;
		--services-card-padding: clamp(1.35rem, 2vw, 1.75rem);
		--services-list-gap: 0.75rem;
		--detail-heading: clamp(2.15rem, 3.8vw, 3.75rem);
	}

	.service-detail-page .eyebrow {
		color: var(--action);
	}

	.service-detail-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(19rem, 0.55fr);
		gap: clamp(2.5rem, 7vw, 7rem);
		align-items: end;
		padding-block: clamp(1.5rem, 3vw, 2.5rem) clamp(3.5rem, 5vw, 4.5rem);
	}

	.service-detail-hero__back {
		display: inline-flex;
		gap: 0.5rem;
		align-items: center;
		color: var(--text-muted);
		font-size: 0.78rem;
		font-weight: 800;
	}

	.service-detail-hero__back:hover {
		color: var(--action);
	}

	.service-detail-hero__identity {
		display: flex;
		gap: 1rem;
		align-items: center;
		margin-top: 2rem;
	}

	.service-detail-hero h1 {
		max-width: 15ch;
		margin-top: 1.25rem;
		color: var(--home-navy);
		font-size: clamp(2.75rem, 5vw, 4.65rem);
		font-weight: 950;
		letter-spacing: -0.065em;
		line-height: 0.95;
		text-wrap: balance;
	}

	.service-detail-hero__intro {
		max-width: 46rem;
		margin-top: 1.5rem;
		color: var(--text-muted);
		font-size: clamp(1rem, 1.5vw, 1.16rem);
		line-height: 1.75;
	}

	.service-detail-hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 2rem;
	}

	.service-detail-summary {
		padding: 1.6rem;
		border: 1px solid var(--surface-border);
		border-radius: 1.25rem;
		background:
			radial-gradient(
				circle at 100% 0%,
				color-mix(in srgb, var(--action) 12%, transparent),
				transparent 12rem
			),
			var(--surface);
		box-shadow: var(--shadow-card);
	}

	.service-detail-summary__topline {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.service-detail-summary__topline span {
		color: var(--action);
		font-size: 0.7rem;
		font-weight: 900;
		letter-spacing: 0.18em;
	}

	.service-detail-summary__price {
		margin-top: 1.5rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--surface-border);
	}

	.service-detail-summary__price span,
	.service-detail-summary__price small {
		display: block;
		color: var(--text-muted);
		font-size: 0.72rem;
		font-weight: 750;
	}

	.service-detail-summary__price strong {
		display: block;
		margin-block: 0.15rem;
		color: var(--home-navy);
		font-size: clamp(2.4rem, 4vw, 3.5rem);
		font-weight: 950;
		letter-spacing: -0.06em;
	}

	.service-detail-summary__timeline {
		display: flex;
		gap: 0.8rem;
		align-items: start;
		padding-block: 1.25rem;
		color: var(--action);
	}

	.service-detail-summary__timeline small,
	.service-detail-summary__timeline strong {
		display: block;
	}

	.service-detail-summary__timeline small {
		color: var(--text-muted);
		font-size: 0.68rem;
	}

	.service-detail-summary__timeline strong {
		margin-top: 0.2rem;
		color: var(--text);
		font-size: 0.82rem;
		line-height: 1.45;
	}

	.service-detail-summary .button-secondary {
		width: 100%;
		font-size: 0.78rem;
	}

	.service-outcome,
	.service-pricing,
	.service-scope,
	.service-detail-process,
	.service-detail-proof,
	.related-services,
	.service-detail-faq {
		padding-block: var(--services-section-space);
	}

	.service-detail-heading {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.72fr);
		gap: 2rem 5rem;
		align-items: end;
	}

	.service-detail-heading h2 {
		max-width: 18ch;
		margin-top: 0.9rem;
		color: var(--home-navy);
		font-size: var(--detail-heading);
		font-weight: 950;
		letter-spacing: -0.06em;
		line-height: 0.99;
		text-wrap: balance;
	}

	.service-detail-heading > p {
		color: var(--text-muted);
		line-height: 1.75;
	}

	.service-outcome__content {
		display: grid;
		grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
		gap: clamp(2.5rem, 7vw, 6rem);
		margin-top: var(--services-content-gap);
	}

	.service-outcome__problem > strong {
		display: block;
		margin-top: 1rem;
		color: var(--text);
		font-size: clamp(1.4rem, 2.4vw, 2rem);
		font-weight: 900;
		line-height: 1.25;
	}

	.service-outcome__problem > div {
		display: grid;
		gap: 1rem;
		margin-top: 1.5rem;
		color: var(--text-muted);
		line-height: 1.75;
	}

	.service-outcome__benefits {
		border-top: 1px solid var(--surface-border);
	}

