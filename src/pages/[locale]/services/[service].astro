---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/forms/ContactForm.astro";
import ServicesExitIntent from "@/components/common/ServicesExitIntent.astro";
import { Icon } from "astro-icon/components";
import {
	getService,
	getServiceAlternatePaths,
	getServicePages,
} from "@/lib/services";
import { getTranslations, locales, t, type Locale } from "@/i18n";
import { getCv } from "@cv";
import { buildBreadcrumbList, buildFaqPage, buildServicePage } from "@/lib/seo";

export function getStaticPaths() {
	return locales.flatMap((locale) =>
		getServicePages(locale).map((service) => ({
			params: { locale, service: service.slug },
		})),
	);
}

const locale = Astro.params.locale as Locale;
const slug = Astro.params.service ?? "";
const service = getService(locale, slug);
if (!service) throw new Error(`Service not found: ${locale}/${slug}`);

const cv = getCv(locale);
const servicePages = getServicePages(locale);
const getServiceHref = (item: (typeof servicePages)[number]) =>
	item.canonicalPath ?? `/${locale}/services/${item.slug}/`;
const getRelatedKeys = () => {
	if (service.translationKey.startsWith("web-wordpress:")) {
		return [
			"web-wordpress:0",
			"web-wordpress:1",
			"web-wordpress:2",
			"web-wordpress:3",
			"web-wordpress:4",
			"it-consulting:4",
		];
	}

	if (service.translationKey.startsWith("ai-automation:")) {
		return [
			"ai-automation:0",
			"ai-automation:1",
			"ai-automation:2",
			"it-consulting:5",
			"base:internal-tools",
			"it-consulting:4",
		];
	}

	if (
		service.translationKey.startsWith("it-consulting:") ||
		service.translationKey === "base:custom-web-application" ||
		service.translationKey === "base:api-integrations" ||
		service.translationKey === "base:automation-workflows"
	) {
		return [
			"it-consulting:3",
			"it-consulting:4",
			"it-consulting:5",
			"base:internal-tools",
			"base:backend-spring-boot",
		];
	}

	return [
		"it-consulting:4",
		"it-consulting:5",
		"base:internal-tools",
		"base:backend-spring-boot",
	];
};
const relatedServices =
	getRelatedKeys()
		.map((key) => servicePages.find((item) => item.translationKey === key))
		.filter(
			(item): item is (typeof servicePages)[number] =>
				item !== undefined && item.slug !== service.slug,
		)
		.slice(0, 3) ?? [];
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const servicePath = `/${locale}/services/${service.slug}/`;
const canonicalPath = service.canonicalPath ?? servicePath;
const alternatePaths = getServiceAlternatePaths(locale, service);
const serviceCopy = getTranslations(locale).services.detail;
const contactHref = `/${locale}/contact`;
const whatsappMessage = serviceCopy.whatsappMessage.replace(
	"{service}",
	service.title,
);
const whatsappHref = `https://wa.me/34609221290?text=${encodeURIComponent(
	whatsappMessage,
)}`;
const overviewTitle = serviceCopy.overviewTitle.replace(
	"{service}",
	service.title,
);
const keywords =
	locale === "es"
		? [
				service.title,
				service.shortTitle,
				"servicio freelance",
				"consultoría informática",
				"desarrollador full-stack freelance",
			]
		: [
				service.title,
				service.shortTitle,
				"freelance service",
				"IT consulting",
				"freelance full-stack developer",
			];
const structuredData = [
	buildServicePage({
		site,
		path: canonicalPath,
		name: service.title,
		description: service.description,
		providerName: cv.name,
		providerUrl: new URL(`/${locale}`, site).toString(),
		areaServed: serviceCopy.areaServed,
		audience: service.whoFor,
		serviceType: service.shortTitle,
		sameAs: [cv.links.linkedin, cv.links.github],
	}),
	buildFaqPage(service.faq),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}` },
		{ name: t(locale, "nav.services"), path: `/${locale}/services` },
		{ name: service.title, path: canonicalPath },
	]),
];
---

<BaseLayout
	title={service.metaTitle}
	description={service.metaDescription}
	canonicalPath={canonicalPath}
	alternatePaths={alternatePaths}
	structuredData={structuredData}
	keywords={keywords}
>
	<section class="section-reveal py-10 md:py-20">
		<p class="eyebrow">{serviceCopy.eyebrow}</p>
		<h1
			class="mt-5 max-w-4xl text-5xl font-black text-[var(--text)] md:text-7xl"
		>
			{service.title}
		</h1>
		<p class="muted-copy mt-6 max-w-2xl text-lg leading-8">
			{service.description}
		</p>
		<div class="mt-9 flex flex-col gap-3 sm:flex-row">
			<a
				href={contactHref}
				class="button-primary w-full sm:w-auto"
				data-contact-modal-open
			>
				{serviceCopy.contactButton}
			</a>
			<a
				href={whatsappHref}
				target="_blank"
				rel="noopener noreferrer nofollow"
				class="button-secondary w-full sm:w-auto"
			>
				{serviceCopy.whatsappButton}
				<Icon name="move-up-right" class="h-4 w-4" />
			</a>
			<a href={`/${locale}/services`} class="button-secondary w-full sm:w-auto">
				{serviceCopy.servicesButton}
			</a>
		</div>
	</section>

	<section class="section-reveal py-16 md:py-24">
		<div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr]">
			<div>
				<p class="eyebrow">{serviceCopy.overviewEyebrow}</p>
				<h2
					class="mt-4 text-3xl font-black text-[var(--text)] sm:text-4xl md:text-5xl"
				>
					{overviewTitle}
				</h2>
				<div class="mt-6 space-y-4">
					{
						service.overview.map((paragraph) => (
							<p class="muted-copy text-lg leading-8">{paragraph}</p>
						))
					}
				</div>
			</div>

			<div>
				<p class="eyebrow">{serviceCopy.benefitsEyebrow}</p>
				<h2 class="mt-4 text-2xl font-black text-[var(--text)] md:text-3xl">
					{serviceCopy.benefitsTitle}
				</h2>
				<div class="mt-7 grid gap-4">
					{
						service.benefits.map((benefit) => (
							<article class="dark-card p-5">
								<h3 class="text-lg font-black text-[var(--text)]">
									{benefit.title}
								</h3>
								<p class="muted-copy mt-3 leading-7">{benefit.body}</p>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section class="section-band section-reveal py-14 md:py-20">
		<div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
			<div>
				<p class="eyebrow">{serviceCopy.pricingEyebrow}</p>
				<h2
					class="mt-4 text-3xl font-black text-[var(--text)] sm:text-4xl md:text-5xl"
				>
					{serviceCopy.pricingTitle}
				</h2>
				<p class="muted-copy mt-5 max-w-xl text-base leading-8">
					{service.pricing.note}
				</p>
				<p class="muted-copy mt-5 max-w-xl text-sm leading-7">
					{serviceCopy.pricingNote}
				</p>
			</div>

			<article class="dark-card overflow-hidden">
				<div
					class="border-b border-[var(--surface-border)] bg-[var(--surface-strong)] p-6 md:p-7 dark:bg-white/[0.03]"
				>
					<p
						class="text-sm font-black text-[var(--accent-strong)] dark:text-[var(--accent)]"
					>
						{service.pricing.label}
					</p>
					<p class="mt-4 text-4xl font-black text-[var(--text)] md:text-5xl">
						{service.pricing.price}
					</p>
				</div>

				<div class="p-6 md:p-7">
					<p class="eyebrow">{serviceCopy.pricingScope}</p>
					<ul class="mt-5 space-y-4">
						{
							service.pricing.scope.map((item) => (
								<li class="flex gap-3 leading-7 text-[var(--text-muted)]">
									<span class="text-[var(--accent-strong)] dark:text-[var(--accent)]">
										✓
									</span>
									<span>{item}</span>
								</li>
							))
						}
					</ul>
					<div class="mt-7 flex flex-col gap-3 sm:flex-row">
						<a
							href={contactHref}
							class="button-primary w-full sm:w-auto"
							data-contact-modal-open
						>
							{serviceCopy.contactButton}
						</a>
						<a
							href={whatsappHref}
							target="_blank"
							rel="noopener noreferrer nofollow"
							class="button-secondary w-full sm:w-auto"
						>
							{serviceCopy.whatsappButton}
							<Icon name="move-up-right" class="h-4 w-4" />
						</a>
						<a
							href={`/${locale}/services`}
							class="button-secondary w-full sm:w-auto"
						>
							{serviceCopy.servicesButton}
						</a>
					</div>
				</div>
			</article>
		</div>
	</section>

	<section class="section-reveal py-16 md:py-24">
		<div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
			<div>
				<p class="eyebrow">{serviceCopy.problem}</p>
				<p class="mt-5 max-w-3xl text-lg leading-8 text-[var(--text)]">
					{service.problem}
				</p>
			</div>

			<article class="dark-card p-6">
				<h2 class="text-3xl font-black text-[var(--text)]">
					{serviceCopy.whenNeeded}
				</h2>
				<ul class="mt-6 space-y-4">
					{
						service.whenNeeded.map((item) => (
							<li class="flex gap-3 leading-7 text-[var(--text-muted)]">
								<span class="text-[var(--accent-strong)] dark:text-[var(--accent)]">
									✓
								</span>
								<span>{item}</span>
							</li>
						))
					}
				</ul>
			</article>
		</div>
	</section>

	<section class="section-reveal py-16 md:py-24">
		<div class="grid gap-5 lg:grid-cols-2">
			<article class="dark-card p-6">
				<h2 class="text-3xl font-black text-[var(--text)]">
					{serviceCopy.whoFor}
				</h2>
				<ul class="mt-6 space-y-4">
					{
						service.whoFor.map((item) => (
							<li class="flex gap-3 leading-7 text-[var(--text-muted)]">
								<span class="text-[var(--accent-strong)] dark:text-[var(--accent)]">
									✓
								</span>
								<span>{item}</span>
							</li>
						))
					}
				</ul>
			</article>

			<article class="dark-card p-6">
				<h2 class="text-3xl font-black text-[var(--text)]">
					{serviceCopy.builds}
				</h2>
				<ul class="mt-6 space-y-4">
					{
						service.builds.map((item) => (
							<li class="flex gap-3 leading-7 text-[var(--text-muted)]">
								<span class="text-[var(--accent-strong)] dark:text-[var(--accent)]">
									✓
								</span>
								<span>{item}</span>
							</li>
						))
					}
				</ul>
			</article>
		</div>
	</section>

	<section class="section-band section-reveal py-16 md:py-24">
		<div class="grid gap-10 lg:grid-cols-[0.75fr_1.25fr]">
			<div>
				<p class="eyebrow">{serviceCopy.whyMe}</p>
				<h2
					class="mt-4 text-3xl font-black text-[var(--text)] sm:text-4xl md:text-5xl"
				>
					{serviceCopy.whyMeTitle}
				</h2>
			</div>
			<div class="grid gap-4 sm:grid-cols-3">
				{
					service.whyMe.map((item) => (
						<article class="dark-card p-5">
							<p class="muted-copy leading-7">{item}</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="section-reveal py-16 md:py-24">
		<p class="eyebrow">{serviceCopy.process}</p>
		<div class="stagger-children mt-8 grid gap-4 md:grid-cols-4">
			{
				service.process.map((step, index) => (
					<article class="dark-card p-5">
						<p class="font-black text-[var(--accent-strong)] dark:text-[var(--accent)]">
							{String(index + 1).padStart(2, "0")}
						</p>
						<p class="mt-5 leading-7 text-[var(--text-muted)]">{step}</p>
					</article>
				))
			}
		</div>
	</section>

	<section class="section-band section-reveal py-16 md:py-24">
		<h2 class="text-3xl font-black text-[var(--text)] md:text-5xl">
			{serviceCopy.faq}
		</h2>
		<div class="mt-8 grid gap-4 md:grid-cols-2">
			{
				service.faq.map((item) => (
					<article class="rounded-3xl border border-[var(--surface-border)] bg-[var(--surface)] p-6">
						<h3 class="text-xl font-black text-[var(--text)]">
							{item.question}
						</h3>
						<p class="muted-copy mt-4 leading-7">{item.answer}</p>
					</article>
				))
			}
		</div>
	</section>

	<section class="section-reveal py-16 md:py-24">
		<div class="grid gap-5 lg:grid-cols-[1.2fr_0.8fr]">
			<article class="dark-card p-6 md:p-8">
				<p class="eyebrow">{serviceCopy.relatedTitle}</p>
				<div class="mt-6 flex flex-wrap gap-3">
					{
						relatedServices.slice(0, 3).map((item) => (
							<a
								href={getServiceHref(item)}
								class="tag-pill hover:border-[var(--accent-strong)]"
							>
								{item.shortTitle}
							</a>
						))
					}
				</div>
			</article>

			<article class="dark-card p-6 md:p-8">
				<h2 class="text-2xl font-black text-[var(--text)]">
					{serviceCopy.blogTitle}
				</h2>
				<p class="muted-copy mt-4 leading-7">{serviceCopy.blogText}</p>
				{
					service.relatedPosts?.length ? (
						<div class="mt-6 grid gap-3">
							{service.relatedPosts.map((post) => (
								<a
									href={post.href}
									class="rounded-lg border border-[var(--surface-border)] bg-[var(--surface)] p-4 transition hover:border-[var(--accent-line)]"
								>
									<h3 class="font-black text-[var(--text)]">{post.title}</h3>
									<p class="muted-copy mt-2 text-sm leading-6">
										{post.description}
									</p>
								</a>
							))}
						</div>
					) : (
						<a href={`/${locale}/blog`} class="button-secondary mt-6">
							{serviceCopy.blogButton}
						</a>
					)
				}
			</article>
		</div>
	</section>

	<section class="section-band section-reveal py-20 text-center md:py-28">
		<p class="eyebrow">{serviceCopy.contactEyebrow}</p>
		<h2
			class="mx-auto mt-4 max-w-3xl text-4xl font-black text-[var(--text)] md:text-6xl"
		>
			{serviceCopy.contactTitle}
		</h2>
		<p class="muted-copy mx-auto mt-5 max-w-xl text-lg leading-8">
			{serviceCopy.contactText}
		</p>
		<div class="mt-9 flex flex-col justify-center gap-3 sm:flex-row">
			<a
				href={contactHref}
				class="button-primary w-full sm:w-auto"
				data-contact-modal-open
			>
				{serviceCopy.contactButton}
			</a>
			<a
				href={whatsappHref}
				target="_blank"
				rel="noopener noreferrer nofollow"
				class="button-secondary w-full sm:w-auto"
			>
				{serviceCopy.whatsappButton}
				<Icon name="move-up-right" class="h-4 w-4" />
			</a>
		</div>
	</section>

	<dialog
		id="service-contact-dialog"
		class="m-auto w-[min(760px,92vw)] rounded-[var(--radius-card)] border border-[var(--surface-border)] bg-[var(--surface)] p-0 text-[var(--text)] shadow-[var(--shadow-card)] backdrop:bg-slate-950/55 dark:backdrop:bg-black/70"
	>
		<div class="max-h-[min(86vh,920px)] overflow-y-auto">
			<header
				class="flex items-start justify-between gap-4 border-b border-[var(--surface-border)] p-5 md:p-6"
			>
				<div>
					<p class="eyebrow">{service.title}</p>
					<h2 class="mt-3 text-2xl font-black text-[var(--text)] md:text-3xl">
						{serviceCopy.contactModalTitle}
					</h2>
					<p class="muted-copy mt-3 max-w-xl leading-7">
						{serviceCopy.contactModalText}
					</p>
				</div>
				<form method="dialog">
					<button
						class="header-utility inline-flex min-h-11 min-w-11 items-center justify-center rounded-full"
						aria-label={serviceCopy.closeContactModal}
					>
						<Icon name="x" class="h-5 w-5" />
					</button>
				</form>
			</header>

			<div class="p-5 md:p-6">
				<ContactForm
					locale={locale}
					sourceCategory="service"
					sourcePath={canonicalPath}
					idPrefix={`service-${service.slug}`}
				/>
				<a
					href={whatsappHref}
					target="_blank"
					rel="noopener noreferrer nofollow"
					class="button-secondary mt-4 w-full"
				>
					{serviceCopy.whatsappButton}
					<Icon name="move-up-right" class="h-4 w-4" />
				</a>
			</div>
		</div>
	</dialog>

	<script>
		const contactDialog = document.getElementById("service-contact-dialog");
		const contactButtons = document.querySelectorAll(
			"[data-contact-modal-open]",
		);

		contactButtons.forEach((button) => {
			button.addEventListener("click", (event) => {
				if (!(contactDialog instanceof HTMLDialogElement)) return;
				event.preventDefault();
				contactDialog.showModal();
			});
		});

		contactDialog?.addEventListener("click", (event) => {
			if (
				event.target === contactDialog &&
				contactDialog instanceof HTMLDialogElement
			) {
				contactDialog.close();
			}
		});
	</script>

	<ServicesExitIntent
		locale={locale}
		serviceTitle={service.title}
		contactHref={contactHref}
		whatsappHref={whatsappHref}
		openContactModal
	/>
</BaseLayout>
