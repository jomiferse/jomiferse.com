---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ExperienceCard from "@/components/cards/ExperienceCard.astro";
import { Icon } from "astro-icon/components";
import { getLocaleStaticPaths, t } from "@/i18n";
import { getCv } from "@cv";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const cv = getCv(locale);

const experience = cv.experience ?? [];

const pageTitle = `${t(locale, "experience.meta.title")} - ${cv.name}`;
const pageDescription = t(locale, "experience.meta.description").replace(
	"{name}",
	cv.name,
);
---

<BaseLayout title={pageTitle} description={pageDescription}>
	<section class="section-reveal pt-4 md:pt-8">
		<div class="glass-panel surface-ring rounded-[2rem] p-6 md:p-8">
			<div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
				<div>
					<p
						class="text-xs font-semibold tracking-[0.24em] text-slate-500 uppercase dark:text-slate-400"
					>
						{t(locale, "experience.hero.titlePrefix")}
					</p>
					<h1
						class="mt-4 text-4xl font-semibold text-slate-950 md:text-5xl dark:text-slate-50"
					>
						<span class="text-[var(--accent-strong)]">
							{t(locale, "experience.hero.titleHighlight")}
						</span>
					</h1>
					<p
						class="mt-5 max-w-3xl text-base leading-8 text-slate-600 dark:text-slate-300"
					>
						{t(locale, "experience.hero.subtitle")}
					</p>
				</div>

				<div class="grid gap-3 sm:grid-cols-2">
					<div
						class="rounded-[1.5rem] border border-slate-200/80 bg-white/75 p-5 dark:border-slate-800/70 dark:bg-slate-950/35"
					>
						<p
							class="text-[11px] font-semibold tracking-[0.22em] text-slate-500 uppercase dark:text-slate-400"
						>
							Roles
						</p>
						<p
							class="mt-3 text-3xl font-semibold text-slate-950 dark:text-slate-50"
						>
							{experience.length}
						</p>
					</div>
					<div
						class="rounded-[1.5rem] border border-slate-200/80 bg-white/75 p-5 dark:border-slate-800/70 dark:bg-slate-950/35"
					>
						<p
							class="text-[11px] font-semibold tracking-[0.22em] text-slate-500 uppercase dark:text-slate-400"
						>
							Focus
						</p>
						<p
							class="mt-3 text-base font-semibold text-slate-950 dark:text-slate-50"
						>
							{cv.focus}
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="section-reveal mt-10 md:mt-14">
		<ol class="stagger-children relative space-y-6">
			{
				experience.map((exp, index) => (
					<li class="relative pl-0 md:pl-18">
						<span class="absolute top-8 left-0 hidden h-[calc(100%+1.5rem)] w-px bg-slate-200 md:block dark:bg-slate-800" />
						<span class="absolute top-6 left-0 hidden h-12 w-12 items-center justify-center rounded-2xl border border-[var(--accent-line)] bg-[var(--accent-soft)] text-[var(--accent-strong)] md:inline-flex">
							<Icon
								name={index === 0 ? "briefcase-business" : "briefcase"}
								class="h-5 w-5"
							/>
						</span>
						<ExperienceCard experience={exp} locale={locale} />
					</li>
				))
			}
		</ol>
	</section>
</BaseLayout>
