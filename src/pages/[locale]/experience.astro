---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getLocaleStaticPaths, getTranslations, t } from "@/i18n";
import { getCv } from "@cv";
import { buildBreadcrumbList, buildCollectionPage } from "@/lib/seo";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const cv = getCv(locale);
const experience = cv.experience ?? [];
const page = getTranslations(locale).experience.page;
const pageTitle = page.meta.title;
const pageDescription = page.meta.description;
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const structuredData = [
	buildCollectionPage(
		site,
		`/${locale}/experience`,
		pageTitle,
		pageDescription,
	),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}` },
		{ name: t(locale, "nav.experience"), path: `/${locale}/experience` },
	]),
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	structuredData={structuredData}
	keywords={[
		"Software Engineer Experience",
		"Backend Engineering",
		"Platform Engineering",
		"Distributed Systems",
	]}
>
	<section class="section-reveal pt-4 md:pt-8">
		<div class="max-w-4xl">
			<p class="eyebrow">{page.eyebrow}</p>
			<h1 class="mt-5 text-5xl font-black text-[var(--text)] md:text-7xl">
				{page.title}
				<span class="accent-text">{page.titleAccent}</span>
			</h1>
			<p class="muted-copy mt-6 max-w-2xl text-lg leading-8">
				{page.intro}
			</p>
		</div>
	</section>

	<section class="section-reveal py-16 md:py-24">
		<div class="stagger-children grid gap-4 md:grid-cols-3">
			{
				page.signals.map((signal) => (
					<article class="dark-card hover-card p-5 md:p-6">
						<h2 class="text-xl font-black text-[var(--text)]">
							{signal.title}
						</h2>
						<p class="muted-copy mt-3 text-sm leading-7">{signal.body}</p>
					</article>
				))
			}
		</div>
	</section>

	<section class="section-band section-reveal py-16 md:py-28">
		<div class="grid gap-10 lg:grid-cols-[0.32fr_1fr] lg:gap-14">
			<div>
				<p class="eyebrow">{page.timelineLabel}</p>
				<h2
					class="mt-4 text-3xl font-black text-[var(--text)] sm:text-4xl md:text-5xl"
				>
					{cv.yearsWorking}+ {page.yearsSuffix}
				</h2>
				<p class="muted-copy mt-5 leading-7">{page.timelineText}</p>
			</div>

			<div class="stagger-children space-y-5">
				{
					experience.map((exp, index) => {
						const endDate =
							exp.endDate?.toLowerCase() === "present"
								? t(locale, "experienceCard.present")
								: exp.endDate;
						const roleStack = page.roleStacks[index] ?? [];

						return (
							<article class="dark-card hover-card p-5 md:p-7">
								<div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
									<div>
										<p class="eyebrow">
											{exp.startDate} - {endDate}
										</p>
										<h3 class="mt-4 text-2xl font-black text-[var(--text)] md:text-3xl">
											{exp.role}
										</h3>
										<p class="muted-copy mt-2 text-sm font-bold">
											{exp.company} · {exp.location}
										</p>
									</div>
									{index === 0 ? (
										<span class="tag-pill">{page.currentLabel}</span>
									) : null}
								</div>

								<p class="muted-copy mt-6 max-w-3xl leading-7">
									{exp.description}
								</p>

								<div class="mt-7 grid gap-6 lg:grid-cols-[0.65fr_0.35fr]">
									<div>
										<p class="eyebrow">{page.impactLabel}</p>
										<ul class="mt-4 grid gap-3">
											{exp.highlights?.map((highlight) => (
												<li class="flex gap-3 text-sm leading-7 text-[var(--text)]">
													<span class="mt-2.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--accent)]" />
													<span class="text-[var(--text-muted)]">
														{highlight}
													</span>
												</li>
											))}
										</ul>
									</div>

									<div>
										<p class="eyebrow">{page.stackLabel}</p>
										<div class="mt-4 flex flex-wrap gap-2">
											{roleStack.map((tech) => (
												<span class="tag-pill">{tech}</span>
											))}
										</div>
									</div>
								</div>
							</article>
						);
					})
				}
			</div>
		</div>
	</section>

	<section class="section-reveal py-16 text-center md:py-28">
		<div class="dark-card px-5 py-12 sm:px-8 md:py-16">
			<p class="eyebrow">{page.cta.eyebrow}</p>
			<h2
				class="mx-auto mt-4 max-w-3xl text-3xl font-black text-[var(--text)] sm:text-4xl md:text-6xl"
			>
				{page.cta.title}
			</h2>
			<p
				class="muted-copy mx-auto mt-5 max-w-xl text-base leading-8 md:text-lg"
			>
				{page.cta.text}
			</p>
			<div class="mt-10 flex flex-col justify-center gap-3 sm:flex-row">
				<a href={`/${locale}/contact`} class="button-primary w-full sm:w-auto">
					{page.cta.primary}
					<Icon name="arrow-right" class="h-4 w-4" />
				</a>
				<a
					href={`/${locale}/projects`}
					class="button-secondary w-full sm:w-auto"
				>
					{page.cta.secondary}
				</a>
			</div>
		</div>
	</section>
</BaseLayout>
