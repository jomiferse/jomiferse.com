---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLocaleStaticPaths, t } from "@/i18n";
import { getCv } from "@cv";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const cv = getCv(locale);

const experience = cv.experience ?? [];

const pageTitle = `${t(locale, "experience.meta.title")} - ${cv.name}`;
const pageDescription = t(locale, "experience.meta.description").replace(
	"{name}",
	cv.name,
);
---

<BaseLayout title={pageTitle} description={pageDescription}>
	<section class="section-reveal pt-4 md:pt-8">
		<div class="max-w-3xl">
			<p
				class="text-[11px] font-semibold tracking-[0.32em] text-slate-500 uppercase dark:text-slate-400"
			>
				{t(locale, "experience.hero.titlePrefix")}
			</p>
			<h1
				class="mt-5 text-4xl leading-tight font-semibold tracking-[-0.045em] text-slate-950 md:text-6xl dark:text-slate-50"
			>
				{t(locale, "experience.hero.titleHighlight")}
			</h1>
			<p
				class="mt-6 max-w-2xl text-lg leading-8 text-slate-600 dark:text-slate-300"
			>
				{t(locale, "experience.hero.subtitle")}
			</p>
		</div>
	</section>

	<section class="section-reveal mt-20 md:mt-28">
		<div class="stagger-children space-y-16 md:space-y-24">
			{
				experience.map((exp) => (
					<article class="grid gap-8 lg:grid-cols-[0.36fr_1fr] lg:gap-14">
						<div class="space-y-3">
							<p class="text-sm font-semibold text-slate-950 dark:text-slate-50">
								{exp.company}
							</p>
							<p class="text-sm text-slate-500 dark:text-slate-400">
								{exp.startDate} -{" "}
								{exp.endDate === "Present"
									? t(locale, "experienceCard.present")
									: exp.endDate}
							</p>
							<p class="text-sm text-slate-500 dark:text-slate-400">
								{exp.location}
							</p>
						</div>

						<div class="max-w-4xl">
							<h2 class="text-3xl leading-tight font-semibold tracking-[-0.035em] text-slate-950 md:text-5xl dark:text-slate-50">
								{exp.role}
							</h2>
							<p class="mt-6 max-w-2xl text-base leading-7 text-slate-600 dark:text-slate-300">
								{exp.description}
							</p>

							<ul class="mt-8 max-w-2xl space-y-4">
								{exp.highlights?.map((highlight) => (
									<li class="flex gap-4 text-sm leading-7 text-slate-700 dark:text-slate-200">
										<span class="mt-3 h-1.5 w-1.5 rounded-full bg-[var(--accent)]" />
										<span>{highlight}</span>
									</li>
								))}
							</ul>
						</div>
					</article>
				))
			}
		</div>
	</section>
</BaseLayout>
