---
import { Icon } from "astro-icon/components";
import ConversionCta from "@/components/common/ConversionCta.astro";
import ProjectServiceCard from "@/components/projects/ProjectServiceCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getTranslations, locales, t, type Locale } from "@/i18n";
import {
	getProject,
	getProjectAlternatePaths,
	getProjectPages,
} from "@/lib/projects";
import {
	buildBreadcrumbList,
	buildCreativeWork,
	buildSoftwareApplication,
} from "@/lib/seo";

export function getStaticPaths() {
	return locales.flatMap((locale) =>
		getProjectPages(locale).map((project) => ({
			params: { locale, project: project.slug },
		})),
	);
}

const locale = Astro.params.locale as Locale;
const slug = Astro.params.project ?? "";
const project = getProject(locale, slug);

if (!project) throw new Error(`Project not found: ${locale}/${slug}`);

const copy = getTranslations(locale).projects.detail;
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const detailPath = `/${locale}/projects/${project.slug}/`;
const archivePath = `/${locale}/projects/`;
const alternatePaths = getProjectAlternatePaths(project);
const image = project.img?.imgStatic;
const caseStudy = project.caseStudy;
const facts = [
	project.role ? { label: copy.role, value: project.role } : null,
	project.companyRelated
		? { label: copy.organization, value: project.companyRelated }
		: null,
	project.timeframe
		? { label: copy.timeframe, value: project.timeframe }
		: null,
].filter((fact): fact is { label: string; value: string } => Boolean(fact));
const structuredData = [
	project.kind === "personal"
		? buildSoftwareApplication({
				name: project.title,
				description: project.summary,
				url: new URL(detailPath, site).toString(),
				technologies: project.technologies,
			})
		: buildCreativeWork(site, {
				name: project.title,
				description: project.summary,
				technologies: project.technologies,
				path: detailPath,
			}),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}/` },
		{ name: t(locale, "nav.projects"), path: archivePath },
		{ name: project.title, path: detailPath },
	]),
];
---

<BaseLayout
	title={`${project.title} | ${t(locale, "nav.projects")}`}
	description={project.summary}
	image={image?.src}
	imageAlt={image?.alt ?? project.title}
	canonicalPath={detailPath}
	alternatePaths={alternatePaths}
	structuredData={structuredData}
	keywords={project.technologies}
>
	<div class="projects-page project-detail-page">
		<a
			href={archivePath}
			class="inline-flex items-center gap-2 text-sm font-black text-[var(--text)] hover:text-[var(--action)] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--action)]"
		>
			<Icon name="arrow-left" class="h-4 w-4" aria-hidden="true" />
			{copy.back}
		</a>

		<section
			class="project-detail-hero section-reveal grid gap-9 py-10 md:py-14 lg:grid-cols-[minmax(0,0.92fr)_minmax(24rem,1.08fr)] lg:items-center lg:gap-14"
		>
			<div>
				{
					project.status ? (
						<p class="eyebrow text-[var(--action)]">{project.status}</p>
					) : null
				}
				<h1
					class="mt-4 max-w-4xl text-5xl leading-[0.98] font-black text-[var(--home-navy)] sm:text-6xl md:text-7xl"
				>
					{project.title}
				</h1>
				<p class="muted-copy mt-6 max-w-3xl text-lg leading-8">
					{project.summary}
				</p>

				{
					facts.length ? (
						<dl
							class="mt-8 grid gap-4 border-y border-[var(--surface-border)] py-5 sm:grid-cols-3"
							aria-label={copy.facts}
						>
							{facts.map((fact) => (
								<div>
									<dt class="eyebrow text-[var(--action)]">{fact.label}</dt>
									<dd class="mt-2 text-sm leading-6 font-bold text-[var(--text)]">
										{fact.value}
									</dd>
								</div>
							))}
						</dl>
					) : null
				}
			</div>

			<div
				class="overflow-hidden rounded-[1.35rem] border border-[var(--surface-border)] bg-[radial-gradient(circle_at_20%_10%,color-mix(in_srgb,var(--action)_12%,transparent),transparent_46%),var(--bg-band)] shadow-[var(--shadow-card)]"
			>
				{
					image ? (
						<img
							src={image.src}
							alt={image.alt ?? project.title}
							width="1200"
							height="675"
							class="aspect-[16/9] h-full w-full object-cover"
							fetchpriority="high"
						/>
					) : (
						<div class="flex aspect-[16/9] items-end p-6">
							<span class="eyebrow text-[var(--text-muted)]">
								{t(locale, "projects.page.fallbackImage")}
							</span>
						</div>
					)
				}
			</div>
		</section>

		<div
			class="grid gap-10 border-t border-[var(--surface-border)] py-14 md:py-18 lg:grid-cols-[minmax(0,1fr)_19rem] lg:gap-16"
		>
			<div class="project-narrative grid gap-12">
				{
					project.context ? (
						<section>
							<p class="eyebrow text-[var(--action)]">01</p>
							<h2 class="mt-3 text-3xl font-black text-[var(--home-navy)]">
								{copy.context}
							</h2>
							<p class="muted-copy mt-4 max-w-3xl leading-8">
								{project.context}
							</p>
						</section>
					) : null
				}

				{
					caseStudy?.problem || caseStudy?.constraints ? (
						<section>
							<p class="eyebrow text-[var(--action)]">02</p>
							<h2 class="mt-3 text-3xl font-black text-[var(--home-navy)]">
								{copy.challenge}
							</h2>
							<p class="muted-copy mt-4 max-w-3xl leading-8">
								{caseStudy.problem}
								{caseStudy.constraints ? ` ${caseStudy.constraints}` : ""}
							</p>
						</section>
					) : null
				}

				{
					caseStudy?.decisions ? (
						<section>
							<p class="eyebrow text-[var(--action)]">03</p>
							<h2 class="mt-3 text-3xl font-black text-[var(--home-navy)]">
								{copy.decisions}
							</h2>
							<p class="muted-copy mt-4 max-w-3xl leading-8">
								{caseStudy.decisions}
							</p>
						</section>
					) : null
				}

				{
					caseStudy?.delivered ? (
						<section>
							<p class="eyebrow text-[var(--action)]">04</p>
							<h2 class="mt-3 text-3xl font-black text-[var(--home-navy)]">
								{copy.outcome}
							</h2>
							<p class="muted-copy mt-4 max-w-3xl leading-8">
								{caseStudy.delivered}
							</p>
						</section>
					) : null
				}

				{
					project.highlights?.length ? (
						<section>
							<p class="eyebrow text-[var(--action)]">05</p>
							<h2 class="mt-3 text-3xl font-black text-[var(--home-navy)]">
								{copy.highlights}
							</h2>
							<ul class="mt-6 grid gap-4 sm:grid-cols-2">
								{project.highlights.map((highlight) => (
									<li class="flex gap-3 border-t border-[var(--surface-border)] pt-4 text-sm leading-7 text-[var(--text-muted)]">
										<span class="mt-2.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--action)]" />
										<span>{highlight}</span>
									</li>
								))}
							</ul>
						</section>
					) : null
				}
			</div>

			<ProjectServiceCard
				technologies={project.technologies}
				serviceHref={caseStudy?.serviceHref}
				serviceLabel={caseStudy?.serviceLabel || copy.relatedService}
				externalHref={project.link}
				copy={{
					...copy.serviceCard,
					technologies: copy.technologies,
					externalLink: copy.externalLink,
				}}
			/>
		</div>

		<ConversionCta
			eyebrow={copy.cta.eyebrow}
			title={copy.cta.title}
			text={copy.cta.text}
			primary={{
				label: copy.cta.primary,
				href: `/${locale}/contact?service=assessment`,
			}}
			secondary={{ label: copy.cta.secondary, href: archivePath }}
			headingId="project-conversion-title"
		/>
	</div>
</BaseLayout>
