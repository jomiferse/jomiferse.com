---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CertificationCard from "@/components/cards/CertificationCard.astro";
import EducationCard from "@/components/cards/EducationCard.astro";
import { getLocaleStaticPaths, t } from "@/i18n";
import { getCv } from "@cv";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const cv = getCv(locale);

const certifications = cv.certifications ?? [];
const education = cv.education ?? [];

const pageTitle = `${t(locale, "education.meta.title")} - ${cv.name}`;
const pageDescription = t(locale, "education.meta.description").replace(
	"{name}",
	cv.name,
);
---

<BaseLayout title={pageTitle} description={pageDescription}>
	<section class="section-reveal pt-4 md:pt-8">
		<div class="max-w-3xl">
			<p
				class="text-[11px] font-semibold tracking-[0.32em] text-slate-500 uppercase dark:text-slate-400"
			>
				{t(locale, "education.hero.titlePrefix")}
			</p>
			<h1
				class="mt-5 text-4xl leading-tight font-semibold tracking-[-0.045em] text-slate-950 md:text-6xl dark:text-slate-50"
			>
				{t(locale, "education.hero.titleHighlight")}
			</h1>
			<p
				class="mt-6 max-w-2xl text-lg leading-8 text-slate-600 dark:text-slate-300"
			>
				{t(locale, "education.hero.subtitle")}
			</p>
		</div>
	</section>

	<section class="section-reveal mt-20 md:mt-28">
		<div class="max-w-3xl">
			<h2
				class="text-3xl leading-tight font-semibold tracking-[-0.04em] text-slate-950 md:text-5xl dark:text-slate-50"
			>
				{t(locale, "education.sections.certifications")}
			</h2>
		</div>

		<div class="stagger-children mt-10 space-y-14 md:mt-14">
			{
				certifications.map((certification) => (
					<CertificationCard certification={certification} locale={locale} />
				))
			}
		</div>
	</section>

	<section class="section-reveal mt-24 md:mt-36">
		<div class="max-w-3xl">
			<h2
				class="text-3xl leading-tight font-semibold tracking-[-0.04em] text-slate-950 md:text-5xl dark:text-slate-50"
			>
				{t(locale, "education.sections.education")}
			</h2>
		</div>

		<div class="stagger-children mt-10 space-y-14 md:mt-14">
			{
				education.map((item) => (
					<EducationCard education={item} locale={locale} />
				))
			}
		</div>
	</section>
</BaseLayout>
