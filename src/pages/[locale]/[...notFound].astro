---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NotFoundPage from "@/components/common/NotFoundPage.astro";
import { getTranslations, locales, type Locale } from "@/i18n";

export const prerender = false;

const requestedLocale = Astro.params.locale;
const locale: Locale = locales.includes(requestedLocale as Locale)
	? (requestedLocale as Locale)
	: "es";
const page = getTranslations(locale).notFound.page;
Astro.response.status = 404;
---

<BaseLayout title={page.meta.title} description={page.meta.description} noindex>
	<NotFoundPage locale={locale} />
</BaseLayout>
