---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/forms/ContactForm.astro";
import { Icon } from "astro-icon/components";
import { getLocaleStaticPaths, getTranslations, t } from "@/i18n";
import { getCv } from "@cv";
import { buildBreadcrumbList } from "@/lib/seo";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const cv = getCv(locale);
const page = getTranslations(locale).contact.page;
const pageTitle = page.meta.title;
const pageDescription = page.meta.description;
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "ContactPage",
		name: pageTitle,
		description: pageDescription,
		url: new URL(`/${locale}/contact`, site).toString(),
	},
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}` },
		{ name: t(locale, "nav.contact"), path: `/${locale}/contact` },
	]),
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	structuredData={structuredData}
	keywords={["Contact Software Engineer", "Freelance Developer"]}
>
	<section class="section-reveal py-10 md:py-20">
		<p class="eyebrow">{page.eyebrow}</p>
		<h1
			class="mt-5 max-w-4xl text-5xl font-black text-[var(--text)] md:text-7xl"
		>
			{page.title}
			<span class="accent-text">{page.titleAccent}</span>
		</h1>
		<p class="muted-copy mt-6 max-w-2xl text-lg leading-8">
			{page.intro}
		</p>
	</section>

	<section class="section-reveal pb-20 md:pb-28">
		<div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr]">
			<aside class="space-y-4">
				<a
					href={`mailto:${cv.email}`}
					class="dark-card hover-card flex items-center justify-between gap-4 p-5"
				>
					<span>
						<span class="eyebrow block">Email</span>
						<span class="mt-2 block font-bold text-[var(--text)]"
							>{cv.email}</span
						>
					</span>
					<Icon name="move-up-right" class="h-4 w-4" />
				</a>
				<a
					href={cv.links.linkedin}
					target="_blank"
					rel="noopener noreferrer nofollow"
					class="dark-card hover-card flex items-center justify-between gap-4 p-5"
				>
					<span>
						<span class="eyebrow block">LinkedIn</span>
						<span class="mt-2 block font-bold text-[var(--text)]">
							{page.linkedin}
						</span>
					</span>
					<Icon name="move-up-right" class="h-4 w-4" />
				</a>
				<a
					href={cv.links.github}
					target="_blank"
					rel="noopener noreferrer nofollow"
					class="dark-card hover-card flex items-center justify-between gap-4 p-5"
				>
					<span>
						<span class="eyebrow block">GitHub</span>
						<span class="mt-2 block font-bold text-[var(--text)]">
							{page.github}
						</span>
					</span>
					<Icon name="move-up-right" class="h-4 w-4" />
				</a>
			</aside>

			<div>
				<p
					id="contact-success"
					hidden
					class="mb-6 rounded-2xl border border-emerald-400/30 bg-emerald-500/10 px-5 py-4 text-sm font-semibold text-emerald-200"
				>
					{t(locale, "contact.success")}
				</p>

				<ContactForm locale={locale} />
			</div>
		</div>
	</section>

	<script>
		const successMessage = document.getElementById("contact-success");
		if (
			successMessage &&
			new URLSearchParams(window.location.search).get("sent") === "1"
		) {
			successMessage.hidden = false;
		}
	</script>
</BaseLayout>
