---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/forms/ContactForm.astro";
import { getLocaleFromPath, t } from "@/i18n";
import { getCv } from "@cv";

export const prerender = false;

const locale = getLocaleFromPath(Astro.url.pathname);
const cv = getCv(locale);

const pageTitle = `${t(locale, "contact.meta.title")} - ${cv.name}`;
const pageDescription = t(locale, "contact.meta.description").replace(
	"{name}",
	cv.name,
);

const isSent = Astro.url.searchParams.get("sent") === "1";
---

<BaseLayout title={pageTitle} description={pageDescription}>
	<section class="section-reveal pt-4 md:pt-8">
		<div class="max-w-3xl">
			<p
				class="text-[11px] font-semibold tracking-[0.32em] text-slate-500 uppercase dark:text-slate-400"
			>
				{t(locale, "contact.hero.titlePrefix")}
			</p>
			<h1
				class="mt-5 text-4xl leading-tight font-semibold tracking-[-0.045em] text-slate-950 md:text-6xl dark:text-slate-50"
			>
				{t(locale, "contact.hero.titleHighlight")}
			</h1>
			<p
				class="mt-6 max-w-2xl text-lg leading-8 text-slate-600 dark:text-slate-300"
			>
				{t(locale, "contact.hero.subtitle")}
			</p>
		</div>
	</section>

	<section class="section-reveal mt-20 md:mt-28">
		<div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:gap-14">
			<div class="stagger-children space-y-8">
				<div class="border-t border-slate-200/70 pt-6 dark:border-slate-800/70">
					<p
						class="text-[11px] font-semibold tracking-[0.22em] text-slate-500 uppercase dark:text-slate-400"
					>
						{t(locale, "contact.emailLabel")}
					</p>
					<a
						href={`mailto:${cv.email}`}
						class="mt-3 inline-flex text-lg font-semibold text-slate-950 hover:text-[var(--accent-strong)] dark:text-slate-50 dark:hover:text-[var(--accent-strong)]"
					>
						{cv.email}
					</a>
				</div>

				<div class="border-t border-slate-200/70 pt-6 dark:border-slate-800/70">
					<p
						class="text-[11px] font-semibold tracking-[0.22em] text-slate-500 uppercase dark:text-slate-400"
					>
						{t(locale, "contact.social.linkedin")}
					</p>
					<a
						href={cv.links.linkedin}
						target="_blank"
						rel="noreferrer"
						class="mt-3 inline-flex text-lg font-semibold text-slate-950 hover:text-[var(--accent-strong)] dark:text-slate-50 dark:hover:text-[var(--accent-strong)]"
					>
						LinkedIn
					</a>
				</div>

				<div class="border-t border-slate-200/70 pt-6 dark:border-slate-800/70">
					<p
						class="text-[11px] font-semibold tracking-[0.22em] text-slate-500 uppercase dark:text-slate-400"
					>
						{t(locale, "contact.social.github")}
					</p>
					<a
						href={cv.links.github}
						target="_blank"
						rel="noreferrer"
						class="mt-3 inline-flex text-lg font-semibold text-slate-950 hover:text-[var(--accent-strong)] dark:text-slate-50 dark:hover:text-[var(--accent-strong)]"
					>
						GitHub
					</a>
				</div>
			</div>

			<div>
				{
					isSent && (
						<p class="mb-6 rounded-[1.5rem] border border-emerald-400/30 bg-emerald-50 px-5 py-4 text-sm text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-200">
							{t(locale, "contact.success")}
						</p>
					)
				}

				<ContactForm locale={locale} />
			</div>
		</div>
	</section>
</BaseLayout>
