---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/forms/ContactForm.astro";
import { Icon } from "astro-icon/components";
import { getLocaleFromPath, t } from "@/i18n";
import { getCv } from "@cv";
import { buildBreadcrumbList } from "@/lib/seo";

export const prerender = false;

const locale = getLocaleFromPath(Astro.url.pathname);
const cv = getCv(locale);
const isEs = locale === "es";
const copy = isEs
	? {
			pageTitle: `Contacto - ${cv.name}`,
			pageDescription:
				"Contacta con José Miguel Fernández para proyectos freelance, colaboraciones, oportunidades profesionales y software práctico.",
			eyebrow: "Contacto",
			title: "Hablemos sobre lo que quieres",
			titleAccent: "construir.",
			intro:
				"Envíame una idea de proyecto, una pregunta o una oportunidad. Leo cada mensaje y responderé cuando haya buen encaje.",
			linkedin: "Conectar en LinkedIn",
			github: "Ver mi código",
		}
	: {
			pageTitle: `Contact - ${cv.name}`,
			pageDescription:
				"Contact José Miguel Fernández for freelance projects, collaborations, professional opportunities and practical software work.",
			eyebrow: "Contact",
			title: "Let’s talk about what you want to",
			titleAccent: "build.",
			intro:
				"Send a project idea, a question or an opportunity. I read every message and I’ll reply when there’s a good fit.",
			linkedin: "Connect on LinkedIn",
			github: "View my code",
		};
const pageTitle = copy.pageTitle;
const pageDescription = copy.pageDescription;
const isSent = Astro.url.searchParams.get("sent") === "1";
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "ContactPage",
		name: pageTitle,
		description: pageDescription,
		url: new URL(`/${locale}/contact`, site).toString(),
	},
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}` },
		{ name: t(locale, "nav.contact"), path: `/${locale}/contact` },
	]),
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	structuredData={structuredData}
	keywords={["Contact Software Engineer", "Freelance Developer"]}
>
	<section class="section-reveal py-10 md:py-20">
		<p class="eyebrow">{copy.eyebrow}</p>
		<h1
			class="mt-5 max-w-4xl text-5xl font-black text-[var(--text)] md:text-7xl"
		>
			{copy.title}
			<span class="accent-text">{copy.titleAccent}</span>
		</h1>
		<p class="muted-copy mt-6 max-w-2xl text-lg leading-8">
			{copy.intro}
		</p>
	</section>

	<section class="section-reveal pb-20 md:pb-28">
		<div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr]">
			<aside class="space-y-4">
				<a
					href={`mailto:${cv.email}`}
					class="dark-card hover-card flex items-center justify-between gap-4 p-5"
				>
					<span>
						<span class="eyebrow block">Email</span>
						<span class="mt-2 block font-bold text-[var(--text)]"
							>{cv.email}</span
						>
					</span>
					<Icon name="move-up-right" class="h-4 w-4" />
				</a>
				<a
					href={cv.links.linkedin}
					target="_blank"
					rel="noopener noreferrer nofollow"
					class="dark-card hover-card flex items-center justify-between gap-4 p-5"
				>
					<span>
						<span class="eyebrow block">LinkedIn</span>
						<span class="mt-2 block font-bold text-[var(--text)]">
							{copy.linkedin}
						</span>
					</span>
					<Icon name="move-up-right" class="h-4 w-4" />
				</a>
				<a
					href={cv.links.github}
					target="_blank"
					rel="noopener noreferrer nofollow"
					class="dark-card hover-card flex items-center justify-between gap-4 p-5"
				>
					<span>
						<span class="eyebrow block">GitHub</span>
						<span class="mt-2 block font-bold text-[var(--text)]">
							{copy.github}
						</span>
					</span>
					<Icon name="move-up-right" class="h-4 w-4" />
				</a>
			</aside>

			<div>
				{
					isSent && (
						<p class="mb-6 rounded-2xl border border-emerald-400/30 bg-emerald-500/10 px-5 py-4 text-sm font-semibold text-emerald-200">
							{t(locale, "contact.success")}
						</p>
					)
				}

				<ContactForm locale={locale} />
			</div>
		</div>
	</section>
</BaseLayout>
