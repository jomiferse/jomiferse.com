---
import BaseLayout from "@/layouts/BaseLayout.astro";
import TechnologyMarquee from "@/components/common/TechnologyMarquee.astro";
import ContactForm from "@/components/forms/ContactForm.astro";
import { Icon } from "astro-icon/components";
import { getTranslations, t, type Locale } from "@/i18n";
import { getCv } from "@cv";
import { buildBreadcrumbList, buildContactPage } from "@/lib/seo";
import { pricingKeys, type PricingKey } from "@/lib/service-commercial";
import { getServicePages } from "@/lib/services";

export const prerender = false;

const localeParam = Astro.params.locale;
if (localeParam !== "en" && localeParam !== "es") {
	return Astro.redirect("/es/contact", 302);
}
const locale: Locale = localeParam;
const cv = getCv(locale);
const page = getTranslations(locale).contact.page;
const pageTitle = page.meta.title;
const pageDescription = page.meta.description;
const whatsappHref = `https://wa.me/34609221290?text=${encodeURIComponent(page.whatsappMessage)}`;
const requestedService = Astro.url.searchParams.get("service") ?? "";
const selectedService =
	requestedService === "assessment" ||
	getServicePages(locale).some((service) => service.slug === requestedService)
		? requestedService
		: undefined;
const requestedScope = Astro.url.searchParams.get("scope") ?? "";
const selectedScope =
	selectedService && pricingKeys.includes(requestedScope as PricingKey)
		? (requestedScope as PricingKey)
		: undefined;
const status =
	Astro.url.searchParams.get("sent") === "1"
		? "sent"
		: Astro.url.searchParams.get("error");
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const contactPath = `/${locale}/contact/`;
const structuredData = [
	buildContactPage(site, contactPath, pageTitle, pageDescription),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}/` },
		{ name: t(locale, "nav.contact"), path: contactPath },
	]),
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalPath={contactPath}
	structuredData={structuredData}
>
	<div class="contact-page">
		<section data-contact-hero class="contact-hero section-reveal">
			<div class="contact-hero__copy">
				<p class="eyebrow">{page.eyebrow}</p>
				<h1>{page.title}</h1>
				<p class="contact-hero__intro">{page.intro}</p>
				<ul class="contact-signals" aria-label={page.eyebrow}>
					{
						page.signals.map((signal) => (
							<li>
								<Icon name="check" aria-hidden="true" />
								{signal}
							</li>
						))
					}
				</ul>

				<div data-contact-methods class="contact-methods">
					<p class="eyebrow">{page.methodsEyebrow}</p>
					<a
						href={whatsappHref}
						target="_blank"
						rel="noopener noreferrer"
						class="contact-method contact-method--whatsapp button-secondary"
					>
						<span>
							<strong>{page.whatsappLabel}</strong>
							<small>{page.whatsappText}</small>
						</span>
						<Icon name="message-square" aria-hidden="true" />
					</a>
					<a
						href={`mailto:${cv.email}`}
						class="contact-method"
						aria-label={`${page.emailText}: ${cv.email}`}
					>
						<span>
							<strong>Email</strong>
							<small>{cv.email}</small>
						</span>
						<Icon name="move-up-right" aria-hidden="true" />
					</a>
					<a
						href={cv.links.linkedin}
						target="_blank"
						rel="noopener noreferrer"
						class="contact-method"
					>
						<span>
							<strong>LinkedIn</strong>
							<small>{page.linkedinText}</small>
						</span>
						<Icon name="move-up-right" aria-hidden="true" />
					</a>
				</div>
			</div>

			<div class="contact-form-column">
				<div
					id="contact-status-sent"
					data-contact-status="sent"
					class:list={[
						"contact-status contact-status--success",
						status === "sent" && "contact-status--visible",
					]}
					role="status"
				>
					<strong>{page.successTitle}</strong>
					<p>{page.successText}</p>
				</div>
				<div
					id="contact-status-missing"
					data-contact-status="missing"
					class:list={[
						"contact-status",
						status === "missing" && "contact-status--visible",
					]}
					role="alert"
				>
					<strong>{page.missingTitle}</strong>
					<p>{page.missingText}</p>
				</div>
				<div
					id="contact-status-send"
					data-contact-status="send"
					class:list={[
						"contact-status",
						status === "send" && "contact-status--visible",
					]}
					role="alert"
				>
					<strong>{page.errorTitle}</strong>
					<p>{page.errorText}</p>
					<div class="contact-status__actions">
						<a href={whatsappHref}>{page.whatsappLabel}</a>
						<a href={`mailto:${cv.email}`}>Email</a>
					</div>
				</div>
				<ContactForm
					locale={locale}
					selectedService={selectedService}
					selectedScope={selectedScope}
				/>
			</div>
		</section>

		<TechnologyMarquee
			eyebrow="Stack"
			title={page.technologiesTitle}
			pauseLabel={page.technologiesPauseLabel}
			headingId="contact-technologies-title"
		/>
	</div>

	<script>
		import { consumeContactLeadRedirect } from "@/lib/contact-analytics";
		import {
			ANALYTICS_READY_EVENT,
			type AnalyticsReadyDetail,
		} from "@/lib/cookie-consent";

		const params = new URLSearchParams(window.location.search);
		const status = params.get("sent") === "1" ? "sent" : params.get("error");
		if (status) {
			document
				.querySelector<HTMLElement>(`[data-contact-status="${status}"]`)
				?.classList.add("contact-status--visible");
		}

		const trackConfirmedContactLead = (event: Event) => {
			const { analyticsEnabled } = (event as CustomEvent<AnalyticsReadyDetail>)
				.detail;
			const cleanContactUrl = consumeContactLeadRedirect(window.location.href, {
				analyticsEnabled,
				gtag: window.gtag,
			});
			if (cleanContactUrl) {
				window.history.replaceState(window.history.state, "", cleanContactUrl);
			}
		};

		window.addEventListener(ANALYTICS_READY_EVENT, trackConfirmedContactLead);
	</script>
</BaseLayout>

<style>
	.contact-page .eyebrow {
		color: var(--action);
	}

	.contact-hero {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(30rem, 1.1fr);
		gap: clamp(3rem, 7vw, 7rem);
		align-items: start;
		padding-block: clamp(1.5rem, 3vw, 2.5rem) clamp(3.5rem, 5vw, 4.5rem);
	}

	.contact-hero h1 {
		max-width: 12ch;
		margin-top: 1rem;
		color: var(--home-navy);
		font-size: clamp(3rem, 5.6vw, 5.4rem);
		font-weight: 950;
		letter-spacing: -0.065em;
		line-height: 0.95;
		text-wrap: balance;
	}

	.contact-hero__intro {
		max-width: 39rem;
		margin-top: 1.5rem;
		color: var(--text-muted);
		font-size: 1.05rem;
		line-height: 1.75;
	}

	.contact-signals {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem 1.2rem;
		margin-top: 1.6rem;
	}

	.contact-signals li {
		display: inline-flex;
		gap: 0.45rem;
		align-items: center;
		color: var(--text);
		font-size: 0.82rem;
		font-weight: 800;
	}

	.contact-signals :global(svg) {
		width: 1rem;
		color: var(--action);
	}

	.contact-methods {
		margin-top: 2.4rem;
		border-top: 1px solid var(--surface-border);
	}

	.contact-methods > .eyebrow {
		padding-block: 1.2rem;
	}

	.contact-method {
		display: flex;
		min-height: 4.75rem;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		border-top: 1px solid var(--surface-border);
		color: var(--text);
	}

	.contact-method strong,
	.contact-method small {
		display: block;
	}

	.contact-method small {
		margin-top: 0.25rem;
		color: var(--text-muted);
		font-size: 0.8rem;
	}

	.contact-method:hover strong {
		color: var(--action);
	}

	.contact-method--whatsapp {
		width: 100%;
		margin-block: 0.2rem 0.9rem;
		padding-inline: 1rem;
	}

	.contact-method--whatsapp :global(svg) {
		color: #25d366;
	}

	.contact-status {
		display: none;
		margin-bottom: 1rem;
		padding: 1rem 1.1rem;
		border: 1px solid
			color-mix(in srgb, var(--action) 28%, var(--surface-border));
		border-radius: 1rem;
		background: color-mix(in srgb, var(--action) 7%, var(--surface));
		color: var(--text);
	}

	.contact-status:target,
	.contact-status--visible {
		display: block;
	}

	.contact-status p {
		margin-top: 0.25rem;
		color: var(--text-muted);
		line-height: 1.6;
	}

	.contact-status__actions {
		display: flex;
		gap: 1rem;
		margin-top: 0.65rem;
	}

	.contact-status a {
		color: var(--action);
		font-weight: 850;
	}

	@media (max-width: 900px) {
		.contact-hero {
			grid-template-columns: 1fr;
			gap: 2.5rem;
		}
	}

	@media (max-width: 767px) {
		.contact-hero {
			padding-top: 1.25rem;
		}

		.contact-hero h1 {
			font-size: clamp(2.75rem, 12vw, 3.65rem);
		}
	}
</style>
