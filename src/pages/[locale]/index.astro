---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getLocaleStaticPaths, t } from "@/i18n";
import { getCv } from "@cv";
import { buildBreadcrumbList, buildProfilePage } from "@/lib/seo";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const cv = getCv(locale);
const projects = [
	...(cv.projects?.personal ?? []),
	...(cv.projects?.company ?? []),
];
const featuredProjects = projects.slice(0, 3);
const focusAreas = cv.focusAreas.slice(0, 4);
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const copy =
	locale === "es"
		? {
				pageTitle: `Portfolio de Software Engineer - ${cv.name}`,
				pageDescription:
					"Software engineer que construye software limpio y fiable para backend, productos web, automatizaciones y herramientas internas.",
				eyebrow: "Software Engineer · Backend · Productos web",
				title: "Construyo software limpio y fiable para",
				titleAccent: "problemas reales.",
				intro:
					"Sistemas backend, microservicios, webs, automatizaciones y herramientas internas. Software útil, fácil de mantener y preparado para durar.",
				primaryCta: "Ver proyectos",
				secondaryCta: "Contactar",
				years: "Años construyendo software",
				projects: "Proyectos seleccionados",
				full: "Completo",
				scope: "Backend, frontend y delivery",
				aboutEyebrow: "Sobre mí",
				aboutTitle: "Ingeniería práctica con producción en mente.",
				aboutP1:
					"Soy software engineer en Granada. Mi trabajo principal está en backend con Java, Spring Boot y sistemas distribuidos.",
				aboutP2:
					"También trabajo en frontend cuando el producto lo necesita: interfaces, automatización, CI/CD, Docker, Kubernetes y tooling para que los equipos avancen mejor.",
				workEyebrow: "Trabajo seleccionado",
				workTitle: "Algunas cosas que he construido",
				viewAll: "Ver todo",
				buildEyebrow: "Qué puedo construir",
				buildTitle:
					"Software para resolver los problemas importantes, incluso los menos visibles.",
				ctaEyebrow: "Trabajemos juntos",
				ctaTitle:
					"¿Tienes un producto, flujo de trabajo o sistema que construir?",
				ctaText:
					"Cuéntame qué necesitas. Puedo ayudarte a darle forma, construirlo y hacerlo fácil de mantener.",
				ctaButton: "Empezar una conversación",
			}
		: {
				pageTitle: `Software Engineer Portfolio - ${cv.name}`,
				pageDescription:
					"Software engineer building clean, reliable software for backend systems, web products, automations and internal tools.",
				eyebrow: "Software Engineer · Backend · Web Products",
				title: "I build clean, reliable software for",
				titleAccent: "real-world problems.",
				intro:
					"Backend systems, microservices, websites, automations and internal tools. Useful software that is simple to run, easy to change and built to last.",
				primaryCta: "View Projects",
				secondaryCta: "Contact Me",
				years: "Years building software",
				projects: "Selected projects",
				full: "Full",
				scope: "Backend, frontend and delivery",
				aboutEyebrow: "About me",
				aboutTitle: "Practical engineering with production in mind.",
				aboutP1:
					"I am a software engineer based in Granada, Spain. My core work is backend development with Java, Spring Boot and distributed systems.",
				aboutP2:
					"I also move across the stack when it helps the product: frontend interfaces, automation, CI/CD, Docker, Kubernetes and the tooling that keeps teams moving.",
				workEyebrow: "Selected work",
				workTitle: "A few things I’ve built",
				viewAll: "View all",
				buildEyebrow: "What I can build",
				buildTitle: "Software that solves the boring, important problems.",
				ctaEyebrow: "Let’s work together",
				ctaTitle: "Have a product, workflow or system that needs to be built?",
				ctaText:
					"Tell me what you need. I can help shape it, build it and make it practical to maintain.",
				ctaButton: "Start a Conversation",
			};
const pageTitle = copy.pageTitle;
const pageDescription = copy.pageDescription;
const structuredData = [
	buildProfilePage(site, locale, {
		name: cv.name,
		description: pageDescription,
		email: cv.email,
		location: cv.location,
		links: cv.links,
	}),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}` },
	]),
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	structuredData={structuredData}
	keywords={[
		"Software Engineer",
		"Backend Development",
		"Spring Boot",
		"Microservices",
		"Freelance Web Development",
	]}
>
	<section class="section-reveal py-10 md:py-20">
		<p class="eyebrow">{copy.eyebrow}</p>
		<h1
			class="mt-6 max-w-5xl text-5xl leading-[1.02] font-black text-[var(--text)] md:text-7xl"
		>
			{copy.title}
			<span class="accent-text">{copy.titleAccent}</span>
		</h1>
		<p class="muted-copy mt-7 max-w-2xl text-lg leading-8 md:text-xl">
			{copy.intro}
		</p>
		<div class="mt-10 flex flex-col gap-3 sm:flex-row">
			<a href={`/${locale}/projects`} class="button-primary">
				{copy.primaryCta}
				<Icon name="arrow-right" class="h-4 w-4" />
			</a>
			<a href={`/${locale}/contact`} class="button-secondary"
				>{copy.secondaryCta}</a
			>
		</div>
	</section>

	<section class="section-reveal full-bleed-divider py-10">
		<div class="grid gap-8 sm:grid-cols-3">
			<div>
				<p class="text-4xl font-black text-[var(--text)]">{cv.yearsWorking}+</p>
				<p class="muted-copy mt-1 text-sm">{copy.years}</p>
			</div>
			<div>
				<p class="text-4xl font-black text-[var(--text)]">{projects.length}+</p>
				<p class="muted-copy mt-1 text-sm">{copy.projects}</p>
			</div>
			<div>
				<p class="text-4xl font-black text-[var(--text)]">{copy.full}</p>
				<p class="muted-copy mt-1 text-sm">{copy.scope}</p>
			</div>
		</div>
	</section>

	<section class="section-reveal py-20 md:py-28">
		<div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
			<div>
				<p class="eyebrow">{copy.aboutEyebrow}</p>
				<h2 class="mt-4 text-4xl font-black text-[var(--text)] md:text-5xl">
					{copy.aboutTitle}
				</h2>
			</div>
			<div class="space-y-6 text-lg leading-8 text-[var(--text-muted)]">
				<p>
					{copy.aboutP1}
				</p>
				<p>
					{copy.aboutP2}
				</p>
			</div>
		</div>
	</section>

	<section class="section-band section-reveal py-20 md:py-28">
		<div
			class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between"
		>
			<div>
				<p class="eyebrow">{copy.workEyebrow}</p>
				<h2 class="mt-4 text-4xl font-black text-[var(--text)] md:text-5xl">
					{copy.workTitle}
				</h2>
			</div>
			<a href={`/${locale}/projects`} class="button-secondary w-fit"
				>{copy.viewAll}</a
			>
		</div>

		<div class="stagger-children mt-10 grid gap-5 md:grid-cols-3">
			{
				featuredProjects.map((project) => (
					<article class="dark-card hover-card p-6">
						<div class="mb-6 flex flex-wrap gap-2">
							{project.technologies.slice(0, 3).map((tech) => (
								<span class="tag-pill">{tech}</span>
							))}
						</div>
						<h3 class="text-2xl font-black text-[var(--text)]">
							{project.title}
						</h3>
						<p class="muted-copy mt-4 text-sm leading-6">{project.summary}</p>
						<p class="mt-5 text-sm font-bold text-[var(--accent-strong)] dark:text-[var(--accent)]">
							{project.highlights?.[0] ?? project.status}
						</p>
					</article>
				))
			}
		</div>
	</section>

	<section class="section-reveal py-20 md:py-28">
		<p class="eyebrow">{copy.buildEyebrow}</p>
		<h2
			class="mt-4 max-w-3xl text-4xl font-black text-[var(--text)] md:text-5xl"
		>
			{copy.buildTitle}
		</h2>
		<div class="stagger-children mt-10 grid gap-5 md:grid-cols-2">
			{
				focusAreas.map((area) => (
					<article class="dark-card hover-card p-6">
						<h3 class="text-xl font-black text-[var(--text)]">{area.title}</h3>
						<p class="muted-copy mt-3 leading-7">{area.description}</p>
						<div class="mt-5 flex flex-wrap gap-2">
							{area.items.map((item) => (
								<span class="tag-pill">{item}</span>
							))}
						</div>
					</article>
				))
			}
		</div>
	</section>

	<section class="section-band section-reveal py-20 text-center md:py-28">
		<p class="eyebrow">{copy.ctaEyebrow}</p>
		<h2
			class="mx-auto mt-4 max-w-3xl text-4xl font-black text-[var(--text)] md:text-6xl"
		>
			{copy.ctaTitle}
		</h2>
		<p class="muted-copy mx-auto mt-6 max-w-xl text-lg leading-8">
			{copy.ctaText}
		</p>
		<div class="mt-10 flex justify-center">
			<a href={`/${locale}/contact`} class="button-primary">{copy.ctaButton}</a>
		</div>
	</section>
</BaseLayout>
