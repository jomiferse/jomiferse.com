---
import { Icon } from "astro-icon/components";
import HomeHero from "@/components/home/HomeHero.astro";
import HomeProcess from "@/components/home/HomeProcess.astro";
import HomeServicePaths from "@/components/home/HomeServicePaths.astro";
import HomeSpecializedServices from "@/components/home/HomeSpecializedServices.astro";
import HomeTrust from "@/components/home/HomeTrust.astro";
import TechnologyMarquee from "@/components/common/TechnologyMarquee.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLocaleStaticPaths, getTranslations, t } from "@/i18n";
import { getCv } from "@cv";
import { getProjectPages } from "@/lib/projects";
import { buildBreadcrumbList, buildProfilePage } from "@/lib/seo";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const cv = getCv(locale);
const projects = getProjectPages(locale);
const featuredProject =
	projects.find((project) => project.id === "euroinnova-education-platform") ??
	projects[0];
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const page = getTranslations(locale).home.page;
const pageTitle = page.meta.title;
const pageDescription = page.meta.description;
const structuredData = [
	buildProfilePage(site, locale, {
		name: cv.name,
		description: pageDescription,
		email: cv.email,
		location: cv.location,
		links: cv.links,
	}),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}` },
	]),
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	structuredData={structuredData}
	keywords={[
		"Freelance Full-Stack Developer",
		"Business Website Development",
		"Workflow Automation",
		"Custom Web Applications",
		"Spring Boot Backend",
	]}
>
	<HomeHero
		locale={locale}
		content={page.consultancyHero}
		selector={page.serviceSelector}
		yearsWorking={cv.yearsWorking}
		project={featuredProject}
	/>

	<HomeServicePaths locale={locale} content={page.assessment} />

	<HomeSpecializedServices locale={locale} content={page.specializedServices} />

	<TechnologyMarquee
		eyebrow={page.skills.eyebrow}
		title={page.skills.title}
		description={page.skills.text}
		pauseLabel={page.skills.pauseLabel}
		headingId="home-technologies-title"
	/>

	<HomeProcess content={page.process} />
	<HomeTrust content={page.proof} />

	<section
		class="home-final-cta section-reveal"
		aria-labelledby="home-cta-title"
	>
		<div>
			<p class="eyebrow">{page.cta.eyebrow}</p>
			<h2 id="home-cta-title">{page.cta.title}</h2>
			<p>{page.cta.text}</p>
		</div>
		<a href={`/${locale}/contact?service=assessment`} class="button-action">
			{page.assessment.button}
			<Icon name="arrow-right" class="h-4 w-4" aria-hidden="true" />
		</a>
	</section>
</BaseLayout>

<style>
	.home-final-cta {
		position: relative;
		display: grid;
		width: 100vw;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 3rem;
		align-items: center;
		margin: 0 calc(50% - 50vw) -5rem;
		padding: clamp(4rem, 8vw, 6.5rem) max(1rem, calc((100vw - 88rem) / 2));
		overflow: hidden;
		background: var(--surface-strong);
	}

	.home-final-cta::before {
		position: absolute;
		top: -7rem;
		right: max(1rem, calc((100vw - 88rem) / 2));
		width: 18rem;
		height: 18rem;
		border: 3.5rem solid color-mix(in srgb, var(--action) 14%, transparent);
		border-radius: 50%;
		content: "";
		pointer-events: none;
	}

	.home-final-cta > div,
	.home-final-cta > a {
		position: relative;
		z-index: 1;
	}

	.home-final-cta h2 {
		max-width: 47rem;
		margin-top: 1rem;
		color: var(--home-navy);
		font-size: clamp(2.4rem, 5.5vw, 4.8rem);
		font-weight: 900;
		letter-spacing: -0.06em;
		line-height: 0.98;
		text-wrap: balance;
	}

	.home-final-cta div > p:last-child {
		max-width: 42rem;
		margin-top: 1.25rem;
		color: var(--text-muted);
		line-height: 1.7;
	}

	@media (min-width: 761px) {
		.home-final-cta {
			padding: clamp(3.5rem, 6vw, 5.25rem) max(1rem, calc((100vw - 88rem) / 2));
		}
	}

	@media (max-width: 760px) {
		.home-final-cta {
			grid-template-columns: 1fr;
			margin-bottom: -3.5rem;
		}

		.home-final-cta > a {
			width: 100%;
		}
	}
</style>
