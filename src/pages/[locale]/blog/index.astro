---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLocaleStaticPaths, t } from "@/i18n";
import { getCollection } from "astro:content";
import { getCv } from "@cv";
import BlogPostCard from "@/components/cards/BlogPostCard.astro";
import { buildBreadcrumbList, buildCollectionPage } from "@/lib/seo";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const cv = getCv(locale);
const posts = (await getCollection("blog"))
	.filter((p) => p.id.startsWith(`${locale}/`))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const toLocalSlug = (id: string) => id.replace(new RegExp(`^${locale}/`), "");
const blogBasePath = `/${locale}/blog`;
const isEs = locale === "es";
const dateLocale = isEs ? "es-ES" : "en-GB";
const copy = isEs
	? {
			pageTitle: `Blog - ${cv.name}`,
			pageDescription:
				"Notas breves sobre software engineering, sistemas, herramientas y construcción práctica de producto.",
			eyebrow: "Escritura",
			title: "Notas de",
			titleAccent: "construir software.",
			intro:
				"Notas cortas sobre proyectos, herramientas, backend y cosas que aprendo mientras construyo.",
			empty: "Todavía no hay artículos publicados.",
		}
	: {
			pageTitle: `Blog - ${cv.name}`,
			pageDescription:
				"Short notes about software engineering, systems, tools and practical product building.",
			eyebrow: "Writing",
			title: "Notes from",
			titleAccent: "building software.",
			intro:
				"Short notes about projects, tools, backend work and things I learn while building.",
			empty: "No articles published yet.",
		};
const pageTitle = copy.pageTitle;
const pageDescription = copy.pageDescription;
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const structuredData = [
	buildCollectionPage(site, blogBasePath, pageTitle, pageDescription),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}` },
		{ name: t(locale, "nav.blog"), path: blogBasePath },
	]),
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	structuredData={structuredData}
	keywords={["Engineering Blog", "Software Engineering", "Automation"]}
>
	<section class="section-reveal py-10 md:py-20">
		<p class="eyebrow">{copy.eyebrow}</p>
		<h1
			class="mt-5 max-w-4xl text-5xl font-black text-[var(--text)] md:text-7xl"
		>
			{copy.title}
			<span class="accent-text">{copy.titleAccent}</span>
		</h1>
		<p class="muted-copy mt-6 max-w-2xl text-lg leading-8">
			{copy.intro}
		</p>
	</section>

	<section class="section-reveal pb-20 md:pb-28">
		{
			posts.length > 0 ? (
				<div class="stagger-children grid gap-5 md:grid-cols-2">
					{posts.map((post) => (
						<BlogPostCard
							href={`${blogBasePath}/${toLocalSlug(post.id)}`}
							title={post.data.title}
							description={post.data.description}
							dateLabel={post.data.date.toLocaleDateString(dateLocale, {
								year: "numeric",
								month: "short",
								day: "numeric",
							})}
							tags={post.data.tags ?? []}
							readingTime={post.data.readingTime}
						/>
					))}
				</div>
			) : (
				<div class="dark-card p-6 text-[var(--text-muted)]">{copy.empty}</div>
			)
		}
	</section>
</BaseLayout>
