---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLocaleStaticPaths, getTranslations, t } from "@/i18n";
import { getCollection } from "astro:content";
import BlogPostCard from "@/components/cards/BlogPostCard.astro";
import { buildBreadcrumbList, buildCollectionPage } from "@/lib/seo";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const posts = (await getCollection("blog"))
	.filter((p) => p.id.startsWith(`${locale}/`))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const featuredPosts = posts.filter((post) => post.data.featured);
const latestPosts = posts.filter((post) => !post.data.featured);

const toLocalSlug = (id: string) => id.replace(new RegExp(`^${locale}/`), "");
const blogBasePath = `/${locale}/blog`;
const dateLocale = locale === "es" ? "es-ES" : "en-GB";
const page = getTranslations(locale).blog.page;
const sections = getTranslations(locale).blog.sections;
const empty = getTranslations(locale).blog.empty;
const featuredLabel = locale === "es" ? "Destacado" : "Featured";
const pageTitle = page.meta.title;
const pageDescription = page.meta.description;
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const structuredData = [
	buildCollectionPage(site, blogBasePath, pageTitle, pageDescription),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}` },
		{ name: t(locale, "nav.blog"), path: blogBasePath },
	]),
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	structuredData={structuredData}
	keywords={["Engineering Blog", "Software Engineering", "Automation"]}
>
	<section class="section-reveal py-10 md:py-20">
		<p class="eyebrow">{page.eyebrow}</p>
		<h1
			class="mt-5 max-w-4xl text-5xl font-black text-[var(--text)] md:text-7xl"
		>
			{page.title}
			<span class="accent-text">{page.titleAccent}</span>
		</h1>
		<p class="muted-copy mt-6 max-w-2xl text-lg leading-8">
			{page.intro}
		</p>
	</section>

	<section class="section-reveal pb-10 md:pb-14">
		<div class="mb-7 flex flex-col gap-2">
			<h2 class="text-3xl font-black text-[var(--text)] md:text-4xl">
				{sections.featured.title}
			</h2>
			<p class="muted-copy">{sections.featured.subtitle}</p>
		</div>
		{
			featuredPosts.length > 0 ? (
				<div class="stagger-children grid gap-5 lg:grid-cols-2">
					{featuredPosts.map((post) => (
						<BlogPostCard
							href={`${blogBasePath}/${toLocalSlug(post.id)}`}
							title={post.data.title}
							description={post.data.description}
							dateLabel={post.data.date.toLocaleDateString(dateLocale, {
								year: "numeric",
								month: "short",
								day: "numeric",
							})}
							tags={post.data.tags ?? []}
							readingTime={post.data.readingTime}
							featured={post.data.featured}
							featuredLabel={featuredLabel}
						/>
					))}
				</div>
			) : (
				<div class="dark-card p-6 text-[var(--text-muted)]">
					{empty.featured}
				</div>
			)
		}
	</section>

	<section class="section-reveal pb-20 md:pb-28">
		<div class="mb-7 flex flex-col gap-2">
			<h2 class="text-3xl font-black text-[var(--text)] md:text-4xl">
				{sections.latest.title}
			</h2>
			<p class="muted-copy">{sections.latest.subtitle}</p>
		</div>
		{
			latestPosts.length > 0 ? (
				<div class="stagger-children grid gap-5 md:grid-cols-2">
					{latestPosts.map((post) => (
						<BlogPostCard
							href={`${blogBasePath}/${toLocalSlug(post.id)}`}
							title={post.data.title}
							description={post.data.description}
							dateLabel={post.data.date.toLocaleDateString(dateLocale, {
								year: "numeric",
								month: "short",
								day: "numeric",
							})}
							tags={post.data.tags ?? []}
							readingTime={post.data.readingTime}
						/>
					))}
				</div>
			) : (
				<div class="dark-card p-6 text-[var(--text-muted)]">
					{posts.length > 0 ? empty.latest : page.empty}
				</div>
			)
		}
	</section>

	<section class="section-band section-reveal py-16 text-center md:py-20">
		<h2 class="text-3xl font-black text-[var(--text)] md:text-5xl">
			{page.cta.title}
		</h2>
		<p class="muted-copy mx-auto mt-5 max-w-2xl leading-7">
			{page.cta.text}
		</p>
		<div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
			<a href={`/${locale}/services`} class="button-primary w-full sm:w-auto">
				{page.cta.services}
			</a>
			<a href={`/${locale}/contact`} class="button-secondary w-full sm:w-auto">
				{page.cta.contact}
			</a>
		</div>
	</section>
</BaseLayout>
