---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLocaleStaticPaths, getTranslations, t } from "@/i18n";
import BlogFeaturedPost from "@/components/cards/BlogFeaturedPost.astro";
import BlogPostCard from "@/components/cards/BlogPostCard.astro";
import BlogPagination from "@/components/common/BlogPagination.astro";
import ConversionCta from "@/components/common/ConversionCta.astro";
import {
	getBlogPostGroups,
	getLocalBlogSlug,
	getPublishedBlogPosts,
} from "@/lib/blog";
import { getPageItems, getTotalPages } from "@/lib/blog-pagination";
import { buildBreadcrumbList, buildCollectionPage } from "@/lib/seo";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const posts = await getPublishedBlogPosts(locale);
const { primaryFeatured, archivePosts } = getBlogPostGroups(posts);
const currentPage = 1;
const totalPages = getTotalPages(archivePosts.length);
const latestPosts = getPageItems(archivePosts, currentPage);

const blogBasePath = `/${locale}/blog`;
const dateLocale = locale === "es" ? "es-ES" : "en-GB";
const page = getTranslations(locale).blog.page;
const sections = getTranslations(locale).blog.sections;
const empty = getTranslations(locale).blog.empty;
const pagination = getTranslations(locale).blog.pagination;
const pageTitle = page.meta.title;
const pageDescription = page.meta.description;
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const structuredData = [
	buildCollectionPage(site, blogBasePath, pageTitle, pageDescription),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}` },
		{ name: t(locale, "nav.blog"), path: blogBasePath },
	]),
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	structuredData={structuredData}
	keywords={["Engineering Blog", "Software Engineering", "Automation"]}
>
	<section class="section-reveal py-8 md:py-14">
		<p class="eyebrow">{page.eyebrow}</p>
		<h1
			class="mt-5 max-w-4xl text-4xl font-black text-[var(--text)] sm:text-5xl md:text-6xl"
		>
			{page.title}
			<span class="accent-text"> {page.titleAccent}</span>
		</h1>
		<p class="muted-copy mt-5 max-w-2xl text-lg leading-8">
			{page.intro}
		</p>
	</section>

	<section class="section-reveal pb-12 md:pb-16">
		{
			primaryFeatured ? (
				<BlogFeaturedPost
					href={`${blogBasePath}/${getLocalBlogSlug(primaryFeatured.id, locale)}`}
					title={primaryFeatured.data.title}
					description={primaryFeatured.data.description}
					dateLabel={primaryFeatured.data.date.toLocaleDateString(dateLocale, {
						year: "numeric",
						month: "short",
						day: "numeric",
					})}
					readingTime={primaryFeatured.data.readingTime}
					cover={primaryFeatured.data.cover}
					featuredLabel={page.featuredEyebrow}
					readLabel={page.readArticle}
				/>
			) : (
				<div class="dark-card p-6 text-[var(--text-muted)]">
					{empty.featured}
				</div>
			)
		}
	</section>

	<section class="section-reveal pb-16 md:pb-24">
		<div class="mb-7 flex flex-col gap-2">
			<h2 class="text-3xl font-black text-[var(--text)] md:text-4xl">
				{sections.latest.title}
			</h2>
			<p class="muted-copy">{sections.latest.subtitle}</p>
		</div>
		{
			latestPosts.length > 0 ? (
				<div class="stagger-children grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
					{latestPosts.map((post) => (
						<BlogPostCard
							href={`${blogBasePath}/${getLocalBlogSlug(post.id, locale)}`}
							title={post.data.title}
							description={post.data.description}
							dateLabel={post.data.date.toLocaleDateString(dateLocale, {
								year: "numeric",
								month: "short",
								day: "numeric",
							})}
							tags={post.data.tags ?? []}
							readingTime={post.data.readingTime}
							cover={post.data.cover}
						/>
					))}
				</div>
			) : (
				<div class="dark-card p-6 text-[var(--text-muted)]">
					{posts.length > 0 ? empty.latest : page.empty}
				</div>
			)
		}
		<BlogPagination
			locale={locale}
			currentPage={currentPage}
			totalPages={totalPages}
			labels={pagination}
		/>
	</section>

	<ConversionCta
		eyebrow={page.cta.eyebrow}
		title={page.cta.title}
		text={page.cta.text}
		primary={{ label: page.cta.services, href: `/${locale}/services` }}
		secondary={{ label: page.cta.contact, href: `/${locale}/contact` }}
		headingId="blog-conversion-title"
	/>
</BaseLayout>
