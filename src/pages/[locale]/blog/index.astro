---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLocaleStaticPaths, t } from "@/i18n";
import { getCollection } from "astro:content";
import { getCv } from "@cv";
import BlogPostCard from "@/components/cards/BlogPostCard.astro";
import { buildBreadcrumbList, buildCollectionPage } from "@/lib/seo";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const cv = getCv(locale);

const posts = (await getCollection("blog"))
	.filter((p) => p.slug.startsWith(`${locale}/`))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const toLocalSlug = (slug: string) =>
	slug.replace(new RegExp(`^${locale}/`), "");

const featuredPosts = posts
	.filter((p) => p.data.tags?.includes("featured"))
	.slice(0, 2);

const latestPosts = posts.filter((p) => !p.data.tags?.includes("featured"));

const pageTitle = `${t(locale, "blog.meta.title")} - ${cv.name}`;
const pageDescription = t(locale, "blog.meta.description").replace(
	"{name}",
	cv.name,
);

const blogBasePath = `/${locale}/blog`;
const dateLocale = locale === "es" ? "es-ES" : "en-GB";
const featuredLabel = locale === "es" ? "Seleccionado" : "Selected";
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const structuredData = [
	buildCollectionPage(site, blogBasePath, pageTitle, pageDescription),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}` },
		{ name: t(locale, "nav.blog"), path: blogBasePath },
	]),
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	structuredData={structuredData}
	keywords={[
		"Engineering Blog",
		"Systems Thinking",
		"Architecture",
		"Automation",
		"Product Engineering",
	]}
>
	<section class="section-reveal pt-4 md:pt-8">
		<div class="max-w-3xl">
			<p
				class="text-[11px] font-semibold tracking-[0.32em] text-slate-500 uppercase dark:text-slate-400"
			>
				{t(locale, "blog.hero.titlePrefix")}
			</p>
			<h1
				class="mt-5 text-4xl leading-tight font-semibold tracking-[-0.045em] text-slate-950 md:text-6xl dark:text-slate-50"
			>
				{t(locale, "blog.hero.titleHighlight")}
			</h1>
			<p
				class="mt-6 max-w-2xl text-lg leading-8 text-slate-600 dark:text-slate-300"
			>
				{t(locale, "blog.hero.subtitle")}
			</p>
		</div>
	</section>

	{
		featuredPosts.length > 0 && (
			<section class="section-reveal mt-20 md:mt-28">
				<div class="max-w-3xl">
					<h2 class="text-3xl leading-tight font-semibold tracking-[-0.04em] text-slate-950 md:text-5xl dark:text-slate-50">
						{t(locale, "blog.sections.featured.title")}
					</h2>
				</div>

				<div class="stagger-children mt-10 space-y-10 md:mt-14">
					{featuredPosts.map((post) => (
						<BlogPostCard
							href={`${blogBasePath}/${toLocalSlug(post.slug)}`}
							title={post.data.title}
							description={post.data.description}
							dateLabel={post.data.date.toLocaleDateString(dateLocale, {
								year: "numeric",
								month: "short",
								day: "numeric",
							})}
							tags={post.data.tags ?? []}
							featured={true}
							readingTime={post.data.readingTime}
							featuredLabel={featuredLabel}
						/>
					))}
				</div>
			</section>
		)
	}

	<section class="section-reveal mt-24 md:mt-36">
		<div class="max-w-3xl">
			<h2
				class="text-3xl leading-tight font-semibold tracking-[-0.04em] text-slate-950 md:text-5xl dark:text-slate-50"
			>
				{t(locale, "blog.sections.latest.title")}
			</h2>
		</div>

		{
			latestPosts.length > 0 ? (
				<div class="stagger-children mt-10 space-y-10 md:mt-14">
					{latestPosts.map((post) => (
						<BlogPostCard
							href={`${blogBasePath}/${toLocalSlug(post.slug)}`}
							title={post.data.title}
							description={post.data.description}
							dateLabel={post.data.date.toLocaleDateString(dateLocale, {
								year: "numeric",
								month: "short",
								day: "numeric",
							})}
							tags={post.data.tags ?? []}
							featured={false}
							readingTime={post.data.readingTime}
							featuredLabel={featuredLabel}
						/>
					))}
				</div>
			) : (
				<div class="mt-10 text-base text-slate-600 dark:text-slate-300">
					{t(locale, "blog.empty.latest")}
				</div>
			)
		}
	</section>
</BaseLayout>
