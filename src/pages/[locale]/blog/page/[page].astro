---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getTranslations, locales, t, type Locale } from "@/i18n";
import BlogPostCard from "@/components/cards/BlogPostCard.astro";
import BlogPagination from "@/components/common/BlogPagination.astro";
import {
	getBlogPostGroups,
	getLocalBlogSlug,
	getPublishedBlogPosts,
} from "@/lib/blog";
import {
	getBlogPagePath,
	getPageItems,
	getTotalPages,
} from "@/lib/blog-pagination";
import { buildBreadcrumbList, buildCollectionPage } from "@/lib/seo";

export async function getStaticPaths() {
	const paths = [];

	for (const locale of locales) {
		const posts = await getPublishedBlogPosts(locale);
		const { latestPosts } = getBlogPostGroups(posts);
		const totalPages = getTotalPages(latestPosts.length);

		for (let page = 2; page <= totalPages; page += 1) {
			paths.push({
				params: {
					locale,
					page: String(page),
				},
				props: {
					pageNumber: page,
				},
			});
		}
	}

	return paths;
}

const locale = Astro.params.locale as Locale;
const { pageNumber } = Astro.props as { pageNumber: number };
const posts = await getPublishedBlogPosts(locale);
const { latestPosts: allLatestPosts } = getBlogPostGroups(posts);
const totalPages = getTotalPages(allLatestPosts.length);
const latestPosts = getPageItems(allLatestPosts, pageNumber);

const blogBasePath = `/${locale}/blog`;
const pagePath = getBlogPagePath(locale, pageNumber);
const dateLocale = locale === "es" ? "es-ES" : "en-GB";
const page = getTranslations(locale).blog.page;
const sections = getTranslations(locale).blog.sections;
const empty = getTranslations(locale).blog.empty;
const pagination = getTranslations(locale).blog.pagination;
const pageTitle = pagination.metaTitle.replace("{page}", String(pageNumber));
const pageDescription = pagination.metaDescription.replace(
	"{page}",
	String(pageNumber),
);
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const structuredData = [
	buildCollectionPage(site, pagePath, pageTitle, pageDescription),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}` },
		{ name: t(locale, "nav.blog"), path: blogBasePath },
		{ name: `${pagination.page} ${pageNumber}`, path: pagePath },
	]),
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	structuredData={structuredData}
	keywords={["Engineering Blog", "Software Engineering", "Automation"]}
>
	<section class="section-reveal py-10 md:py-20">
		<p class="eyebrow">{page.eyebrow}</p>
		<h1
			class="mt-5 max-w-4xl text-5xl font-black text-[var(--text)] md:text-7xl"
		>
			{page.title}
			<span class="accent-text">{page.titleAccent}</span>
		</h1>
		<p class="muted-copy mt-6 max-w-2xl text-lg leading-8">
			{page.intro}
		</p>
	</section>

	<section class="section-reveal pb-20 md:pb-28">
		<div class="mb-7 flex flex-col gap-2">
			<h2 class="text-3xl font-black text-[var(--text)] md:text-4xl">
				{sections.latest.title}
			</h2>
			<p class="muted-copy">{sections.latest.subtitle}</p>
		</div>
		{
			latestPosts.length > 0 ? (
				<div class="stagger-children grid gap-5 md:grid-cols-2">
					{latestPosts.map((post) => (
						<BlogPostCard
							href={`${blogBasePath}/${getLocalBlogSlug(post.id, locale)}`}
							title={post.data.title}
							description={post.data.description}
							dateLabel={post.data.date.toLocaleDateString(dateLocale, {
								year: "numeric",
								month: "short",
								day: "numeric",
							})}
							tags={post.data.tags ?? []}
							readingTime={post.data.readingTime}
						/>
					))}
				</div>
			) : (
				<div class="dark-card p-6 text-[var(--text-muted)]">{empty.latest}</div>
			)
		}
		<BlogPagination
			locale={locale}
			currentPage={pageNumber}
			totalPages={totalPages}
			labels={pagination}
		/>
	</section>

	<section class="section-band section-reveal py-16 text-center md:py-20">
		<h2 class="text-3xl font-black text-[var(--text)] md:text-5xl">
			{page.cta.title}
		</h2>
		<p class="muted-copy mx-auto mt-5 max-w-2xl leading-7">
			{page.cta.text}
		</p>
		<div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
			<a href={`/${locale}/services`} class="button-primary w-full sm:w-auto">
				{page.cta.services}
			</a>
			<a href={`/${locale}/contact`} class="button-secondary w-full sm:w-auto">
				{page.cta.contact}
			</a>
		</div>
	</section>
</BaseLayout>
