---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogPostLayout from "@/layouts/BlogPostLayout.astro";
import { getCollection, getEntry, render } from "astro:content";
import { getTranslatedBlogPath } from "@/lib/blog-translation";
import { buildBlogPosting, buildBreadcrumbList } from "@/lib/seo";
import { t, type Locale } from "@/i18n";

export async function getStaticPaths() {
	const posts = await getCollection("blog");

	return posts.map((p) => {
		const slugParts = p.id.split("/");
		const locale = slugParts[0];
		const slug = slugParts.slice(1).join("/");

		return {
			params: {
				locale,
				slug,
			},
			props: {
				fullSlug: p.id,
			},
		};
	});
}

const locale = Astro.params.locale as Locale;
const { fullSlug } = Astro.props;

const post = await getEntry("blog", fullSlug);
if (!post) throw new Error(`Post not found: ${fullSlug}`);

const { Content, headings } = await render(post);
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const postPath = `/${locale}/blog/${Astro.params.slug}`;
const translatedPostPath = getTranslatedBlogPath(
	locale,
	Astro.params.slug ?? "",
	post.data.translationSlug,
);
const alternatePaths =
	locale === "en"
		? { en: postPath, es: translatedPostPath }
		: { en: translatedPostPath, es: postPath };
const structuredData = [
	buildBlogPosting({
		site,
		locale,
		path: postPath,
		title: post.data.title,
		description: post.data.description,
		datePublished: post.data.date,
		dateModified: post.data.dateModified,
		author: post.data.author ?? "José Miguel Fernández",
		tags: post.data.tags,
		readingTime: post.data.readingTime,
	}),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}` },
		{ name: t(locale, "nav.blog"), path: `/${locale}/blog` },
		{ name: post.data.title, path: postPath },
	]),
];
---

<BaseLayout
	title={post.data.title}
	description={post.data.description}
	ogType="article"
	structuredData={structuredData}
	keywords={post.data.tags ?? []}
	alternatePaths={alternatePaths}
	image={post.data.cover.src}
	imageAlt={post.data.cover.alt}
>
	<BlogPostLayout frontmatter={post.data} locale={locale} headings={headings}>
		<Content />
	</BlogPostLayout>
</BaseLayout>
