---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getLocaleStaticPaths, t } from "@/i18n";
import { getCv } from "@cv";
import {
	buildBreadcrumbList,
	buildCollectionPage,
	buildCreativeWork,
	buildSoftwareApplication,
} from "@/lib/seo";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const cv = getCv(locale);
const personalProjects = cv.projects?.personal ?? [];
const companyProjects = cv.projects?.company ?? [];
const projects = [...personalProjects, ...companyProjects];
const isEs = locale === "es";
const copy = isEs
	? {
			pageTitle: `Proyectos - ${cv.name}`,
			pageDescription:
				"Proyectos seleccionados de software sobre backend, productos web, herramientas internas y delivery full-stack práctico.",
			eyebrow: "Proyectos",
			title: "Trabajo seleccionado, construido para",
			titleAccent: "uso real.",
			intro:
				"Una mezcla de proyectos personales y trabajo profesional en el que he contribuido. Problemas claros, decisiones prácticas y software mantenible.",
			result: "Qué cambió",
			fallback:
				"Software práctico con un flujo claro y una estructura mantenible.",
			view: "Ver proyecto",
		}
	: {
			pageTitle: `Projects - ${cv.name}`,
			pageDescription:
				"Selected software projects covering backend systems, web products, internal tools and practical full-stack delivery.",
			eyebrow: "Projects",
			title: "Selected work, built for",
			titleAccent: "real use.",
			intro:
				"A mix of personal projects and professional work I contributed to. Clear problems, practical decisions and maintainable software.",
			result: "What changed",
			fallback:
				"Practical software with a clear workflow and maintainable structure.",
			view: "View project",
		};
const pageTitle = copy.pageTitle;
const pageDescription = copy.pageDescription;
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const structuredData = [
	buildCollectionPage(site, `/${locale}/projects`, pageTitle, pageDescription),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}` },
		{ name: t(locale, "nav.projects"), path: `/${locale}/projects` },
	]),
	...personalProjects.map((project) =>
		buildSoftwareApplication({
			name: project.title,
			description: project.summary,
			url: project.link || undefined,
			technologies: project.technologies,
		}),
	),
	...companyProjects.map((project) =>
		buildCreativeWork(site, {
			name: project.title,
			description: project.summary,
			technologies: project.technologies,
		}),
	),
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	structuredData={structuredData}
	keywords={["Software Projects", "Backend Systems", "Web Applications"]}
>
	<section class="section-reveal py-10 md:py-20">
		<p class="eyebrow">{copy.eyebrow}</p>
		<h1
			class="mt-5 max-w-4xl text-5xl font-black text-[var(--text)] md:text-7xl"
		>
			{copy.title}
			<span class="accent-text">{copy.titleAccent}</span>
		</h1>
		<p class="muted-copy mt-6 max-w-2xl text-lg leading-8">
			{copy.intro}
		</p>
	</section>

	<section class="section-reveal pb-20 md:pb-28">
		<div class="stagger-children grid gap-5 md:grid-cols-2">
			{
				projects.map((project) => (
					<article class="dark-card hover-card flex flex-col p-5 md:min-h-[22rem] md:p-6">
						<div class="mb-6 flex flex-wrap gap-2">
							{project.status ? (
								<span class="tag-pill">{project.status}</span>
							) : null}
							{project.technologies.slice(0, 4).map((tech) => (
								<span class="tag-pill">{tech}</span>
							))}
						</div>
						<h2 class="text-xl font-black text-[var(--text)] md:text-2xl">
							{project.title}
						</h2>
						<p class="muted-copy mt-3 text-sm font-semibold">
							{project.role}
							{project.companyRelated ? ` · ${project.companyRelated}` : ""}
						</p>
						<p class="muted-copy mt-5 leading-7">{project.summary}</p>
						<div class="hairline mt-6 border-t pt-5">
							<p class="eyebrow">{copy.result}</p>
							<p class="mt-3 text-sm leading-6 font-bold text-[var(--accent-strong)] dark:text-[var(--accent)]">
								{project.highlights?.[0] ?? copy.fallback}
							</p>
						</div>
						{project.link ? (
							<a
								href={project.link}
								target="_blank"
								rel="noreferrer"
								class="mt-auto inline-flex items-center gap-2 pt-6 text-sm font-bold text-[var(--text)] hover:text-[var(--accent-strong)] dark:hover:text-[var(--accent)]"
							>
								{copy.view}
								<Icon name="move-up-right" class="h-4 w-4" />
							</a>
						) : null}
					</article>
				))
			}
		</div>
	</section>
</BaseLayout>
