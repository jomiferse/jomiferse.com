---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCard from "@/components/cards/ProjectCard.astro";
import { Icon } from "astro-icon/components";
import { getLocaleStaticPaths, t } from "@/i18n";
import { getCv } from "@cv";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const cv = getCv(locale);

const companyProjects = cv.projects?.company ?? [];
const personalProjects = cv.projects?.personal ?? [];

const pageTitle = `${t(locale, "projects.meta.title")} - ${cv.name}`;
const pageDescription = t(locale, "projects.meta.description").replace(
	"{name}",
	cv.name,
);
---

<BaseLayout title={pageTitle} description={pageDescription}>
	<section class="section-reveal pt-4 md:pt-8">
		<div class="glass-panel surface-ring rounded-[2rem] p-6 md:p-8">
			<div class="grid gap-6 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
				<div>
					<p
						class="text-xs font-semibold tracking-[0.24em] text-slate-500 uppercase dark:text-slate-400"
					>
						{t(locale, "projects.hero.titlePrefix")}
					</p>
					<h1
						class="mt-4 text-4xl font-semibold text-slate-950 md:text-5xl dark:text-slate-50"
					>
						<span class="text-[var(--accent-strong)]">
							{t(locale, "projects.hero.titleHighlight")}
						</span>
					</h1>
					<p
						class="mt-5 max-w-3xl text-base leading-8 text-slate-600 dark:text-slate-300"
					>
						{t(locale, "projects.hero.subtitle")}
					</p>
				</div>

				<div class="grid gap-3 sm:grid-cols-2">
					<div
						class="rounded-[1.5rem] border border-slate-200/80 bg-white/75 p-5 dark:border-slate-800/70 dark:bg-slate-950/35"
					>
						<p
							class="text-[11px] font-semibold tracking-[0.22em] text-slate-500 uppercase dark:text-slate-400"
						>
							Personal
						</p>
						<p
							class="mt-3 text-3xl font-semibold text-slate-950 dark:text-slate-50"
						>
							{personalProjects.length}
						</p>
					</div>
					<div
						class="rounded-[1.5rem] border border-slate-200/80 bg-white/75 p-5 dark:border-slate-800/70 dark:bg-slate-950/35"
					>
						<p
							class="text-[11px] font-semibold tracking-[0.22em] text-slate-500 uppercase dark:text-slate-400"
						>
							Company
						</p>
						<p
							class="mt-3 text-3xl font-semibold text-slate-950 dark:text-slate-50"
						>
							{companyProjects.length}
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="section-reveal mt-10 md:mt-14">
		<div class="mb-6 flex items-center gap-3">
			<span
				class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-[var(--accent-line)] bg-[var(--accent-soft)] text-[var(--accent-strong)]"
			>
				<Icon name="user" class="h-5 w-5" />
			</span>
			<div>
				<h2 class="text-2xl font-semibold text-slate-950 dark:text-slate-50">
					{t(locale, "projects.sections.personal.title")}
				</h2>
				<p class="text-sm text-slate-600 dark:text-slate-300">
					{t(locale, "projects.sections.personal.subtitle")}
				</p>
			</div>
		</div>

		{
			personalProjects.length ? (
				<div class="stagger-children grid gap-6 lg:grid-cols-2">
					{personalProjects.map((project) => (
						<ProjectCard project={project} locale={locale} />
					))}
				</div>
			) : (
				<div class="glass-panel surface-ring rounded-[2rem] p-6 text-sm text-slate-600 dark:text-slate-300">
					{t(locale, "projects.empty.personal")}
				</div>
			)
		}
	</section>

	<section class="section-reveal mt-12 md:mt-16">
		<div class="mb-6 flex items-center gap-3">
			<span
				class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-[var(--accent-line)] bg-[var(--accent-soft)] text-[var(--accent-strong)]"
			>
				<Icon name="briefcase-business" class="h-5 w-5" />
			</span>
			<div>
				<h2 class="text-2xl font-semibold text-slate-950 dark:text-slate-50">
					{t(locale, "projects.sections.company.title")}
				</h2>
				<p class="text-sm text-slate-600 dark:text-slate-300">
					{t(locale, "projects.sections.company.subtitle")}
				</p>
			</div>
		</div>

		{
			companyProjects.length ? (
				<div class="stagger-children grid gap-6 lg:grid-cols-2">
					{companyProjects.map((project) => (
						<ProjectCard project={project} locale={locale} />
					))}
				</div>
			) : (
				<div class="glass-panel surface-ring rounded-[2rem] p-6 text-sm text-slate-600 dark:text-slate-300">
					{t(locale, "projects.empty.company")}
				</div>
			)
		}
	</section>
</BaseLayout>
