---
import BaseLayout from "@/layouts/BaseLayout.astro";
import WorkCard from "@/components/cards/WorkCard.astro";
import { getLocaleStaticPaths, getTranslations, t, type Locale } from "@/i18n";
import { getProjectPages } from "@/lib/projects";
import {
	buildBreadcrumbList,
	buildCollectionPage,
	buildCreativeWork,
	buildSoftwareApplication,
} from "@/lib/seo";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const locale = Astro.params.locale as Locale;
const projects = getProjectPages(locale);
const page = getTranslations(locale).projects.page;
const pageTitle = page.meta.title;
const pageDescription = page.meta.description;
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const archivePath = `/${locale}/projects/`;
const structuredData = [
	buildCollectionPage(site, archivePath, pageTitle, pageDescription),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}/` },
		{ name: t(locale, "nav.projects"), path: archivePath },
	]),
	...projects.map((project) => {
		const path = `/${locale}/projects/${project.slug}/`;

		return project.kind === "personal"
			? buildSoftwareApplication({
					name: project.title,
					description: project.summary,
					url: new URL(path, site).toString(),
					technologies: project.technologies,
				})
			: buildCreativeWork(site, {
					name: project.title,
					description: project.summary,
					technologies: project.technologies,
					path,
				});
	}),
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalPath={archivePath}
	structuredData={structuredData}
	keywords={["Software Projects", "Backend Systems", "Web Applications"]}
>
	<section class="section-reveal py-10 md:py-20">
		<p class="eyebrow">{page.eyebrow}</p>
		<h1
			class="mt-5 max-w-4xl text-5xl font-black text-[var(--text)] md:text-7xl"
		>
			{page.title}
			<span class="accent-text">{page.titleAccent}</span>
		</h1>
		<p class="muted-copy mt-6 max-w-2xl text-lg leading-8">{page.intro}</p>
	</section>

	<section class="pb-20 md:pb-28" aria-label={t(locale, "nav.projects")}>
		<div class="stagger-children grid gap-6 md:grid-cols-2">
			{
				projects.map((project) => (
					<WorkCard project={project} locale={locale} />
				))
			}
		</div>
	</section>
</BaseLayout>
