---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { getLocaleStaticPaths, t } from "@/i18n";
import { getCv } from "@cv";
import {
	buildBreadcrumbList,
	buildCollectionPage,
	buildCreativeWork,
	buildSoftwareApplication,
} from "@/lib/seo";

export function getStaticPaths() {
	return getLocaleStaticPaths();
}

const { locale } = Astro.params;
const cv = getCv(locale);

const companyProjects = cv.projects?.company ?? [];
const personalProjects = cv.projects?.personal ?? [];
const featuredProject = personalProjects[0] ?? companyProjects[0];
const archiveProjects = [...personalProjects, ...companyProjects].filter(
	(project) => project.title !== featuredProject?.title,
);

const pageTitle = `${t(locale, "projects.meta.title")} - ${cv.name}`;
const pageDescription = t(locale, "projects.meta.description").replace(
	"{name}",
	cv.name,
);
const site = Astro.site?.toString() ?? "https://www.jomiferse.com";
const structuredData = [
	buildCollectionPage(site, `/${locale}/projects`, pageTitle, pageDescription),
	buildBreadcrumbList(site, [
		{ name: t(locale, "nav.home"), path: `/${locale}` },
		{ name: t(locale, "nav.projects"), path: `/${locale}/projects` },
	]),
	...personalProjects.map((project) =>
		buildSoftwareApplication({
			name: project.title,
			description: project.summary,
			url: project.link || undefined,
			technologies: project.technologies,
		}),
	),
	...companyProjects.map((project) =>
		buildCreativeWork(site, {
			name: project.title,
			description: project.summary,
			technologies: project.technologies,
		}),
	),
];

const featuredLabel =
	locale === "es" ? "Proyecto protagonista" : "Featured build";
const archiveLabel = locale === "es" ? "Trabajo adicional" : "Additional work";
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	structuredData={structuredData}
	keywords={[
		"Software Projects",
		"Case Studies",
		"Product Delivery",
		"Backend Systems",
		"Internal Tooling",
	]}
>
	<section class="section-reveal pt-4 md:pt-8">
		<div class="max-w-3xl">
			<p
				class="text-[11px] font-semibold tracking-[0.32em] text-slate-500 uppercase dark:text-slate-400"
			>
				{t(locale, "projects.hero.titlePrefix")}
			</p>
			<h1
				class="mt-5 text-4xl leading-tight font-semibold tracking-[-0.045em] text-slate-950 md:text-6xl dark:text-slate-50"
			>
				{t(locale, "projects.hero.titleHighlight")}
			</h1>
			<p
				class="mt-6 max-w-2xl text-lg leading-8 text-slate-600 dark:text-slate-300"
			>
				{t(locale, "projects.hero.subtitle")}
			</p>
		</div>
	</section>

	{
		featuredProject && (
			<section class="section-reveal mt-20 md:mt-28">
				<div class="max-w-3xl">
					<p class="text-sm font-semibold text-slate-500 dark:text-slate-400">
						{featuredLabel}
					</p>
					<h2 class="mt-4 text-3xl leading-tight font-semibold tracking-[-0.04em] text-slate-950 md:text-5xl dark:text-slate-50">
						{featuredProject.title}
					</h2>
				</div>

				<div class="stagger-children mt-10 grid gap-8 lg:grid-cols-[1.08fr_0.92fr] lg:gap-12">
					<div class="overflow-hidden rounded-[2.6rem]">
						<Image
							src={featuredProject.img?.imgStatic?.src ?? "/images/avatar.avif"}
							alt={featuredProject.img?.imgStatic?.alt ?? featuredProject.title}
							width={1280}
							height={920}
							loading="eager"
							class="h-[23rem] w-full object-cover md:h-[31rem]"
						/>
					</div>

					<div class="flex max-w-2xl flex-col justify-center">
						<p class="text-sm font-semibold text-slate-500 dark:text-slate-400">
							{featuredProject.status} - {featuredProject.timeframe}
						</p>
						<p class="mt-4 text-base text-slate-500 dark:text-slate-400">
							{featuredProject.role} - {featuredProject.companyRelated}
						</p>
						<p class="mt-6 max-w-lg text-base leading-7 text-slate-600 dark:text-slate-300">
							{featuredProject.summary}
						</p>

						<ul class="mt-7 space-y-4">
							{featuredProject.highlights?.slice(0, 2).map((highlight) => (
								<li class="flex gap-4 text-sm leading-7 text-slate-700 dark:text-slate-200">
									<span class="mt-3 h-1.5 w-1.5 rounded-full bg-[var(--accent)]" />
									<span>{highlight}</span>
								</li>
							))}
						</ul>

						<div class="mt-7 flex flex-wrap gap-2">
							{featuredProject.technologies.slice(0, 3).map((tech) => (
								<span class="inline-flex items-center rounded-full bg-slate-200/65 px-3 py-1.5 text-xs font-semibold text-slate-700 dark:bg-slate-800/70 dark:text-slate-200">
									{tech}
								</span>
							))}
						</div>

						{featuredProject.link ? (
							<a
								href={featuredProject.link}
								target="_blank"
								rel="noreferrer"
								class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-slate-950 hover:text-[var(--accent-strong)] dark:text-slate-50 dark:hover:text-[var(--accent-strong)]"
							>
								{t(locale, "projectCard.viewProject")}
								<Icon name="move-up-right" class="h-4 w-4" />
							</a>
						) : null}
					</div>
				</div>
			</section>
		)
	}

	<section class="section-reveal mt-24 md:mt-36">
		<div class="max-w-3xl">
			<h2
				class="text-3xl leading-tight font-semibold tracking-[-0.04em] text-slate-950 md:text-5xl dark:text-slate-50"
			>
				{archiveLabel}
			</h2>
		</div>

		<div class="stagger-children mt-10 space-y-10 md:mt-14">
			{
				archiveProjects.map((project) => (
					<article class="border-t border-slate-200/70 pt-8 dark:border-slate-800/70">
						<div class="grid gap-6 lg:grid-cols-[0.34fr_1fr] lg:gap-12">
							<div class="space-y-3">
								<p class="text-sm font-semibold text-slate-950 dark:text-slate-50">
									{project.companyRelated}
								</p>
								<p class="text-sm text-slate-500 dark:text-slate-400">
									{project.status}
								</p>
								<p class="text-sm text-slate-500 dark:text-slate-400">
									{project.timeframe}
								</p>
							</div>

							<div class="max-w-4xl">
								<h3 class="text-2xl leading-tight font-semibold tracking-[-0.03em] text-slate-950 md:text-4xl dark:text-slate-50">
									{project.title}
								</h3>
								<p class="mt-4 text-base text-slate-500 dark:text-slate-400">
									{project.role}
								</p>
								<p class="mt-5 max-w-2xl text-base leading-7 text-slate-600 dark:text-slate-300">
									{project.summary}
								</p>
								<div class="mt-6 flex flex-wrap gap-2">
									{project.technologies.slice(0, 3).map((tech) => (
										<span class="inline-flex items-center rounded-full bg-slate-200/65 px-3 py-1.5 text-xs font-semibold text-slate-700 dark:bg-slate-800/70 dark:text-slate-200">
											{tech}
										</span>
									))}
								</div>
							</div>
						</div>
					</article>
				))
			}
		</div>
	</section>
</BaseLayout>
