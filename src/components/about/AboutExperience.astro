---
import { Icon } from "astro-icon/components";
import { getCv } from "@cv";
import TechnologyGrid from "@/components/common/TechnologyGrid.astro";
import { t, type Locale } from "@/i18n";

type Experience = ReturnType<typeof getCv>["experience"];

interface Props {
	locale: Locale;
	content: {
		eyebrow: string;
		title: string;
		intro: string;
		yearsSuffix: string;
		timelineText: string;
		currentLabel: string;
		impactLabel: string;
		stackLabel: string;
		showMore: string;
		showLess: string;
		roleStacks: string[][];
	};
	experience: Experience;
	yearsWorking: string;
}

const { locale, content, experience, yearsWorking } = Astro.props as Props;
---

<section class="about-experience section-reveal py-18 md:py-20">
	<header class="max-w-4xl">
		<p class="eyebrow">{content.eyebrow}</p>
		<h2 class="mt-4 text-4xl font-black md:text-6xl">
			{content.title}
		</h2>
		<p class="muted-copy mt-5 max-w-3xl text-lg leading-8">{content.intro}</p>
	</header>

	<div class="mt-12 grid gap-12 lg:grid-cols-[0.28fr_0.72fr] lg:gap-16">
		<div class="lg:sticky lg:top-28 lg:self-start">
			<p class="text-5xl font-black text-[var(--action)]">
				{yearsWorking}+
			</p>
			<p class="mt-2 text-lg font-black text-[var(--text)]">
				{content.yearsSuffix}
			</p>
			<p class="muted-copy mt-5 leading-7">{content.timelineText}</p>
		</div>

		<div class="about-timeline">
			{
				experience.map((role, index) => {
					const endDate =
						role.endDate?.toLowerCase() === "present" ||
						role.endDate?.toLowerCase() === "presente"
							? t(locale, "experienceCard.present")
							: role.endDate;
					const stack = content.roleStacks[index] ?? [];
					const visibleHighlights = role.highlights?.slice(0, 3) ?? [];
					const hiddenHighlights = role.highlights?.slice(3) ?? [];
					const showMoreLabel = content.showMore.replace(
						"{count}",
						String(hiddenHighlights.length),
					);

					return (
						<article class="about-timeline__item">
							<div class="about-timeline__marker" aria-hidden="true" />
							<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
								<div>
									<p class="eyebrow">
										{role.startDate} — {endDate}
									</p>
									<h3 class="mt-3 text-2xl font-black text-[var(--text)] md:text-3xl">
										{role.role}
									</h3>
									<p class="muted-copy mt-2 text-sm font-bold">
										{role.company} · {role.location}
									</p>
								</div>
								{index === 0 ? (
									<span class="tag-pill w-fit">{content.currentLabel}</span>
								) : null}
							</div>

							<p class="muted-copy mt-5 max-w-3xl leading-7">
								{role.description}
							</p>

							<div class="mt-7 grid gap-7 xl:grid-cols-[1fr_0.42fr]">
								<div>
									<p class="eyebrow">{content.impactLabel}</p>
									<ul class="mt-4 grid gap-3">
										{visibleHighlights.map((highlight) => (
											<li class="flex gap-3 text-sm leading-7 text-[var(--text-muted)]">
												<span class="mt-2.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--action)]" />
												<span>{highlight}</span>
											</li>
										))}
									</ul>

									{hiddenHighlights.length ? (
										<details class="about-highlights-more mt-5">
											<summary>
												<span class="show-more-label">{showMoreLabel}</span>
												<span class="show-less-label">{content.showLess}</span>
												<Icon
													name="plus"
													class="about-highlights-more__icon h-4 w-4"
													aria-hidden="true"
												/>
											</summary>
											<ul class="mt-4 grid gap-3 border-t border-[var(--surface-border)] pt-4">
												{hiddenHighlights.map((highlight) => (
													<li class="flex gap-3 text-sm leading-7 text-[var(--text-muted)]">
														<span class="mt-2.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--action)]" />
														<span>{highlight}</span>
													</li>
												))}
											</ul>
										</details>
									) : null}
								</div>
								<div class="h-fit rounded-[1.15rem] border border-[color-mix(in_srgb,var(--action)_26%,var(--surface-border))] bg-[radial-gradient(circle_at_100%_0%,color-mix(in_srgb,var(--action)_10%,transparent),transparent_9rem),var(--surface)] p-5 shadow-[var(--shadow-card)]">
									<TechnologyGrid
										technologies={stack}
										label={content.stackLabel}
									/>
								</div>
							</div>
						</article>
					);
				})
			}
		</div>
	</div>
</section>

<style>
	.about-highlights-more summary {
		display: inline-flex;
		min-height: 2.75rem;
		align-items: center;
		gap: 0.6rem;
		padding: 0.65rem 0.9rem;
		border: 1px solid var(--surface-border);
		border-radius: 999px;
		color: var(--text);
		font-size: 0.8rem;
		font-weight: 900;
		list-style: none;
		cursor: pointer;
		transition:
			color 160ms ease,
			border-color 160ms ease,
			background-color 160ms ease;
	}

	.about-highlights-more summary::-webkit-details-marker {
		display: none;
	}

	.about-highlights-more summary:hover {
		border-color: color-mix(in srgb, var(--action) 45%, var(--surface-border));
		background: color-mix(in srgb, var(--action) 7%, var(--surface));
		color: var(--action);
	}

	.about-highlights-more summary:focus-visible {
		outline: 2px solid var(--action);
		outline-offset: 4px;
	}

	.about-highlights-more:not([open]) .show-less-label,
	.about-highlights-more[open] .show-more-label {
		display: none;
	}

	.about-highlights-more__icon {
		color: var(--action);
		transition: transform 160ms ease;
	}

	.about-highlights-more[open] .about-highlights-more__icon {
		transform: rotate(45deg);
	}

	@media (prefers-reduced-motion: reduce) {
		.about-highlights-more summary,
		.about-highlights-more__icon {
			transition: none;
		}
	}
</style>
