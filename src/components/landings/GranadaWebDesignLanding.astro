---
import { Icon } from "astro-icon/components";
import ConversionCta from "@/components/common/ConversionCta.astro";
import ServiceIconBadge from "@/components/services/ServiceIconBadge.astro";
import ServicePricingGrid from "@/components/services/ServicePricingGrid.astro";
import ServiceProofCard from "@/components/services/ServiceProofCard.astro";
import ServiceTrustStrip from "@/components/services/ServiceTrustStrip.astro";
import type { Locale } from "@/i18n";
import type { CommercialLandingPage } from "@/lib/commercial-landings";
import type { ProjectEntry } from "@/lib/projects";
import type { ServiceItem } from "@/lib/services";

interface Props {
	locale: Locale;
	page: CommercialLandingPage;
	contactHref: string;
	whatsappHref: string;
	service: ServiceItem;
	relatedServices: ServiceItem[];
	featuredProject?: ProjectEntry;
}

const {
	locale,
	page,
	contactHref,
	whatsappHref,
	service,
	relatedServices,
	featuredProject,
} = Astro.props as Props;
const es = locale === "es";
const projectHref = featuredProject
	? `/${locale}/projects/${featuredProject.slug}/`
	: `/${locale}/projects/`;
const projectImage = featuredProject?.img?.imgStatic;
const getServiceHref = (item: ServiceItem) =>
	item.canonicalPath ?? `/${locale}/services/${item.slug}/`;
const entryPrice = new Intl.NumberFormat(es ? "es-ES" : "en-GB", {
	style: "currency",
	currency: service.pricingOptions[0].currency,
	maximumFractionDigits: 0,
}).format(service.pricingOptions[0].amount);
const boundaries = [
	...new Set(service.pricingOptions.map((option) => option.boundary)),
];
const includedScope = [
	...new Set([...page.builds.items, ...service.builds]),
].slice(0, 8);

const copy = es
	? {
			back: "Volver a servicios",
			eyebrow: "Servicio de diseño web en Granada",
			assessment: "Valorar mi proyecto web",
			whatsapp: "Consultar por WhatsApp",
			summary: "Resumen del servicio",
			price: "Inversión inicial",
			from: "Desde",
			tax: "IVA no incluido",
			timeline: "Plazo orientativo",
			compare: "Comparar modalidades",
			trust: [
				{
					icon: "user",
					title: "Trato directo",
					text: "Hablas con quien diseña y desarrolla la web.",
				},
				{
					icon: "circle-check-big",
					title: "Alcance por escrito",
					text: "Páginas, entregables y responsabilidades claras.",
				},
				{
					icon: "badge-check",
					title: "Tu web y tus accesos",
					text: "Recibes propiedad, credenciales y documentación.",
				},
			],
			outcomeEyebrow: "Qué debe resolver",
			outcomeTitle: "Una web que explica tu negocio y facilita el contacto",
			outcomeIntro:
				"El diseño importa, pero la decisión de inversión parte de problemas que ya puedes reconocer en la web actual.",
			problem: "El problema",
			pricingEyebrow: "Modalidades y precios",
			pricingTitle: "Una forma de empezar según el alcance",
			pricingIntro:
				"Los importes son orientativos y permiten separar una intervención concreta, un proyecto completo y el soporte posterior.",
			pricing: {
				mostCommon: "Más habitual",
				from: "Desde",
				tax: "IVA no incluido",
				month: "/mes",
				included: "Incluye",
				boundary: "Límite:",
			},
			scopeEyebrow: "Alcance del trabajo",
			scopeTitle: "Qué puede incluir y qué se presupuesta aparte",
			scopeIntro:
				"La propuesta concreta qué entra en cada modalidad. Esta lista sirve para preparar la conversación inicial.",
			includedTitle: "Puede formar parte del proyecto",
			boundaryTitle: "Depende del alcance contratado",
			processEyebrow: "Forma de trabajo",
			processIntro:
				"Contenido, plataforma, revisiones y responsabilidades quedan definidos antes de desarrollar.",
			processTitles: ["Entender", "Acotar", "Construir", "Publicar"],
			proofEyebrow: "Trabajo real",
			proofTitle: "Una plataforma web recuperada y operativa",
			proofDescription:
				"GetYourTicket muestra cómo abordo una base web existente, corrijo lo que impide usarla y dejo claros despliegue, pagos y mantenimiento.",
			proofAction: "Ver el proyecto",
			relatedEyebrow: "Servicios relacionados",
			relatedTitle: "Otras formas de mejorar tu presencia web",
			relatedIntro:
				"WordPress, rediseño y páginas de campaña cubren puntos de partida distintos.",
			relatedAction: "Ver servicio",
			faqEyebrow: "Antes de decidir",
			faqTitle: "Preguntas sobre el proyecto web",
			faqIntro: "Reuniones, presupuesto, edición y plazos antes de empezar.",
			services: "Ver todos los servicios",
		}
	: {
			back: "Back to services",
			eyebrow: "Web design service in Granada",
			assessment: "Assess my website project",
			whatsapp: "Ask on WhatsApp",
			summary: "Service summary",
			price: "Starting investment",
			from: "From",
			tax: "Tax not included",
			timeline: "Typical timeline",
			compare: "Compare options",
			trust: [
				{
					icon: "user",
					title: "Direct communication",
					text: "You speak with the person designing and building the site.",
				},
				{
					icon: "circle-check-big",
					title: "Written scope",
					text: "Pages, deliverables and responsibilities are clear.",
				},
				{
					icon: "badge-check",
					title: "Your site and access",
					text: "You receive ownership, credentials and documentation.",
				},
			],
			outcomeEyebrow: "What it should solve",
			outcomeTitle:
				"A website that explains the business and makes contact easy",
			outcomeIntro:
				"Design matters, but the investment decision starts with problems you can already recognise in the current website.",
			problem: "The problem",
			pricingEyebrow: "Options and prices",
			pricingTitle: "A way to start that matches the scope",
			pricingIntro:
				"The figures are guides that separate a focused intervention, a complete project and ongoing support.",
			pricing: {
				mostCommon: "Most common",
				from: "From",
				tax: "Tax not included",
				month: "/month",
				included: "Included",
				boundary: "Boundary:",
			},
			scopeEyebrow: "Scope of work",
			scopeTitle: "What can be included and what needs a separate quote",
			scopeIntro:
				"The proposal states what belongs in each option. This list helps prepare the initial conversation.",
			includedTitle: "Can form part of the project",
			boundaryTitle: "Depends on the selected scope",
			processEyebrow: "Working process",
			processIntro:
				"Content, platform, reviews and responsibilities are agreed before development.",
			processTitles: ["Understand", "Define", "Build", "Launch"],
			proofEyebrow: "Real work",
			proofTitle: "A web platform recovered and made operational",
			proofDescription:
				"GetYourTicket shows how I approach an existing web base, fix what prevents its use and make deployment, payments and maintenance clear.",
			proofAction: "View the project",
			relatedEyebrow: "Related services",
			relatedTitle: "Other ways to improve your web presence",
			relatedIntro:
				"WordPress, redesign and campaign pages suit different starting points.",
			relatedAction: "View service",
			faqEyebrow: "Before deciding",
			faqTitle: "Questions about the website project",
			faqIntro: "Meetings, budget, editing and timing before work starts.",
			services: "View all services",
		};
---

<div class="services-page service-detail-page granada-service-page">
	<section
		data-granada-service-hero
		class="granada-service-hero section-reveal"
		aria-labelledby="granada-service-title"
	>
		<div class="granada-service-hero__copy">
			<a href={`/${locale}/services/`} class="granada-service-hero__back">
				<Icon name="arrow-left" class="h-4 w-4" aria-hidden="true" />
				{copy.back}
			</a>
			<div class="granada-service-hero__identity">
				<ServiceIconBadge name={service.icon} size="lg" />
				<p class="eyebrow">{copy.eyebrow}</p>
			</div>
			<h1 id="granada-service-title">{page.title}</h1>
			<p class="granada-service-hero__intro">{page.intro}</p>
			<div class="granada-service-hero__actions">
				<a href={contactHref} class="button-action">
					{copy.assessment}
					<Icon name="arrow-right" class="h-4 w-4" aria-hidden="true" />
				</a>
				<a
					href={whatsappHref}
					target="_blank"
					rel="noopener noreferrer"
					class="button-secondary"
				>
					{copy.whatsapp}
					<Icon name="move-up-right" class="h-4 w-4" aria-hidden="true" />
				</a>
			</div>
		</div>

		<aside class="granada-service-summary" aria-label={copy.summary}>
			<div class="granada-service-summary__topline">
				<p class="eyebrow">{copy.summary}</p>
				<span aria-hidden="true">01</span>
			</div>
			<div class="granada-service-summary__price">
				<span>{copy.price}</span>
				<p><small>{copy.from}</small><strong>{entryPrice}</strong></p>
				<small>{copy.tax}</small>
			</div>
			<div class="granada-service-summary__timeline">
				<Icon name="clock" class="h-5 w-5" aria-hidden="true" />
				<span
					><small>{copy.timeline}</small><strong>{service.timeline}</strong
					></span
				>
			</div>
			<a href="#granada-pricing-options" class="button-secondary">
				{copy.compare}
				<Icon name="arrow-right" class="h-4 w-4 rotate-90" aria-hidden="true" />
			</a>
		</aside>
	</section>

	<div data-granada-service-trust class="granada-service-trust">
		<ServiceTrustStrip items={copy.trust} />
	</div>

	<section
		data-granada-service-outcome
		class="granada-service-outcome section-reveal"
		aria-labelledby="granada-outcome-title"
	>
		<header class="granada-service-heading">
			<div>
				<p class="eyebrow">{copy.outcomeEyebrow}</p>
				<h2 id="granada-outcome-title">{copy.outcomeTitle}</h2>
			</div>
			<p>{copy.outcomeIntro}</p>
		</header>
		<div class="granada-service-outcome__content">
			<div class="granada-service-outcome__problem">
				<p class="eyebrow">{copy.problem}</p>
				<strong>{page.problem.body[0]}</strong>
				<p>{page.problem.body[1]}</p>
			</div>
			<div class="granada-service-outcome__benefits">
				{
					page.cases.items.slice(0, 3).map((item, index) => (
						<article>
							<span aria-hidden="true">
								{String(index + 1).padStart(2, "0")}
							</span>
							<h3>{item.title}</h3>
							<p>{item.body}</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section
		id="granada-pricing-options"
		data-granada-service-pricing
		class="granada-service-pricing section-reveal"
		aria-labelledby="granada-pricing-title"
	>
		<header class="granada-service-heading">
			<div>
				<p class="eyebrow">{copy.pricingEyebrow}</p>
				<h2 id="granada-pricing-title">{copy.pricingTitle}</h2>
			</div>
			<p>{copy.pricingIntro}</p>
		</header>
		<ServicePricingGrid
			locale={locale}
			serviceSlug={service.slug}
			options={service.pricingOptions}
			contactHref={contactHref}
			copy={copy.pricing}
		/>
	</section>

	<section
		data-granada-service-scope
		class="granada-service-scope section-reveal"
		aria-labelledby="granada-scope-title"
	>
		<header class="granada-service-heading">
			<div>
				<p class="eyebrow">{copy.scopeEyebrow}</p>
				<h2 id="granada-scope-title">{copy.scopeTitle}</h2>
			</div>
			<p>{copy.scopeIntro}</p>
		</header>
		<div class="granada-service-scope__columns">
			<article>
				<Icon name="circle-check-big" class="h-6 w-6" aria-hidden="true" />
				<h3>{copy.includedTitle}</h3>
				<ul>
					{
						includedScope.map((item) => (
							<li>
								<>
									<Icon name="check" class="h-4 w-4" aria-hidden="true" />
									<span>{item}</span>
								</>
							</li>
						))
					}
				</ul>
			</article>
			<article>
				<Icon name="info" class="h-6 w-6" aria-hidden="true" />
				<h3>{copy.boundaryTitle}</h3>
				<ul>
					{
						boundaries.map((item) => (
							<li>
								<>
									<Icon name="arrow-right" class="h-4 w-4" aria-hidden="true" />
									<span>{item}</span>
								</>
							</li>
						))
					}
				</ul>
			</article>
		</div>
	</section>

	<section
		data-granada-service-process
		class="granada-service-process section-reveal"
		aria-labelledby="granada-process-title"
	>
		<header class="granada-service-heading">
			<div>
				<p class="eyebrow">{copy.processEyebrow}</p>
				<h2 id="granada-process-title">{page.process.title}</h2>
			</div>
			<p>{copy.processIntro}</p>
		</header>
		<ol>
			{
				page.process.steps.map((step, index) => (
					<li>
						<span aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
						<h3>{copy.processTitles[index]}</h3>
						<p>{step}</p>
					</li>
				))
			}
		</ol>
	</section>

	<section
		data-granada-service-proof
		class="granada-service-proof section-reveal"
		aria-labelledby="granada-proof-title"
	>
		<header class="granada-service-heading">
			<div>
				<p class="eyebrow">{copy.proofEyebrow}</p>
				<h2 id="granada-proof-title">{copy.proofTitle}</h2>
			</div>
			<p>{copy.proofDescription}</p>
		</header>
		<ServiceProofCard
			eyebrow={copy.proofEyebrow}
			title={featuredProject?.title ?? copy.proofTitle}
			description={featuredProject?.summary ?? copy.proofDescription}
			href={projectHref}
			actionLabel={copy.proofAction}
			image={projectImage
				? { src: projectImage.src, alt: projectImage.alt }
				: undefined}
		/>
	</section>

	<section
		data-granada-related-services
		class="granada-related-services section-reveal"
		aria-labelledby="granada-related-title"
	>
		<header class="granada-service-heading">
			<div>
				<p class="eyebrow">{copy.relatedEyebrow}</p>
				<h2 id="granada-related-title">{copy.relatedTitle}</h2>
			</div>
			<p>{copy.relatedIntro}</p>
		</header>
		<div class="granada-related-services__grid">
			{
				relatedServices.map((item) => (
					<article>
						<ServiceIconBadge name={item.icon} size="md" />
						<h3>{item.shortTitle}</h3>
						<p>{item.description}</p>
						<a href={getServiceHref(item)} class="button-secondary">
							{copy.relatedAction}
							<Icon name="arrow-right" class="h-4 w-4" aria-hidden="true" />
						</a>
					</article>
				))
			}
		</div>
	</section>

	<section
		data-granada-service-faq
		class="granada-service-faq section-reveal"
		aria-labelledby="granada-faq-title"
	>
		<header class="granada-service-heading">
			<div>
				<p class="eyebrow">{copy.faqEyebrow}</p>
				<h2 id="granada-faq-title">{copy.faqTitle}</h2>
			</div>
			<p>{copy.faqIntro}</p>
		</header>
		<div class="granada-service-faq__list">
			{
				page.faq.map((item, index) => (
					<details open={index === 0}>
						<summary>
							<span>{item.question}</span>
							<Icon name="plus" class="h-5 w-5" aria-hidden="true" />
						</summary>
						<p>{item.answer}</p>
					</details>
				))
			}
		</div>
	</section>

	<div data-granada-service-cta>
		<ConversionCta
			eyebrow={page.cta.eyebrow}
			title={page.cta.title}
			text={page.cta.text}
			primary={{ label: page.cta.button, href: contactHref }}
			secondary={{ label: copy.services, href: `/${locale}/services/` }}
			headingId="granada-service-conversion-title"
		/>
	</div>
</div>

<style>
	.granada-service-page {
		--services-card-padding: clamp(1.35rem, 2vw, 1.75rem);
		--granada-section-space: clamp(4.5rem, 7vw, 6.5rem);
	}

	.granada-service-page .eyebrow {
		color: var(--action);
	}

	.granada-service-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.65fr);
		gap: clamp(2rem, 5vw, 5rem);
		align-items: start;
		padding-block: 1rem var(--granada-section-space);
	}

	.granada-service-hero__back {
		display: inline-flex;
		gap: 0.5rem;
		align-items: center;
		color: var(--text-muted);
		font-size: 0.8rem;
		font-weight: 850;
	}

	.granada-service-hero__back:hover {
		color: var(--action);
	}

	.granada-service-hero__identity {
		display: flex;
		gap: 1rem;
		align-items: center;
		margin-top: 2rem;
	}

	.granada-service-hero h1 {
		max-width: 58rem;
		margin-top: 1.5rem;
		color: var(--home-navy);
		font-size: clamp(3rem, 6vw, 5.8rem);
		font-weight: 950;
		letter-spacing: -0.065em;
		line-height: 0.94;
		text-wrap: balance;
	}

	.granada-service-hero__intro {
		max-width: 48rem;
		margin-top: 1.5rem;
		color: var(--text-muted);
		font-size: 1.1rem;
		line-height: 1.75;
	}

	.granada-service-hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 2rem;
	}

	.granada-service-summary {
		border: 1px solid var(--surface-border);
		border-radius: 1.2rem;
		background: var(--surface);
		padding: clamp(1.35rem, 2.5vw, 2rem);
		box-shadow: var(--shadow-card);
	}

	.granada-service-summary__topline {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.granada-service-summary__topline > span {
		color: var(--action);
		font-size: 0.72rem;
		font-weight: 900;
		letter-spacing: 0.12em;
	}

	.granada-service-summary__price {
		display: grid;
		gap: 0.25rem;
		margin-top: 1.5rem;
		border-block: 1px solid var(--surface-border);
		padding-block: 1.4rem;
	}

	.granada-service-summary__price > span,
	.granada-service-summary__price small,
	.granada-service-summary__timeline small {
		color: var(--text-muted);
		font-size: 0.7rem;
		font-weight: 750;
	}

	.granada-service-summary__price p {
		display: flex;
		gap: 0.5rem;
		align-items: baseline;
	}

	.granada-service-summary__price strong {
		color: var(--home-navy);
		font-size: clamp(2.3rem, 4vw, 3.5rem);
		font-weight: 950;
		letter-spacing: -0.06em;
	}

	.granada-service-summary__timeline {
		display: flex;
		gap: 0.75rem;
		align-items: center;
		padding-block: 1.3rem;
		color: var(--action);
	}

	.granada-service-summary__timeline span {
		display: grid;
		gap: 0.2rem;
	}

	.granada-service-summary__timeline strong {
		color: var(--text);
		font-size: 0.9rem;
	}

	.granada-service-summary > a {
		width: 100%;
	}

	.granada-service-trust {
		margin-bottom: var(--granada-section-space);
	}

	.granada-service-heading {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(16rem, 0.8fr);
		gap: 1.5rem 3rem;
		align-items: end;
	}

	.granada-service-heading h2 {
		max-width: 54rem;
		margin-top: 0.9rem;
		color: var(--home-navy);
		font-size: clamp(2.2rem, 4.5vw, 4rem);
		font-weight: 950;
		letter-spacing: -0.055em;
		line-height: 1;
		text-wrap: balance;
	}

	.granada-service-heading > p {
		color: var(--text-muted);
		line-height: 1.7;
	}

	.granada-service-outcome,
	.granada-service-scope,
	.granada-service-process,
	.granada-service-proof,
	.granada-related-services,
	.granada-service-faq {
		padding-block: var(--granada-section-space);
	}

	.granada-service-outcome__content {
		display: grid;
		grid-template-columns: minmax(16rem, 0.75fr) minmax(0, 1.25fr);
		gap: clamp(2rem, 5vw, 5rem);
		margin-top: 3rem;
	}

	.granada-service-outcome__problem {
		border-top: 3px solid var(--action);
		padding-top: 1.3rem;
	}

	.granada-service-outcome__problem strong {
		display: block;
		margin-top: 1rem;
		color: var(--text);
		font-size: 1.25rem;
		line-height: 1.55;
	}

	.granada-service-outcome__problem > p:last-child {
		margin-top: 1rem;
		color: var(--text-muted);
		line-height: 1.7;
	}

	.granada-service-outcome__benefits {
		border-top: 1px solid var(--surface-border);
	}

	.granada-service-outcome__benefits article {
		display: grid;
		grid-template-columns: 2.5rem minmax(10rem, 0.42fr) minmax(0, 0.58fr);
		gap: 1rem;
		border-bottom: 1px solid var(--surface-border);
		padding-block: 1.25rem;
	}

	.granada-service-outcome__benefits span,
	.granada-service-process li > span {
		color: var(--action);
		font-size: 0.72rem;
		font-weight: 900;
		letter-spacing: 0.12em;
	}

	.granada-service-outcome__benefits h3,
	.granada-service-process h3,
	.granada-related-services h3,
	.granada-service-scope h3 {
		color: var(--text);
		font-size: 1.15rem;
		font-weight: 900;
	}

