---
import { Icon } from "astro-icon/components";
import type { Locale } from "@/i18n";
import type { CommercialLandingPage } from "@/lib/commercial-landings";
import type { ProjectEntry } from "@/lib/projects";
import type { ServiceItem } from "@/lib/services";

interface Props {
	locale: Locale;
	page: CommercialLandingPage;
	contactHref: string;
	servicePages: ServiceItem[];
	featuredProject?: ProjectEntry;
	yearsWorking: string;
}

const {
	locale,
	page,
	contactHref,
	servicePages,
	featuredProject,
	yearsWorking,
} = Astro.props as Props;
const es = locale === "es";
const getService = (translationKey: string) =>
	servicePages.find(
		(service) =>
			service.translationKey === translationKey ||
			service.slug === translationKey,
	);
const getServiceHref = (service?: ServiceItem) =>
	service
		? (service.canonicalPath ?? `/${locale}/services/${service.slug}/`)
		: `/${locale}/services/`;
const projectHref = featuredProject
	? `/${locale}/projects/${featuredProject.slug}/`
	: `/${locale}/projects/`;
const projectImage = featuredProject?.img?.imgStatic;

const needs = [
	{
		icon: "globe",
		title: es ? "Crear una web nueva" : "Build a new website",
		text: es
			? "Presentar bien el negocio y convertir las visitas en conversaciones útiles."
			: "Present the business clearly and turn visits into useful conversations.",
		service: getService("web-wordpress:0"),
	},
	{
		icon: "layers",
		title: es ? "Replantear la web actual" : "Rethink the current website",
		text: es
			? "Ordenar estructura, contenido, velocidad y experiencia móvil."
			: "Improve structure, content, speed and the mobile experience.",
		service: getService("website-redesign"),
	},
	{
		icon: "wordpress",
		title: es ? "Mejorar WordPress" : "Improve WordPress",
		text: es
			? "Dejar una instalación rápida, editable y sencilla de mantener."
			: "Leave an installation that is fast, editable and straightforward to maintain.",
		service: getService("web-wordpress:2"),
	},
	{
		icon: "send",
		title: es ? "Lanzar una campaña" : "Launch a campaign",
		text: es
			? "Crear una landing centrada en una oferta y una acción principal."
			: "Create a landing page focused on one offer and one primary action.",
		service: getService("web-wordpress:5"),
	},
];

const typicalWork = page.cases.items.slice(0, 3).map((item, index) => ({
	...item,
	points: page.builds.items.slice(index, index + 2),
	service: [
		getService("web-wordpress:0"),
		getService("web-wordpress:5"),
		getService("website-redesign"),
	][index],
}));

const decisionTitles = es
	? [
			"Google apenas muestra tu web",
			"La oferta no se entiende",
			"La base técnica frena cambios",
		]
	: [
			"Google rarely shows your website",
			"The offer is hard to understand",
			"The technical base blocks changes",
		];
---

<div class="granada-landing">
	<section
		data-granada-hero
		class="granada-hero section-reveal"
		aria-labelledby="granada-title"
	>
		<p class="eyebrow">{page.eyebrow}</p>
		<h1 id="granada-title">{page.title}</h1>

		<div class="granada-hero__columns">
			<div class="granada-pitch">
				<p class="granada-pitch__intro">{page.intro}</p>
				<p class="granada-pitch__evidence">
					<strong>
						{yearsWorking}+ {
							es
								? "años desarrollando productos web"
								: "years building web products"
						}
					</strong>
					<span>
						{
							es
								? "Hablas directamente con quien diseña, desarrolla y publica la web."
								: "You speak directly with the person who designs, builds and launches the website."
						}
					</span>
				</p>
				<p class="granada-pitch__challenge">{page.problem.body[1]}</p>

				<div class="granada-pitch__actions">
					<a href={contactHref} class="button-action">
						{page.primaryCta}
						<Icon name="arrow-right" class="h-4 w-4" aria-hidden="true" />
					</a>
					<a href={projectHref} class="granada-pitch__project-link">
						{page.secondaryCta}
						<Icon name="move-up-right" class="h-4 w-4" aria-hidden="true" />
					</a>
				</div>
				<p class="granada-pitch__note">
					<Icon name="circle-check-big" class="h-4 w-4" aria-hidden="true" />
					{
						es
							? "Primera valoración sin compromiso para acotar páginas, plataforma y prioridades."
							: "An initial no-obligation assessment to define pages, platform and priorities."
					}
				</p>
			</div>

			<div class="granada-selector">
				<header>
					<h2>
						{es ? "¿Qué necesita tu web?" : "What does your website need?"}
					</h2>
					<p>
						{
							es
								? "El punto de partida determina el alcance y la tecnología."
								: "The starting point determines the scope and technology."
						}
					</p>
				</header>
				<div class="granada-selector__grid">
					{
						needs.map((need) => (
							<a href={getServiceHref(need.service)} class="granada-option">
								<Icon name={need.icon} class="h-6 w-6" aria-hidden="true" />
								<span>
									<strong>{need.title}</strong>
									<small>{need.text}</small>
								</span>
								<Icon
									name="arrow-right"
									class="granada-option__arrow h-4 w-4"
									aria-hidden="true"
								/>
							</a>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section
		data-granada-decision
		class="granada-decision section-reveal"
		aria-labelledby="granada-decision-title"
	>
		<header class="granada-section-heading">
			<div>
				<p class="eyebrow">
					{es ? "Decisión de inversión" : "Investment decision"}
				</p>
				<h2 id="granada-decision-title">{page.whenWorthIt.title}</h2>
			</div>
			<p>
				{
					es
						? "Una web nueva tiene sentido cuando resuelve un problema comercial o de mantenimiento que ya puedes reconocer."
						: "A new website makes sense when it solves a commercial or maintenance problem you can already recognise."
				}
			</p>
		</header>
		<ol>
			{
				page.whenWorthIt.items.slice(0, 3).map((item, index) => (
					<li>
						<span>{String(index + 1).padStart(2, "0")}</span>
						<h3>{decisionTitles[index]}</h3>
						<p>{item}</p>
					</li>
				))
			}
		</ol>
	</section>

	<section
		data-granada-services
		class="granada-services section-reveal"
		aria-labelledby="granada-services-title"
	>
		<header class="granada-section-heading">
			<div>
				<p class="eyebrow">{es ? "Trabajo habitual" : "Typical work"}</p>
				<h2 id="granada-services-title">{page.cases.title}</h2>
			</div>
			<p>{page.cases.intro}</p>
		</header>
		<div class="granada-services__grid">
			{
				typicalWork.map((item, index) => (
					<article>
						<div class="granada-services__topline">
							<span>{String(index + 1).padStart(2, "0")}</span>
							<Icon
								name={["globe", "send", "layers"][index]}
								class="h-7 w-7"
								aria-hidden="true"
							/>
						</div>
						<h3>{item.title}</h3>
						<p>{item.body}</p>
						<ul>
							{item.points.map((point) => (
								<li>
									<Icon name="check" class="h-4 w-4" aria-hidden="true" />
									{point}
								</li>
							))}
						</ul>
						<a href={getServiceHref(item.service)}>
							{es ? "Ver servicio" : "View service"}
							<Icon name="arrow-right" class="h-4 w-4" aria-hidden="true" />
						</a>
					</article>
				))
			}
		</div>
	</section>

	{
		featuredProject && (
			<section
				data-granada-proof
				class="granada-proof section-reveal"
				aria-labelledby="granada-proof-title"
			>
				<div class="granada-proof__copy">
					<p class="eyebrow">{es ? "Trabajo real" : "Real work"}</p>
					<h2 id="granada-proof-title">
						{es
							? "Una base técnica que también debe funcionar después de publicar"
							: "A technical base that still works after launch"}
					</h2>
					<p>
						{es
							? "Este proyecto muestra cómo abordo una plataforma web existente: entender la base, recuperar lo que aporta valor y dejarla operativa con responsabilidades claras."
							: "This project shows how I approach an existing web platform: understand the base, recover what has value and leave it operational with clear responsibilities."}
					</p>
					<a href={projectHref} class="granada-proof__link">
						{es ? "Ver el proyecto" : "View the project"}
						<Icon name="arrow-right" class="h-4 w-4" aria-hidden="true" />
					</a>
				</div>
				<a href={projectHref} class="granada-project-preview">
					{projectImage ? (
						<img
							src={projectImage.src}
							alt={projectImage.alt ?? featuredProject.title}
							width="960"
							height="600"
							loading="lazy"
							decoding="async"
							sizes="(max-width: 48rem) calc(100vw - 2rem), 42rem"
						/>
					) : (
						<span
							class="granada-project-preview__fallback"
							aria-hidden="true"
						/>
					)}
					<span>
						<strong>{featuredProject.title}</strong>
						<small>{featuredProject.status}</small>
					</span>
				</a>
			</section>
		)
	}

	<section
		data-granada-process
		class="granada-process section-reveal"
		aria-labelledby="granada-process-title"
	>
		<header class="granada-section-heading">
			<div>
				<p class="eyebrow">{es ? "Forma de trabajo" : "Working process"}</p>
				<h2 id="granada-process-title">{page.process.title}</h2>
			</div>
			<p>
				{
					es
						? "El alcance, los contenidos y las responsabilidades quedan claros antes de construir."
						: "Scope, content and responsibilities are made clear before the build starts."
				}
			</p>
		</header>
		<ol>
			{
				page.process.steps.map((step, index) => (
					<li>
						<span>{String(index + 1).padStart(2, "0")}</span>
						<h3>
							{
								(es
									? ["Entender", "Acotar", "Construir", "Publicar"]
									: ["Understand", "Define", "Build", "Launch"])[index]
							}
						</h3>
						<p>{step}</p>
					</li>
				))
			}
		</ol>
	</section>

	<section
		data-granada-faq
		class="granada-faq section-reveal"
		aria-labelledby="granada-faq-title"
	>
		<header class="granada-section-heading">
			<div>
				<p class="eyebrow">{es ? "Antes de decidir" : "Before deciding"}</p>
				<h2 id="granada-faq-title">
					{
						es
							? "Preguntas sobre el proyecto web"
							: "Questions about the website project"
					}
				</h2>
			</div>
			<p>
				{
					es
						? "Respuestas directas sobre reuniones, presupuesto, edición y tiempos."
						: "Direct answers about meetings, budget, editing and timing."
				}
			</p>
		</header>
		<div class="granada-faq__list">
			{
				page.faq.map((item, index) => (
					<details open={index === 0}>
						<summary>
							<span>{item.question}</span>
							<Icon name="plus" class="h-5 w-5" aria-hidden="true" />
						</summary>
						<p>{item.answer}</p>
					</details>
				))
			}
		</div>
	</section>

	<section
		data-granada-cta
		class="granada-final-cta section-reveal"
		aria-labelledby="granada-cta-title"
	>
		<div>
			<p class="eyebrow">{page.cta.eyebrow}</p>
			<h2 id="granada-cta-title">{page.cta.title}</h2>
			<p>{page.cta.text}</p>
		</div>
		<a href={contactHref} class="button-action">
			{page.cta.button}
			<Icon name="arrow-right" class="h-4 w-4" aria-hidden="true" />
		</a>
	</section>
</div>

<style>
	.granada-landing {
		--granada-rule: color-mix(
			in srgb,
			var(--home-navy) 13%,
			var(--surface-border)
		);
	}

	.granada-landing .eyebrow {
		color: var(--action);
	}

	.granada-hero {
		padding-block: 2rem 5.5rem;
	}

	.granada-hero > .eyebrow {
		text-align: center;
	}

	.granada-hero > h1 {
		max-width: 68rem;
		margin: 1rem auto 0;
		color: var(--home-navy);
		font-size: clamp(2.7rem, 5.8vw, 5.5rem);
		font-weight: 900;
		letter-spacing: -0.06em;
		line-height: 0.96;
		text-align: center;
		text-wrap: balance;
	}

	.granada-hero__columns {
		display: grid;
		grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
		gap: clamp(2.5rem, 6vw, 6rem);
		margin-top: clamp(3rem, 6vw, 5rem);
		align-items: start;
	}

	.granada-pitch__intro {
		color: var(--text);
		font-size: 1.15rem;
		font-weight: 700;
		line-height: 1.7;
	}

	.granada-pitch__evidence {
		display: grid;
		gap: 0.2rem;
		margin-top: 2rem;
		border-top: 1px solid var(--surface-border);
		padding-top: 1.4rem;
	}

	.granada-pitch__evidence strong {
		color: var(--action);
		font-size: 1.1rem;
	}

	.granada-pitch__evidence span,
	.granada-pitch__challenge {
		color: var(--text-muted);
		line-height: 1.65;
	}

	.granada-pitch__challenge {
		margin-top: 1.2rem;
		font-weight: 700;
	}

	.granada-pitch__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		align-items: center;
		margin-top: 2rem;
	}

	.granada-pitch__project-link,
	.granada-proof__link,
	.granada-services article > a {
		display: inline-flex;
		width: fit-content;
		min-height: 2.75rem;
		align-items: center;
		gap: 0.5rem;
		border-bottom: 1px solid var(--surface-border);
		color: var(--text);
		font-size: 0.82rem;
		font-weight: 900;
	}

	.granada-pitch__project-link:hover,
	.granada-proof__link:hover,
	.granada-services article > a:hover {
		border-color: var(--action);
		color: var(--action);
	}

	.granada-pitch__note {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		margin-top: 0.8rem;
		color: var(--text-muted);
		font-size: 0.75rem;
	}

	.granada-pitch__note :global(svg) {
		flex: none;
		color: var(--action);
	}

	.granada-selector header h2 {
		color: var(--text);
		font-size: clamp(1.5rem, 2.6vw, 2.2rem);
		font-weight: 900;
		letter-spacing: -0.035em;
	}

	.granada-selector header p {
		margin-top: 0.75rem;
		color: var(--text-muted);
		line-height: 1.6;
	}

	.granada-selector__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.8rem;
		margin-top: 1.6rem;
	}

	.granada-option {
		position: relative;
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.85rem;
		min-height: 9.5rem;
		border: 1px solid var(--surface-border);
		border-radius: 0.9rem;
		background: var(--surface-strong);
		padding: 1.25rem;
		box-shadow: 0 10px 32px rgba(20, 35, 52, 0.06);
	}

	.granada-option > :global(svg:first-child),
	.granada-option__arrow {
		color: var(--action);
	}

	.granada-option span {
		display: grid;
		align-content: start;
		gap: 0.45rem;
	}

	.granada-option strong {
		color: var(--text);
		font-size: 1rem;
		line-height: 1.25;
	}

	.granada-option small {
		color: var(--text-muted);
		line-height: 1.5;
	}

	.granada-option__arrow {
		position: absolute;
		right: 1rem;
		bottom: 1rem;
	}

	.granada-option:hover {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--action) 45%, var(--surface-border));
	}

	.granada-section-heading {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(16rem, 0.8fr);
		gap: 1.5rem 3rem;
		align-items: end;
	}

	.granada-section-heading h2,
	.granada-proof h2,
	.granada-final-cta h2 {
		margin-top: 1rem;
		color: var(--home-navy);
		font-size: clamp(2.2rem, 4.8vw, 4rem);
		font-weight: 900;
		letter-spacing: -0.055em;
		line-height: 1;
		text-wrap: balance;
	}

	.granada-section-heading > p,
	.granada-proof__copy > p:not(.eyebrow),
	.granada-final-cta div > p:last-child {
		color: var(--text-muted);
		line-height: 1.7;
	}

	.granada-decision {
		width: 100vw;
		margin-inline: calc(50% - 50vw);
		background: var(--bg-band);
		padding: clamp(4.5rem, 8vw, 7rem) max(1rem, calc((100vw - 88rem) / 2));
	}

	.granada-decision ol,
	.granada-services__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		margin-top: 3rem;
		border-block: 1px solid var(--surface-border);
	}

	.granada-decision li,
	.granada-services article {
		padding: 2rem;
	}

	.granada-decision li + li,
	.granada-services article + article {
		border-left: 1px solid var(--surface-border);
	}

	.granada-decision li > span,
	.granada-services__topline span {
		color: var(--action);
		font-size: 0.75rem;
		font-weight: 900;
		letter-spacing: 0.12em;
	}

	.granada-decision h3,
	.granada-services h3,
	.granada-process h3 {
		margin-top: 1rem;
		color: var(--text);
		font-size: 1.25rem;
		font-weight: 900;
	}

	.granada-decision li p,
	.granada-services article > p,
	.granada-process li p {
		margin-top: 0.65rem;
		color: var(--text-muted);
		line-height: 1.65;
	}

	.granada-services,
	.granada-process,
	.granada-faq {
		padding-block: clamp(5rem, 9vw, 8rem);
	}

	.granada-services__topline {
		display: flex;
		align-items: center;
		justify-content: space-between;
		color: var(--action);
	}

	.granada-services article {
		display: flex;
		min-width: 0;
		flex-direction: column;
	}

	.granada-services article h3 {
		margin-top: 2rem;
		font-size: clamp(1.45rem, 2.3vw, 2rem);
		letter-spacing: -0.04em;
	}

	.granada-services article ul {
		display: grid;
		gap: 0.7rem;
		margin-top: 1.5rem;
	}

	.granada-services article li {
		display: flex;
		gap: 0.6rem;
		align-items: flex-start;
		color: var(--text);
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1.5;
	}

	.granada-services article li :global(svg) {
		margin-top: 0.12rem;
		flex: none;
		color: var(--action);
	}

	.granada-services article > a {
		margin-top: auto;
		padding-top: 2rem;
	}

	.granada-proof {
		display: grid;
		width: 100vw;
		grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
		gap: clamp(2.5rem, 6vw, 6rem);
		align-items: center;
		margin-inline: calc(50% - 50vw);
		background: var(--surface-strong);
		padding: clamp(4.5rem, 8vw, 7rem) max(1rem, calc((100vw - 88rem) / 2));
	}

	.granada-proof__link {
		margin-top: 1.5rem;
	}

	.granada-project-preview {
		display: grid;
		grid-template-columns: 10rem minmax(0, 1fr);
		gap: 1rem;
		align-items: center;
		border: 1px solid var(--surface-border);
		background: var(--surface);
		padding: 0.75rem;
	}

	.granada-project-preview img,
	.granada-project-preview__fallback {
		width: 100%;
		aspect-ratio: 16 / 10;
		object-fit: cover;
		background: var(--bg-band);
	}

	.granada-project-preview > span:last-child {
		display: grid;
		gap: 0.35rem;
	}

	.granada-project-preview strong {
		color: var(--text);
		line-height: 1.3;
	}

	.granada-project-preview small {
		color: var(--text-muted);
	}

	.granada-process ol {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		margin-top: 3.5rem;
		border-top: 1px solid var(--surface-border);
	}

	.granada-process li {
		padding: 2rem 1.5rem 0 0;
	}

	.granada-process li + li {
		border-left: 1px solid var(--surface-border);
		padding-left: 1.5rem;
	}

	.granada-process li > span {
		display: inline-grid;
		width: 2.3rem;
		height: 2.3rem;
		place-items: center;
		border-radius: 50%;
		background: color-mix(in srgb, var(--action) 13%, transparent);
		color: var(--action);
		font-size: 0.7rem;
		font-weight: 900;
	}

	.granada-faq {
