---
import { t, type Locale } from "@/i18n";

interface Education {
	degree: string;
	institution: string;
	location: string;
	startDate: string;
	endDate: string;
	description: string;
	notes?: string;
	skills?: string[];
}

const { education, locale = "en" } = Astro.props as {
	education: Education;
	locale?: Locale;
};

const dateLabel = `${education.startDate} - ${education.endDate}`;
---

<article
	class="dark-card hover-card grid gap-6 p-5 md:p-7 lg:grid-cols-[0.32fr_1fr]"
>
	<div class="space-y-3">
		<p class="eyebrow">{dateLabel}</p>
		<p class="text-sm font-black text-[var(--text)]">{education.institution}</p>
		<p class="muted-copy text-sm">{education.location}</p>
	</div>

	<div class="max-w-4xl">
		<h3
			class="text-2xl leading-tight font-black text-[var(--text)] md:text-3xl"
		>
			{education.degree}
		</h3>

		<p class="muted-copy mt-5 max-w-2xl text-base leading-7">
			{education.description}
		</p>

		<div class="mt-6 flex flex-wrap gap-2">
			{
				education.skills
					?.slice(0, 4)
					.map((skill) => <span class="tag-pill">{skill}</span>)
			}
		</div>

		{
			education.notes ? (
				<p class="muted-copy mt-5 text-sm">
					<span class="font-bold text-[var(--text)]">
						{t(locale, "educationCard.gradeLabel")}
					</span>{" "}
					{education.notes}
				</p>
			) : null
		}
	</div>
</article>
