---
import { t, type Locale } from "@/i18n";

interface Education {
	degree: string;
	institution: string;
	location: string;
	startDate: string;
	endDate: string;
	description: string;
	notes?: string;
	skills?: string[];
}

const { education, locale = "en" } = Astro.props as {
	education: Education;
	locale?: Locale;
};

const dateLabel = `${education.startDate} - ${education.endDate}`;
---

<article class="grid gap-6 lg:grid-cols-[0.36fr_1fr] lg:gap-12">
	<div class="space-y-3">
		<p class="text-sm font-semibold text-slate-950 dark:text-slate-50">
			{education.institution}
		</p>
		<p class="text-sm text-slate-500 dark:text-slate-400">{dateLabel}</p>
		<p class="text-sm text-slate-500 dark:text-slate-400">
			{education.location}
		</p>
	</div>

	<div class="max-w-4xl">
		<h3
			class="text-2xl leading-tight font-semibold tracking-[-0.03em] text-slate-950 md:text-4xl dark:text-slate-50"
		>
			{education.degree}
		</h3>

		<p
			class="mt-5 max-w-2xl text-base leading-7 text-slate-600 dark:text-slate-300"
		>
			{education.description}
		</p>

		<div class="mt-6 flex flex-wrap gap-2">
			{
				education.skills
					?.slice(0, 4)
					.map((skill) => (
						<span class="inline-flex items-center rounded-full bg-slate-200/65 px-3 py-1.5 text-xs font-semibold text-slate-700 dark:bg-slate-800/70 dark:text-slate-200">
							{skill}
						</span>
					))
			}
		</div>

		{
			education.notes ? (
				<p class="mt-5 text-sm text-slate-500 dark:text-slate-400">
					<span class="font-semibold text-slate-700 dark:text-slate-200">
						{t(locale, "educationCard.gradeLabel")}
					</span>{" "}
					{education.notes}
				</p>
			) : null
		}
	</div>
</article>
