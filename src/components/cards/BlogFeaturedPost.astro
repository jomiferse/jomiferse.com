---
interface Props {
	href: string;
	title: string;
	description: string;
	dateLabel: string;
	readingTime?: string;
	cover: {
		src: string;
		alt: string;
	};
	featuredLabel: string;
	readLabel: string;
}

const {
	href,
	title,
	description,
	dateLabel,
	readingTime,
	cover,
	featuredLabel,
	readLabel,
} = Astro.props as Props;
---

<a href={href} class="group block">
	<article
		data-blog-featured
		class="dark-card hover-card grid overflow-hidden lg:grid-cols-[minmax(0,1.08fr)_minmax(22rem,0.92fr)]"
	>
		<div
			class="overflow-hidden border-b border-[var(--surface-border)] lg:border-r lg:border-b-0"
		>
			<img
				src={cover.src}
				alt={cover.alt}
				width="1600"
				height="900"
				loading="eager"
				fetchpriority="high"
				class="aspect-[16/9] h-full w-full object-cover transition duration-500 group-hover:scale-[1.015]"
			/>
		</div>

		<div class="flex flex-col justify-center p-6 md:p-8 lg:p-10">
			<p class="eyebrow text-[var(--action)]">{featuredLabel}</p>
			<div
				class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm font-semibold text-[var(--text-muted)]"
			>
				<time>{dateLabel}</time>
				{readingTime ? <span aria-hidden="true">·</span> : null}
				{readingTime ? <span>{readingTime}</span> : null}
			</div>

			<h2 class="mt-4 text-3xl font-black text-[var(--text)] md:text-4xl">
				{title}
			</h2>
			<p class="muted-copy mt-4 line-clamp-3 leading-7">{description}</p>

			<span class="button-action mt-7 w-fit">
				{readLabel}
				<span aria-hidden="true">→</span>
			</span>
		</div>
	</article>
</a>
