---
import { Icon } from "astro-icon/components";
import { t, type Locale } from "@/i18n";

interface Certification {
	name: string;
	provider: string;
	year: string;
	icon: string;
	credentialId?: string;
	url?: string;
	skills?: string[];
}

const { certification, locale = "en" } = Astro.props as {
	certification: Certification;
	locale?: Locale;
};
---

<article
	class="dark-card hover-card grid gap-6 p-5 md:p-7 lg:grid-cols-[0.32fr_1fr]"
>
	<div class="space-y-3">
		<div
			class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-[var(--surface-border)] bg-[var(--accent-soft)] text-[var(--accent-strong)] dark:text-[var(--accent)]"
			aria-hidden="true"
		>
			<Icon name="badge-check" class="h-5 w-5" />
		</div>
		<p class="text-sm font-black text-[var(--text)]">
			{certification.provider}
		</p>
		<p class="muted-copy text-sm">{certification.year}</p>
		{
			certification.credentialId ? (
				<p class="muted-copy max-w-xs text-xs leading-6">
					{t(locale, "certificationCard.idLabel")} {certification.credentialId}
				</p>
			) : null
		}
	</div>

	<div class="max-w-4xl">
		<h3
			class="text-2xl leading-tight font-black text-[var(--text)] md:text-3xl"
		>
			{certification.name}
		</h3>

		<div class="mt-6 flex flex-wrap gap-2">
			{
				certification.skills
					?.slice(0, 5)
					.map((skill) => <span class="tag-pill">{skill}</span>)
			}
		</div>

		{
			certification.url ? (
				<a
					href={certification.url}
					target="_blank"
					rel="noopener noreferrer nofollow"
					class="mt-7 inline-flex items-center gap-2 text-sm font-bold text-[var(--accent-strong)] hover:text-[var(--text)] dark:text-[var(--accent)]"
				>
					{t(locale, "certificationCard.viewCredential")}
					<Icon name="move-up-right" class="h-4 w-4" />
				</a>
			) : null
		}
	</div>
</article>
