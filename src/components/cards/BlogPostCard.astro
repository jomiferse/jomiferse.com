---
interface Props {
	href: string;
	title: string;
	description: string;
	dateLabel: string;
	tags?: string[];
	readingTime?: string;
	cover: {
		src: string;
		alt: string;
	};
}

const {
	href,
	title,
	description,
	dateLabel,
	tags = [],
	readingTime,
	cover,
} = Astro.props as Props;

const cleanTags = tags.filter((tag) => tag !== "featured").slice(0, 2);
---

<a href={href} class="group block h-full">
	<article class="dark-card hover-card flex h-full flex-col overflow-hidden">
		<div class="overflow-hidden border-b border-[var(--surface-border)]">
			<img
				src={cover.src}
				alt={cover.alt}
				width="1600"
				height="900"
				loading="lazy"
				class="aspect-[16/9] w-full object-cover transition duration-300 group-hover:scale-[1.02]"
			/>
		</div>

		<div class="flex flex-1 flex-col p-5 md:p-6">
			<div
				class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs font-bold text-[var(--text-muted)]"
			>
				<time>{dateLabel}</time>
				{readingTime ? <span aria-hidden="true">·</span> : null}
				{readingTime ? <span>{readingTime}</span> : null}
			</div>

			<h2
				class="mt-4 line-clamp-2 text-xl font-black text-[var(--text)] transition group-hover:text-[var(--accent-strong)] md:text-2xl dark:group-hover:text-[var(--accent)]"
			>
				{title}
			</h2>

			<p class="muted-copy mt-3 line-clamp-2 text-sm leading-6">
				{description}
			</p>

			<div class="mt-auto flex flex-wrap gap-2 pt-5">
				{cleanTags.map((tag) => <span class="tag-pill">{tag}</span>)}
			</div>
		</div>
	</article>
</a>
