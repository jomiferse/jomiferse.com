---
interface Props {
	href: string;
	title: string;
	description: string;
	dateLabel: string;
	tags?: string[];
	featured?: boolean;
	readingTime?: string;
	featuredLabel?: string;
}

const {
	href,
	title,
	description,
	dateLabel,
	tags = [],
	featured = false,
	readingTime,
	featuredLabel = "Selected",
} = Astro.props as Props;

const cleanTags = tags.filter((tag) => tag !== "featured").slice(0, 3);
---

<a href={href} class="group block">
	<article class="dark-card hover-card flex min-h-[16rem] flex-col p-6">
		<div
			class="flex flex-wrap items-center gap-x-3 gap-y-2 text-xs font-bold text-[var(--text-muted)]"
		>
			<span>{dateLabel}</span>
			{readingTime ? <span>{readingTime}</span> : null}
			{featured ? <span>{featuredLabel}</span> : null}
		</div>

		<h2
			class="mt-6 text-2xl font-black text-[var(--text)] group-hover:text-[var(--accent-strong)] dark:group-hover:text-[var(--accent)]"
		>
			{title}
		</h2>

		<p class="muted-copy mt-4 leading-7">
			{description}
		</p>

		<div class="mt-auto flex flex-wrap gap-2 pt-6">
			{cleanTags.map((tag) => <span class="tag-pill">{tag}</span>)}
		</div>
	</article>
</a>
