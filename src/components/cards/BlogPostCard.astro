---
interface Props {
	href: string;
	title: string;
	description: string;
	dateLabel: string;
	tags?: string[];
	featured?: boolean;
	readingTime?: string;
}

const {
	href,
	title,
	description,
	dateLabel,
	tags = [],
	featured = false,
	readingTime,
} = Astro.props as Props;

const cleanTags = tags.filter((tag) => tag !== "featured").slice(0, 3);
---

<a href={href} class="group block">
	<article
		class="border-t border-slate-200/70 pt-6 transition-colors dark:border-slate-800/70"
	>
		<div
			class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-slate-500 dark:text-slate-400"
		>
			<span>{dateLabel}</span>
			{readingTime ? <span>{readingTime}</span> : null}
			{
				featured ? (
					<span class="font-semibold text-slate-700 dark:text-slate-200">
						Featured
					</span>
				) : null
			}
		</div>

		<h3
			class="mt-4 max-w-3xl text-2xl leading-tight font-semibold tracking-[-0.03em] text-slate-950 transition-colors group-hover:text-[var(--accent-strong)] md:text-4xl dark:text-slate-50 dark:group-hover:text-[var(--accent-strong)]"
		>
			{title}
		</h3>

		<p
			class="mt-4 max-w-2xl text-base leading-7 text-slate-600 dark:text-slate-300"
		>
			{description}
		</p>

		<div class="mt-5 flex flex-wrap gap-2">
			{
				cleanTags.map((tag) => (
					<span class="inline-flex items-center rounded-full bg-slate-200/65 px-3 py-1.5 text-xs font-semibold text-slate-700 dark:bg-slate-800/70 dark:text-slate-200">
						{tag}
					</span>
				))
			}
		</div>
	</article>
</a>
