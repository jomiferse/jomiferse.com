---
import { Icon } from "astro-icon/components";
import { getTranslations, t, type Locale } from "@/i18n";

const { locale } = Astro.props as { locale: Locale };
const projectTypes = getTranslations(locale).contactForm.projectTypes;
---

<form
	action="/api/contact"
	method="post"
	enctype="multipart/form-data"
	class="dark-card p-5 md:p-6"
>
	<input type="hidden" name="locale" value={locale} />

	<div class="grid gap-5 md:grid-cols-2">
		<div>
			<label for="contact-name" class="eyebrow mb-2 block">
				{t(locale, "contactForm.nameLabel")}
			</label>
			<div class="form-shell">
				<Icon name="user" class="form-icon h-5 w-5" />
				<input
					id="contact-name"
					name="name"
					autocomplete="name"
					required
					placeholder={t(locale, "contactForm.namePlaceholder")}
					class="form-input"
				/>
			</div>
		</div>

		<div>
			<label for="contact-email" class="eyebrow mb-2 block">
				{t(locale, "contactForm.emailLabel")}
			</label>
			<div class="form-shell">
				<Icon name="mail" class="form-icon h-5 w-5" />
				<input
					id="contact-email"
					type="email"
					name="email"
					autocomplete="email"
					required
					placeholder={t(locale, "contactForm.emailPlaceholder")}
					class="form-input"
				/>
			</div>
		</div>

		<div class="md:col-span-2">
			<label for="contact-project-type" class="eyebrow mb-2 block">
				{t(locale, "contactForm.projectTypeLabel")}
			</label>
			<div class="form-shell">
				<Icon name="briefcase" class="form-icon h-5 w-5" />
				<select
					id="contact-project-type"
					name="projectType"
					class="form-input"
					required
				>
					<option value=""
						>{t(locale, "contactForm.projectTypePlaceholder")}</option
					>
					{projectTypes.map((type) => <option value={type}>{type}</option>)}
				</select>
			</div>
		</div>

		<div class="md:col-span-2">
			<label for="contact-message" class="eyebrow mb-2 block">
				{t(locale, "contactForm.messageLabel")}
			</label>
			<div class="form-shell form-shell-textarea">
				<Icon name="pencil" class="form-icon form-textarea-icon h-5 w-5" />
				<textarea
					id="contact-message"
					name="message"
					required
					rows="6"
					placeholder={t(locale, "contactForm.messagePlaceholder")}
					class="form-input form-textarea leading-7"></textarea>
			</div>
		</div>

		<div class="md:col-span-2">
			<label for="contact-attachment" class="eyebrow mb-2 block">
				{t(locale, "contactForm.attachmentLabel")}
			</label>
			<div class="form-shell">
				<Icon name="paperclip" class="form-icon h-5 w-5" />
				<input
					id="contact-attachment"
					type="file"
					name="attachment"
					accept="application/pdf,.pdf"
					class="form-input form-file cursor-pointer"
				/>
			</div>
			<p class="mt-2 text-xs text-[var(--text-muted)]">
				{t(locale, "contactForm.attachmentHint")}
			</p>
		</div>
	</div>

	<button type="submit" class="button-primary form-button mt-6 w-full">
		{t(locale, "contactForm.submit")}
		<Icon name="arrow-right" class="h-4 w-4" />
	</button>
</form>
