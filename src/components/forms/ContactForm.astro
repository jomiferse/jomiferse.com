---
import { Icon } from "astro-icon/components";
import { getTranslations, t, type Locale } from "@/i18n";
import type { ContactSourceCategory } from "@/lib/contact-source";

const {
	locale,
	sourceCategory = "direct",
	sourcePath,
	idPrefix = "contact",
} = Astro.props as {
	locale: Locale;
	sourceCategory?: ContactSourceCategory;
	sourcePath?: string;
	idPrefix?: string;
};
const projectTypes = getTranslations(locale).contactForm.projectTypes;
---

<form
	action="/api/contact"
	method="post"
	enctype="multipart/form-data"
	class="dark-card p-5 md:p-6"
>
	<input type="hidden" name="locale" value={locale} />
	<input
		type="hidden"
		name="sourceCategory"
		value={sourceCategory}
		data-source-category
	/>
	<input
		type="hidden"
		name="sourcePath"
		value={sourcePath ?? ""}
		data-source-path
	/>

	<div class="grid gap-5 md:grid-cols-2">
		<div>
			<label for={`${idPrefix}-name`} class="eyebrow mb-2 block">
				{t(locale, "contactForm.nameLabel")}
			</label>
			<div class="form-shell">
				<Icon name="user" class="form-icon h-5 w-5" />
				<input
					id={`${idPrefix}-name`}
					name="name"
					autocomplete="name"
					required
					placeholder={t(locale, "contactForm.namePlaceholder")}
					class="form-input"
				/>
			</div>
		</div>

		<div>
			<label for={`${idPrefix}-email`} class="eyebrow mb-2 block">
				{t(locale, "contactForm.emailLabel")}
			</label>
			<div class="form-shell">
				<Icon name="mail" class="form-icon h-5 w-5" />
				<input
					id={`${idPrefix}-email`}
					type="email"
					name="email"
					autocomplete="email"
					required
					placeholder={t(locale, "contactForm.emailPlaceholder")}
					class="form-input"
				/>
			</div>
		</div>

		<div class="md:col-span-2">
			<label for={`${idPrefix}-project-type`} class="eyebrow mb-2 block">
				{t(locale, "contactForm.projectTypeLabel")}
			</label>
			<div class="form-shell">
				<Icon name="briefcase" class="form-icon h-5 w-5" />
				<select
					id={`${idPrefix}-project-type`}
					name="projectType"
					class="form-input"
					required
				>
					<option value=""
						>{t(locale, "contactForm.projectTypePlaceholder")}</option
					>
					{projectTypes.map((type) => <option value={type}>{type}</option>)}
				</select>
			</div>
		</div>

		<div class="md:col-span-2">
			<label for={`${idPrefix}-message`} class="eyebrow mb-2 block">
				{t(locale, "contactForm.messageLabel")}
			</label>
			<div class="form-shell form-shell-textarea">
				<Icon name="pencil" class="form-icon form-textarea-icon h-5 w-5" />
				<textarea
					id={`${idPrefix}-message`}
					name="message"
					required
					rows="6"
					placeholder={t(locale, "contactForm.messagePlaceholder")}
					class="form-input form-textarea leading-7"></textarea>
			</div>
		</div>

		<div class="md:col-span-2">
			<label for={`${idPrefix}-attachment`} class="eyebrow mb-2 block">
				{t(locale, "contactForm.attachmentLabel")}
			</label>
			<div class="form-shell">
				<Icon name="paperclip" class="form-icon h-5 w-5" />
				<input
					id={`${idPrefix}-attachment`}
					type="file"
					name="attachment"
					accept="application/pdf,.pdf"
					class="form-input form-file cursor-pointer"
				/>
			</div>
			<p class="mt-2 text-xs text-[var(--text-muted)]">
				{t(locale, "contactForm.attachmentHint")}
			</p>
		</div>
	</div>

	<button type="submit" class="button-primary form-button mt-6 w-full">
		{t(locale, "contactForm.submit")}
		<Icon name="arrow-right" class="h-4 w-4" />
	</button>
</form>

<script>
	const allowedCategories = new Set([
		"service",
		"landing",
		"article",
		"project",
	]);
	const params = new URLSearchParams(window.location.search);
	const category = params.get("sourceCategory");
	const path = params.get("sourcePath");
	if (category && path && allowedCategories.has(category)) {
		document
			.querySelectorAll<HTMLInputElement>("[data-source-category]")
			.forEach((input) => (input.value = category));
		document
			.querySelectorAll<HTMLInputElement>("[data-source-path]")
			.forEach((input) => (input.value = path));
	}
</script>
