---
import { Icon } from "astro-icon/components";
import { t, type Locale } from "@/i18n";

const { locale } = Astro.props as { locale: Locale };
---

<form
	action="/api/contact"
	method="post"
	enctype="multipart/form-data"
	class="glass-panel surface-ring rounded-[2rem] p-5 md:p-6"
>
	<input type="hidden" name="locale" value={locale} />

	<div class="grid gap-4 md:grid-cols-2">
		<div class="md:col-span-1">
			<label
				for="contact-name"
				class="mb-2 block text-[11px] font-semibold tracking-[0.22em] text-slate-500 uppercase dark:text-slate-400"
			>
				{t(locale, "contactForm.nameLabel")}
			</label>
			<div class="form-shell">
				<Icon name="user" class="form-icon h-5 w-5" />
				<input
					id="contact-name"
					name="name"
					autocomplete="name"
					required
					placeholder={t(locale, "contactForm.namePlaceholder")}
					class="form-input"
				/>
			</div>
		</div>

		<div class="md:col-span-1">
			<label
				for="contact-email"
				class="mb-2 block text-[11px] font-semibold tracking-[0.22em] text-slate-500 uppercase dark:text-slate-400"
			>
				{t(locale, "contactForm.emailLabel")}
			</label>
			<div class="form-shell">
				<Icon name="mail" class="form-icon h-5 w-5" />
				<input
					id="contact-email"
					type="email"
					name="email"
					autocomplete="email"
					required
					placeholder={t(locale, "contactForm.emailPlaceholder")}
					class="form-input"
				/>
			</div>
		</div>

		<div class="md:col-span-2">
			<label
				for="contact-message"
				class="mb-2 block text-[11px] font-semibold tracking-[0.22em] text-slate-500 uppercase dark:text-slate-400"
			>
				{t(locale, "contactForm.messageLabel")}
			</label>
			<div class="form-shell items-start">
				<Icon name="pencil" class="form-icon mt-1 h-5 w-5" />
				<textarea
					id="contact-message"
					name="message"
					required
					rows="6"
					placeholder={t(locale, "contactForm.messagePlaceholder")}
					class="form-input form-textarea resize-none leading-7"></textarea>
			</div>
		</div>

		<div class="md:col-span-2">
			<label
				for="contact-attachment"
				class="mb-2 block text-[11px] font-semibold tracking-[0.22em] text-slate-500 uppercase dark:text-slate-400"
			>
				{t(locale, "contactForm.attachmentLabel")}
			</label>
			<div class="form-shell">
				<Icon name="paperclip" class="form-icon h-5 w-5" />
				<input
					id="contact-attachment"
					type="file"
					name="attachment"
					accept="application/pdf,.pdf"
					class="form-input form-file cursor-pointer"
				/>
			</div>
			<p class="mt-2 text-xs text-slate-500 dark:text-slate-400">
				{t(locale, "contactForm.attachmentHint")}
			</p>
		</div>
	</div>

	<button
		type="submit"
		class="form-button mt-6 inline-flex min-h-12 w-full items-center justify-center gap-2 rounded-2xl bg-slate-950 px-6 py-3 text-sm font-semibold text-white hover:bg-slate-800 dark:bg-slate-100 dark:text-slate-950 dark:hover:bg-white"
	>
		{t(locale, "contactForm.submit")}
		<Icon name="arrow-right" class="h-4 w-4" />
	</button>
</form>
