---
import { Icon } from "astro-icon/components";

interface Props {
	technologies: string[];
	label: string;
}

const { technologies, label } = Astro.props as Props;

const brandIcons: Array<[RegExp, string]> = [
	[/spring boot/i, "springboot"],
	[/docker/i, "docker"],
	[/kubernetes/i, "kubernetes"],
	[/postgresql/i, "postgresql"],
	[/rabbitmq/i, "rabbitmq"],
	[/kafka/i, "apachekafka"],
	[/liquibase/i, "liquibase"],
];

const getTechnologyIcon = (technology: string) => {
	const brandIcon = brandIcons.find(([pattern]) => pattern.test(technology));
	if (brandIcon) return brandIcon[1];

	const normalizedTechnology = technology.toLowerCase();

	if (
		/(websocket|restclient|rest client|http|api|payment|pagos)/.test(
			normalizedTechnology,
		)
	) {
		return "globe";
	}

	if (
		/(grpc|redis|pub\/sub|messaging|distributed|microservices|microservicios)/.test(
			normalizedTechnology,
		)
	) {
		return "git-branch";
	}

	if (
		/(spring cloud|cloud|helm|ci\/cd|jenkins|devops|grafana|kibana)/.test(
			normalizedTechnology,
		)
	) {
		return "cloud";
	}

	if (
		/(sqlite|mysql|database|elasticsearch|mongodb|storage)/.test(
			normalizedTechnology,
		)
	) {
		return "layers";
	}

	return "code";
};
---

<div class="flex items-center justify-between gap-3">
	<p class="eyebrow text-[var(--action)]">{label}</p>
	<span class="text-xs font-black text-[var(--text-muted)]" aria-hidden="true">
		{String(technologies.length).padStart(2, "0")}
	</span>
</div>

<div data-project-technology-list class="mt-4 grid grid-cols-2 gap-2">
	{
		technologies.map((technology) => (
			<span class="flex min-w-0 items-center gap-2 rounded-xl border border-[var(--surface-border)] bg-[color-mix(in_srgb,var(--surface-strong)_72%,transparent)] px-2.5 py-2 text-[0.72rem] leading-tight font-bold text-[var(--text-muted)]">
				<Icon
					name={getTechnologyIcon(technology)}
					class="h-3.5 w-3.5 shrink-0 text-[var(--action)]"
					aria-hidden="true"
				/>
				<span class="min-w-0 break-words">{technology}</span>
			</span>
		))
	}
</div>
