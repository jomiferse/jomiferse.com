---
import { Icon } from "astro-icon/components";

interface Props {
	eyebrow: string;
	title: string;
	description?: string;
	pauseLabel: string;
	headingId: string;
}

const { eyebrow, title, description, pauseLabel, headingId } =
	Astro.props as Props;
const technologies = [
	{ label: "Java", icon: "java" },
	{ label: "Spring Boot", icon: "springboot" },
	{ label: "Docker", icon: "docker" },
	{ label: "Kubernetes", icon: "kubernetes" },
	{ label: "React", icon: "react" },
	{ label: "Astro", icon: "astro" },
	{ label: "PostgreSQL", icon: "postgresql" },
	{ label: "Redis", icon: "redis" },
	{ label: "Apache Kafka", icon: "apachekafka" },
	{ label: "WordPress", icon: "wordpress" },
] as const;
---

<section
	data-technology-marquee
	class="technology-marquee section-reveal"
	aria-labelledby={headingId}
>
	<p class="eyebrow">{eyebrow}</p>
	<h2 id={headingId}>{title}</h2>
	{
		description ? (
			<p class="technology-marquee__description">{description}</p>
		) : null
	}
	<div
		class="technology-marquee__viewport"
		tabindex="0"
		role="region"
		aria-label={pauseLabel}
	>
		<div class="technology-marquee__track">
			<ul class="technology-marquee__list">
				{
					technologies.map((technology) => (
						<li>
							<Icon name={technology.icon} aria-hidden="true" />
							<span>{technology.label}</span>
						</li>
					))
				}
			</ul>
			<ul class="technology-marquee__list" aria-hidden="true">
				{
					technologies.map((technology) => (
						<li>
							<Icon name={technology.icon} aria-hidden="true" />
							<span>{technology.label}</span>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</section>

<style>
	.technology-marquee {
		padding-block: clamp(3.25rem, 5vw, 4.5rem);
	}

	.technology-marquee .eyebrow {
		color: var(--action);
	}

	.technology-marquee h2 {
		max-width: min(52rem, 100%);
		margin-top: 0.9rem;
		color: var(--home-navy);
		font-size: clamp(2.2rem, 4vw, 3.8rem);
		font-weight: 950;
		letter-spacing: -0.055em;
		line-height: 0.98;
		text-wrap: balance;
	}

	.technology-marquee__description {
		max-width: 42rem;
		margin-top: 1.1rem;
		color: var(--text-muted);
		line-height: 1.7;
	}

	.technology-marquee__viewport {
		margin-top: 2.5rem;
		overflow: hidden;
		-webkit-mask-image: linear-gradient(
			to right,
			transparent,
			black 7%,
			black 93%,
			transparent
		);
		mask-image: linear-gradient(
			to right,
			transparent,
			black 7%,
			black 93%,
			transparent
		);
	}

	.technology-marquee__track {
		display: flex;
		width: max-content;
		animation: technology-marquee 34s linear infinite;
	}

	.technology-marquee__list {
		display: flex;
		gap: 0.85rem;
		padding-right: 0.85rem;
	}

	.technology-marquee__list li {
		display: inline-flex;
		min-width: 10rem;
		min-height: 5rem;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding: 1rem 1.2rem;
		border: 1px solid var(--surface-border);
		border-radius: 1rem;
		background: color-mix(in srgb, var(--surface) 84%, transparent);
		color: var(--text);
		font-size: 0.9rem;
		font-weight: 850;
	}

	.technology-marquee__list :global(svg) {
		width: 1.6rem;
		height: 1.6rem;
		color: var(--text-muted);
		fill: currentColor;
	}

	.technology-marquee__viewport:hover .technology-marquee__track,
	.technology-marquee__viewport:focus .technology-marquee__track {
		animation-play-state: paused;
	}

	@keyframes technology-marquee {
		to {
			transform: translateX(-50%);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.technology-marquee__viewport {
			overflow: visible;
			-webkit-mask-image: none;
			mask-image: none;
		}

		.technology-marquee__track {
			width: 100%;
			animation: none;
		}

		.technology-marquee__list {
			width: 100%;
			flex-wrap: wrap;
			justify-content: center;
			padding: 0;
		}

		.technology-marquee__list[aria-hidden="true"] {
			display: none;
		}
	}
</style>
