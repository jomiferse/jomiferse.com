---
import { Icon } from "astro-icon/components";
import ContactForm from "@/components/forms/ContactForm.astro";
import DialogShell from "@/components/common/DialogShell.astro";
import { getTranslations, type Locale } from "@/i18n";
import { getCv } from "@cv";

interface Props {
	locale: Locale;
	sourcePath: string;
}

const { locale, sourcePath } = Astro.props as Props;
const translations = getTranslations(locale);
const copy = translations.popups.contact;
const cv = getCv(locale);
const whatsappHref = `https://wa.me/34609221290?text=${encodeURIComponent(
	translations.contact.page.whatsappMessage,
)}`;
---

<DialogShell
	id="global-contact-dialog"
	labelledBy="global-contact-title"
	describedBy="global-contact-description"
	size="form"
	className="global-contact-dialog"
>
	<div slot="header" class="dialog-shell__header-layout">
		<div>
			<p class="dialog-shell__eyebrow">{copy.eyebrow}</p>
			<h2 id="global-contact-title" class="dialog-shell__title">
				{copy.title}
			</h2>
			<p id="global-contact-description" class="dialog-shell__description">
				{copy.description}
			</p>
		</div>
		<form method="dialog">
			<button class="dialog-shell__close" aria-label={copy.close}>
				<Icon name="x" class="h-5 w-5" aria-hidden="true" />
			</button>
		</form>
	</div>

	<div
		data-global-contact-dialog
		data-submitting-label={copy.submitting}
		data-submit-label={copy.submit}
		data-validation-message={copy.validationError}
		data-delivery-message={copy.deliveryError}
	>
		<div
			hidden
			data-contact-status="submitting"
			class="global-contact-status global-contact-status--progress"
			role="status"
			aria-live="polite"
		>
			<span class="global-contact-status__signal" aria-hidden="true"></span>
			<p>{copy.submitting}</p>
		</div>
		<div
			hidden
			data-contact-status="success"
			class="global-contact-status global-contact-status--success"
			role="status"
			aria-live="polite"
		>
			<Icon name="circle-check-big" class="h-6 w-6" aria-hidden="true" />
			<div>
				<strong>{copy.successTitle}</strong>
				<p>{copy.successText}</p>
			</div>
		</div>
		<div
			hidden
			data-contact-status="validation"
			class="global-contact-status global-contact-status--error"
			role="alert"
		>
			<Icon name="info" class="h-5 w-5" aria-hidden="true" />
			<p>{copy.validationError}</p>
		</div>
		<div
			hidden
			data-contact-status="delivery"
			class="global-contact-status global-contact-status--error"
			role="alert"
		>
			<Icon name="info" class="h-5 w-5" aria-hidden="true" />
			<p>
				{copy.deliveryError}
				<a href={`mailto:${cv.email}`}>{cv.email}</a>
			</p>
		</div>

		<div data-contact-form-container>
			<ContactForm
				locale={locale}
				sourceCategory="direct"
				sourcePath={sourcePath}
				idPrefix="global-contact"
				variant="modal"
				submitLabel={copy.submit}
			/>
		</div>
	</div>

	<a
		slot="footer"
		href={whatsappHref}
		target="_blank"
		rel="noopener noreferrer nofollow"
		class="button-secondary global-contact-whatsapp"
	>
		<Icon name="message-square" class="h-4 w-4" aria-hidden="true" />
		{copy.whatsapp}
	</a>
</DialogShell>

<style>
	.global-contact-status {
		display: flex;
		gap: 0.75rem;
		align-items: flex-start;
		margin-bottom: 1rem;
		padding: 0.9rem 1rem;
		border: 1px solid var(--surface-border);
		border-radius: 0.9rem;
		background: var(--surface-strong);
		font-size: 0.9rem;
		line-height: 1.55;
	}

	.global-contact-status[hidden] {
		display: none;
	}

	.global-contact-status strong {
		color: var(--home-navy);
		font-weight: 900;
	}

	.global-contact-status p {
		color: var(--text-muted);
	}

	.global-contact-status a {
		display: inline-block;
		margin-left: 0.35rem;
		color: var(--action);
		font-weight: 850;
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}

	.global-contact-status--success {
		border-color: color-mix(in srgb, var(--action) 28%, var(--surface-border));
		background: color-mix(in srgb, var(--action) 7%, var(--surface));
		color: var(--action);
	}

	.global-contact-status--error {
		color: var(--action);
	}

	.global-contact-status--progress {
		align-items: center;
		color: var(--action);
		font-weight: 850;
	}

	.global-contact-status__signal {
		width: 0.7rem;
		height: 0.7rem;
		flex: 0 0 auto;
		border: 2px solid color-mix(in srgb, var(--action) 30%, transparent);
		border-top-color: var(--action);
		border-radius: 999px;
		animation: contact-status-spin 700ms linear infinite;
	}

	.global-contact-whatsapp {
		width: 100%;
	}

	@keyframes contact-status-spin {
		to {
			transform: rotate(360deg);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.global-contact-status__signal {
			animation: none;
		}
	}
</style>

<script>
	import { parseContactSubmissionResult } from "@/lib/contact-submission";

	const contactDialog = document.getElementById("global-contact-dialog");
	const contactRoot = contactDialog?.querySelector<HTMLElement>(
		"[data-global-contact-dialog]",
	);
	const form = contactRoot?.querySelector<HTMLFormElement>(
		'[data-contact-form-variant="modal"]',
	);
	let lastContactTrigger: HTMLElement | null = null;

	const contactStatuses = contactRoot
		? Array.from(
				contactRoot.querySelectorAll<HTMLElement>("[data-contact-status]"),
			)
		: [];

	const showContactStatus = (
		status: "submitting" | "success" | "validation" | "delivery" | null,
	) => {
		contactStatuses.forEach((panel) => {
			panel.hidden = panel.dataset.contactStatus !== status;
		});
	};

	const resolveSourceCategory = (pathname: string) => {
		if (/\/(?:en|es)\/services(?:\/|$)/.test(pathname)) return "service";
		if (/\/(?:en|es)\/blog(?:\/|$)/.test(pathname)) return "article";
		if (/\/(?:en|es)\/projects(?:\/|$)/.test(pathname)) return "project";
		return "direct";
	};

	const setFormValue = (selector: string, value: string) => {
		const input = form?.querySelector<HTMLInputElement>(selector);
		if (input) input.value = value;
	};

	const updateSelection = (service: string, scope: string) => {
		if (!form) return;
		const serviceOption = Array.from(
			form.querySelectorAll<HTMLElement>("[data-service-option]"),
		).find((option) => option.dataset.serviceValue === service);
		const scopeOption = Array.from(
			form.querySelectorAll<HTMLElement>("[data-scope-option]"),
		).find((option) => option.dataset.scopeValue === scope);
		const serviceInput = form.querySelector<HTMLInputElement>(
			"[data-selected-service]",
		);
		const scopeInput = form.querySelector<HTMLInputElement>(
			"[data-selected-scope]",
		);
		const summary = form.querySelector<HTMLElement>(
			"[data-service-selection-summary]",
		);
		const serviceLabel = form.querySelector<HTMLElement>(
			"[data-selected-service-label]",
		);
		const scopeRow = form.querySelector<HTMLElement>(
			"[data-selected-scope-row]",
		);
		const scopeLabel = form.querySelector<HTMLElement>(
			"[data-selected-scope-label]",
		);

		if (!serviceInput || !scopeInput || !summary || !serviceLabel) return;
		serviceInput.value = serviceOption?.dataset.serviceValue ?? "";
		scopeInput.value = serviceOption && scopeOption ? scope : "";
		serviceLabel.textContent = serviceOption?.dataset.serviceLabel ?? "";
		summary.hidden = !serviceOption;
		if (scopeRow) scopeRow.hidden = !serviceOption || !scopeOption;
		if (scopeLabel)
			scopeLabel.textContent = scopeOption?.dataset.scopeLabel ?? "";
	};

	const getSelectionFromTrigger = (trigger: HTMLElement) => {
		const href = trigger instanceof HTMLAnchorElement ? trigger.href : "";
		const params = href
			? new URL(href, window.location.href).searchParams
			: new URLSearchParams();
		return {
			service: trigger.dataset.serviceSelection ?? params.get("service") ?? "",
			scope: trigger.dataset.scopeSelection ?? params.get("scope") ?? "",
		};
	};

	const openContactDialog = (trigger: HTMLElement) => {
		if (!(contactDialog instanceof HTMLDialogElement) || !form) return false;
		const openDialog =
			document.querySelector<HTMLDialogElement>("dialog[open]");
		if (openDialog && openDialog !== contactDialog) {
			if (
				!openDialog.matches(
					"[data-exit-intent-dialog], [data-global-exit-dialog]",
				)
			) {
				return false;
			}
			openDialog.close();
		}

		lastContactTrigger = trigger;
		const selection = getSelectionFromTrigger(trigger);
		updateSelection(selection.service, selection.scope);
		setFormValue(
			"[data-source-category]",
			trigger.dataset.sourceCategory ??
				resolveSourceCategory(window.location.pathname),
		);
		setFormValue(
			"[data-source-path]",
			trigger.dataset.sourcePath ?? window.location.pathname,
		);
		showContactStatus(null);
		contactRoot
			?.querySelector<HTMLElement>("[data-contact-form-container]")
			?.removeAttribute("hidden");
		contactDialog.showModal();
		requestAnimationFrame(() => {
			form.querySelector<HTMLInputElement>('input[name="name"]')?.focus();
		});
		return true;
	};

	document.addEventListener("click", (event) => {
		const trigger =
			event.target instanceof Element
				? event.target.closest<HTMLElement>("[data-contact-dialog-open]")
				: null;
		if (!trigger) return;
		if (openContactDialog(trigger)) event.preventDefault();
	});

	document.addEventListener("open-global-contact", (event) => {
		const trigger =
			event instanceof CustomEvent &&
			event.detail?.trigger instanceof HTMLElement
				? event.detail.trigger
				: document.body;
		openContactDialog(trigger);
	});

	contactDialog?.addEventListener("click", (event) => {
		if (
			event.target === contactDialog &&
			contactDialog instanceof HTMLDialogElement
		) {
			contactDialog.close();
		}
	});

	contactDialog?.addEventListener("close", () => {
		showContactStatus(null);
		lastContactTrigger?.focus();
		lastContactTrigger = null;
	});

	form?.addEventListener(
		"invalid",
		() => {
			showContactStatus("validation");
		},
		true,
	);

	form?.addEventListener("submit", async (event) => {
		if (!form.reportValidity()) {
			event.preventDefault();
			showContactStatus("validation");
			return;
		}

		event.preventDefault();
		const submit = form.querySelector<HTMLButtonElement>(
			"[data-contact-submit]",
		);
		const submitLabel = form.querySelector<HTMLElement>(
			"[data-contact-submit-label]",
		);
		const idleLabel =
			contactRoot?.dataset.submitLabel ?? submitLabel?.textContent ?? "";
		if (submit) submit.disabled = true;
		if (submitLabel) {
			submitLabel.textContent =
				contactRoot?.dataset.submittingLabel ?? idleLabel;
		}
		showContactStatus("submitting");

		try {
			const response = await fetch(form.action, {
				method: "POST",
				body: new FormData(form),
			});
			const result = parseContactSubmissionResult(response.url);
			showContactStatus(result);
			if (result === "success") {
				form.reset();
				contactRoot
					?.querySelector<HTMLElement>("[data-contact-form-container]")
					?.setAttribute("hidden", "");
			} else if (result === "validation") {
				form.querySelector<HTMLElement>(":invalid")?.focus();
			}
		} catch {
			showContactStatus("delivery");
		} finally {
			if (submit) submit.disabled = false;
			if (submitLabel) submitLabel.textContent = idleLabel;
		}
	});
</script>
