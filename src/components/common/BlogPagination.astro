---
import { getBlogPagePath } from "@/lib/blog-pagination";
import type { Locale } from "@/i18n";

interface Props {
	locale: Locale;
	currentPage: number;
	totalPages: number;
	labels: {
		ariaLabel: string;
		previous: string;
		next: string;
		page: string;
		pageLabel: string;
	};
}

const { locale, currentPage, totalPages, labels } = Astro.props as Props;
const pages = Array.from({ length: totalPages }, (_, index) => index + 1);
const previousPage = currentPage - 1;
const nextPage = currentPage + 1;
const pageLabel = labels.pageLabel
	.replace("{current}", String(currentPage))
	.replace("{total}", String(totalPages));
---

{
	totalPages > 1 ? (
		<nav
			class="mt-8 flex flex-col items-center justify-between gap-4 border-t border-[var(--surface-border)] pt-6 sm:flex-row"
			aria-label={labels.ariaLabel}
		>
			{currentPage > 1 ? (
				<a
					href={getBlogPagePath(locale, previousPage)}
					class="button-secondary w-full sm:w-auto"
				>
					{labels.previous}
				</a>
			) : (
				<span
					class="button-secondary pointer-events-none w-full opacity-45 sm:w-auto"
					aria-disabled="true"
				>
					{labels.previous}
				</span>
			)}

			<p class="muted-copy text-sm font-bold sm:hidden">{pageLabel}</p>

			<ol class="hidden items-center gap-2 sm:flex">
				{pages.map((page) => (
					<li>
						{page === currentPage ? (
							<span
								class="flex size-11 items-center justify-center rounded-full border border-[var(--accent-line)] bg-[var(--surface)] text-sm font-black text-[var(--accent-strong)] dark:text-[var(--accent)]"
								aria-current="page"
							>
								{page}
							</span>
						) : (
							<a
								href={getBlogPagePath(locale, page)}
								class="flex size-11 items-center justify-center rounded-full border border-[var(--surface-border)] bg-[var(--surface)] text-sm font-bold text-[var(--text-muted)] transition hover:-translate-y-0.5 hover:border-[var(--accent-line)] hover:text-[var(--accent-strong)] dark:hover:text-[var(--accent)]"
								aria-label={`${labels.page} ${page}`}
							>
								{page}
							</a>
						)}
					</li>
				))}
			</ol>

			{currentPage < totalPages ? (
				<a
					href={getBlogPagePath(locale, nextPage)}
					class="button-secondary w-full sm:w-auto"
				>
					{labels.next}
				</a>
			) : (
				<span
					class="button-secondary pointer-events-none w-full opacity-45 sm:w-auto"
					aria-disabled="true"
				>
					{labels.next}
				</span>
			)}
		</nav>
	) : null
}
