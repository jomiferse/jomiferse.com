---
import { Icon } from "astro-icon/components";
import { t, type Locale } from "@/i18n";
import { getCv } from "@cv";

interface Props {
	locale?: Locale;
}

const { locale = "en" } = Astro.props as Props;
const cv = getCv(locale);
---

<footer class="px-3 pb-3 md:px-6 md:pb-6">
	<div class="footer-bar mx-auto max-w-6xl px-5 py-6 md:px-6 md:py-6">
		<div
			class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between"
		>
			<div class="max-w-2xl">
				<p
					class="text-xs font-semibold tracking-[0.22em] text-slate-500 uppercase dark:text-slate-400"
				>
					{t(locale, "footer.contact")}
				</p>
				<h2
					class="mt-3 text-2xl font-semibold text-slate-950 dark:text-slate-50"
				>
					{t(locale, "footer.title")}
				</h2>
				<p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">
					{t(locale, "footer.description")}
				</p>
				<p class="mt-4 text-sm text-slate-500 dark:text-slate-400">
					{t(locale, "footer.location")}
					{cv.location}
				</p>
			</div>

			<div class="flex flex-col gap-4 md:items-end">
				<a
					href={`mailto:${cv.email}`}
					class="text-base font-semibold text-slate-950 hover:text-[var(--accent-strong)] dark:text-slate-50 dark:hover:text-[var(--accent-strong)]"
				>
					{cv.email}
				</a>

				<div class="flex items-center gap-1.5">
					<a
						href={cv.links.github}
						target="_blank"
						rel="noopener noreferrer"
						aria-label="GitHub"
						class="header-utility inline-flex min-h-10 min-w-10 items-center justify-center rounded-full text-slate-600 dark:text-slate-300"
					>
						<Icon name="github" class="h-5 w-5" />
					</a>

					<a
						href={cv.links.linkedin}
						target="_blank"
						rel="noopener noreferrer"
						aria-label="LinkedIn"
						class="header-utility inline-flex min-h-10 min-w-10 items-center justify-center rounded-full text-slate-600 dark:text-slate-300"
					>
						<Icon name="linkedin" class="h-5 w-5" />
					</a>
				</div>
			</div>
		</div>
	</div>
</footer>
