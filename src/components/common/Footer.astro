---
import { Icon } from "astro-icon/components";
import { t, type Locale } from "@/i18n";
import { getCv } from "@cv";

interface Props {
	locale?: Locale;
}

const { locale = "es" } = Astro.props as Props;
const cv = getCv(locale);
const year = new Date().getFullYear();
const links = [
	{ href: `/${locale}`, label: t(locale, "nav.home") },
	{ href: `/${locale}/services`, label: t(locale, "nav.services") },
	{ href: `/${locale}/blog`, label: t(locale, "nav.blog") },
	{ href: `/${locale}/privacy`, label: t(locale, "footer.privacy") },
	{ href: `/${locale}/contact`, label: t(locale, "nav.contact") },
];
---

<footer class="footer-bar mt-auto">
	<div class="site-shell px-4 py-8 md:px-6">
		<div
			class="flex flex-col gap-8 md:flex-row md:items-center md:justify-between"
		>
			<p class="text-sm text-[var(--text-muted)]">
				© {year}
				{cv.name}
			</p>

			<nav
				aria-label="Footer"
				class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm font-semibold text-[var(--text-muted)]"
			>
				{
					links.map((link) => (
						<a href={link.href} class="hover:text-[var(--text)]">
							{link.label}
						</a>
					))
				}
			</nav>

			<div class="flex items-center gap-2">
				<a
					href={cv.links.github}
					target="_blank"
					rel="noopener noreferrer nofollow"
					aria-label="GitHub"
					class="header-utility inline-flex min-h-10 min-w-10 items-center justify-center rounded-full"
				>
					<Icon name="github" class="h-5 w-5" />
				</a>

				<a
					href={cv.links.linkedin}
					target="_blank"
					rel="noopener noreferrer nofollow"
					aria-label="LinkedIn"
					class="header-utility inline-flex min-h-10 min-w-10 items-center justify-center rounded-full"
				>
					<Icon name="linkedin" class="h-5 w-5" />
				</a>

				<a
					href="#main-content"
					class="ml-2 text-sm font-semibold text-[var(--text-muted)] hover:text-[var(--text)]"
				>
					{t(locale, "footer.backToTop")}
				</a>
			</div>
		</div>
	</div>
</footer>
