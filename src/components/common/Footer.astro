---
import { Icon } from "astro-icon/components";
import { type Locale } from "@/i18n";
import { getCv } from "@cv";

interface Props {
	locale?: Locale;
}

const { locale = "en" } = Astro.props as Props;
const cv = getCv(locale);
const year = new Date().getFullYear();
const tagline =
	locale === "es"
		? "Software práctico para productos y sistemas reales."
		: "Practical software for real products and systems.";
const backToTop = locale === "es" ? "Volver arriba ↑" : "Back to top ↑";
---

<footer class="footer-bar mt-auto">
	<div class="site-shell px-4 py-8 md:px-6">
		<div
			class="flex flex-col gap-8 md:flex-row md:items-center md:justify-between"
		>
			<p class="text-sm text-[var(--text-muted)]">
				© {year}
				{cv.name}. {tagline}
			</p>

			<div class="flex items-center gap-2">
				<a
					href={cv.links.github}
					target="_blank"
					rel="noopener noreferrer"
					aria-label="GitHub"
					class="header-utility inline-flex min-h-10 min-w-10 items-center justify-center rounded-full"
				>
					<Icon name="github" class="h-5 w-5" />
				</a>

				<a
					href={cv.links.linkedin}
					target="_blank"
					rel="noopener noreferrer"
					aria-label="LinkedIn"
					class="header-utility inline-flex min-h-10 min-w-10 items-center justify-center rounded-full"
				>
					<Icon name="linkedin" class="h-5 w-5" />
				</a>

				<a
					href="#main-content"
					class="ml-2 text-sm font-semibold text-[var(--text-muted)] hover:text-[var(--text)]"
				>
					{backToTop}
				</a>
			</div>
		</div>
	</div>
</footer>
