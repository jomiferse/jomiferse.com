---
import { brandGeometry } from "@/lib/brand-mark";

interface Props {
	class?: string;
}

const { class: className } = Astro.props as Props;
const { background, dot, fPath, jPath, viewBox } = brandGeometry;
---

<svg
	viewBox={viewBox}
	class:list={["brand-mark", className]}
	aria-hidden="true"
	focusable="false"
>
	<rect
		class="brand-mark__surface"
		x={background.x}
		y={background.y}
		width={background.width}
		height={background.height}
		rx={background.rx}></rect>
	<path class="brand-mark__letter" d={jPath}></path>
	<path class="brand-mark__letter" d={fPath}></path>
	<rect
		class="brand-mark__dot"
		x={dot.x}
		y={dot.y}
		width={dot.width}
		height={dot.height}
		rx={dot.rx}></rect>
</svg>

<style>
	.brand-mark {
		display: block;
	}

	.brand-mark__surface {
		fill: var(--surface);
		stroke: color-mix(in srgb, var(--action) 34%, var(--surface-border));
		stroke-width: 2;
	}

	.brand-mark__letter {
		fill: var(--home-navy);
	}

	.brand-mark__dot {
		fill: var(--action);
	}
</style>
