---
import { Icon } from "astro-icon/components";
import type { Locale } from "@/i18n";

interface Props {
	locale?: Locale;
}

const { locale = "en" } = Astro.props as Props;

const path = Astro.url.pathname;
const suffix = path.replace(/^\/(en|es)(?=\/|$)/, "") || "";
const otherLocale: Locale = locale === "en" ? "es" : "en";
const otherPath = `/${otherLocale}${suffix}`;
const qs = Astro.url.searchParams.toString();
const hash = Astro.url.hash ?? "";
const otherHref = `${otherPath}${qs ? `?${qs}` : ""}${hash}`;
---

<a
	href={otherHref}
	class="inline-flex min-h-11 items-center gap-2 rounded-2xl border border-slate-200/70 bg-white/70 px-3 py-2 text-xs font-semibold text-slate-700 shadow-sm hover:bg-white dark:border-slate-800/70 dark:bg-slate-950/35 dark:text-slate-200 dark:hover:bg-slate-900/70"
	aria-label={locale === "en" ? "Cambiar a Español" : "Switch to English"}
	data-lang={otherLocale}
>
	<Icon name="languages" class="h-4.5 w-4.5" />
	<span class="tracking-wide">{otherLocale.toUpperCase()}</span>
</a>
