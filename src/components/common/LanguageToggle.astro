---
import { Icon } from "astro-icon/components";
import { t, type Locale } from "@/i18n";

interface Props {
	locale?: Locale;
	href?: string;
}

const { locale = "es", href } = Astro.props as Props;

const path = Astro.url.pathname;
const suffix = path.replace(/^\/(en|es)(?=\/|$)/, "") || "";
const otherLocale: Locale = locale === "en" ? "es" : "en";
const otherPath = `/${otherLocale}${suffix}`;
const qs = Astro.url.searchParams.toString();
const hash = Astro.url.hash ?? "";
const fallbackHref = `${otherPath}${qs ? `?${qs}` : ""}${hash}`;
const otherHref = href ?? fallbackHref;
---

<a
	href={otherHref}
	class="header-utility inline-flex min-h-10 items-center gap-1.5 rounded-full px-3 py-2 text-[11px] font-semibold text-slate-600 dark:text-slate-300"
	aria-label={t(locale, `languageToggle.${otherLocale}`)}
	data-lang={otherLocale}
>
	<Icon name="languages" class="h-4.5 w-4.5" />
	<span class="tracking-wide">{otherLocale.toUpperCase()}</span>
</a>
