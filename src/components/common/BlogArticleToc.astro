---
interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings: Heading[];
	label: string;
	currentLabel?: string;
}

const { headings, label } = Astro.props as Props;
const sectionHeadings = headings.filter((heading) => heading.depth === 2);
---

{
	sectionHeadings.length > 0 ? (
		<>
			<nav
				aria-label={label}
				class="dark-card hidden p-5 lg:sticky lg:top-28 lg:block"
			>
				<p class="eyebrow text-[var(--action)]">{label}</p>
				<ol class="mt-4 space-y-3">
					{sectionHeadings.map((heading) => (
						<li>
							<a
								href={`#${heading.slug}`}
								class="block text-sm leading-6 font-semibold text-[var(--text-muted)] transition hover:text-[var(--accent-strong)] focus-visible:rounded focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--accent-strong)] dark:hover:text-[var(--accent)]"
							>
								{heading.text}
							</a>
						</li>
					))}
				</ol>
			</nav>

			<details class="dark-card p-5 lg:hidden">
				<summary class="cursor-pointer font-bold text-[var(--text)] marker:text-[var(--action)]">
					{label}
				</summary>
				<nav
					aria-label={label}
					class="mt-4 border-t border-[var(--surface-border)] pt-4"
				>
					<ol class="space-y-3">
						{sectionHeadings.map((heading) => (
							<li>
								<a
									href={`#${heading.slug}`}
									class="block text-sm leading-6 font-semibold text-[var(--text-muted)] hover:text-[var(--accent-strong)] focus-visible:rounded focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--accent-strong)] dark:hover:text-[var(--accent)]"
								>
									{heading.text}
								</a>
							</li>
						))}
					</ol>
				</nav>
			</details>
		</>
	) : null
}
