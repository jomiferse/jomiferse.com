---
import { Icon } from "astro-icon/components";

interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings: Heading[];
	label: string;
	currentLabel: string;
}

const { headings, label, currentLabel } = Astro.props as Props;
const sectionHeadings = headings.filter((heading) => heading.depth === 2);
---

{
	sectionHeadings.length > 0 ? (
		<div
			data-article-toc
			data-current-label={currentLabel}
			class="lg:sticky lg:top-24"
		>
			<nav
				aria-label={label}
				class="relative isolate hidden max-h-[calc(100svh-7.5rem)] min-h-0 flex-col overflow-hidden rounded-[1.15rem] border border-[color-mix(in_srgb,var(--action)_26%,var(--surface-border))] bg-[radial-gradient(circle_at_100%_0%,color-mix(in_srgb,var(--action)_12%,transparent),transparent_11rem),var(--surface)] p-5 shadow-[var(--shadow-card)] lg:flex"
			>
				<div class="flex shrink-0 items-center gap-3">
					<span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-[color-mix(in_srgb,var(--action)_28%,transparent)] bg-[color-mix(in_srgb,var(--action)_12%,var(--surface))] text-[var(--action)]">
						<Icon name="book-open" class="h-5 w-5" aria-hidden="true" />
					</span>
					<p class="eyebrow text-[var(--action)]">{label}</p>
				</div>
				<div
					class="mt-5 h-1 shrink-0 overflow-hidden rounded-full bg-[var(--surface-border)]"
					aria-hidden="true"
				>
					<span
						data-toc-progress
						class="block h-full origin-left scale-x-0 rounded-full bg-[var(--action)] transition-transform"
					/>
				</div>
				<ol
					class="toc-scroll mt-4 min-h-0 flex-1 [scrollbar-gutter:stable] space-y-1.5 overflow-y-auto overscroll-contain pr-2"
					data-toc-scroll
				>
					{sectionHeadings.map((heading) => (
						<li>
							<a
								data-toc-link
								href={`#${heading.slug}`}
								class="relative block rounded-xl border border-transparent px-3 py-2.5 text-sm leading-5 font-bold text-[var(--text-muted)] transition hover:bg-[color-mix(in_srgb,var(--action)_8%,transparent)] hover:text-[var(--action)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--action)] data-[active]:border-[color-mix(in_srgb,var(--action)_18%,transparent)] data-[active]:bg-[color-mix(in_srgb,var(--action)_10%,var(--surface))] data-[active]:text-[var(--home-navy)]"
							>
								<span
									class="toc-link-indicator absolute inset-y-2 left-0 hidden w-0.5 rounded-full bg-[var(--action)]"
									aria-hidden="true"
								/>
								{heading.text}
							</a>
						</li>
					))}
				</ol>
			</nav>

			<details class="rounded-[1.15rem] border border-[color-mix(in_srgb,var(--action)_26%,var(--surface-border))] bg-[var(--surface)] p-5 shadow-[var(--shadow-card)] lg:hidden">
				<summary class="cursor-pointer list-none text-[var(--text)] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--action)]">
					<span class="flex items-center gap-3">
						<span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-[color-mix(in_srgb,var(--action)_28%,transparent)] bg-[color-mix(in_srgb,var(--action)_12%,var(--surface))] text-[var(--action)]">
							<Icon name="book-open" class="h-5 w-5" aria-hidden="true" />
						</span>
						<span>
							<span class="eyebrow block text-[var(--action)]">{label}</span>
							<span class="mt-1 block text-xs font-semibold text-[var(--text-muted)]">
								<span class="sr-only">{currentLabel}: </span>
								<span data-toc-current>{sectionHeadings[0]?.text}</span>
							</span>
						</span>
					</span>
				</summary>
				<nav
					aria-label={label}
					class="mt-4 border-t border-[var(--surface-border)] pt-4"
				>
					<ol class="space-y-1.5">
						{sectionHeadings.map((heading) => (
							<li>
								<a
									data-toc-link
									href={`#${heading.slug}`}
									class="block rounded-xl border border-transparent px-3 py-2.5 text-sm leading-5 font-bold text-[var(--text-muted)] hover:bg-[color-mix(in_srgb,var(--action)_8%,transparent)] hover:text-[var(--action)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--action)] data-[active]:border-[color-mix(in_srgb,var(--action)_18%,transparent)] data-[active]:bg-[color-mix(in_srgb,var(--action)_10%,var(--surface))] data-[active]:text-[var(--home-navy)]"
								>
									{heading.text}
								</a>
							</li>
						))}
					</ol>
				</nav>
			</details>
		</div>
	) : null
}

<script>
	const setupArticleToc = () => {
		document
			.querySelectorAll<HTMLElement>("[data-article-toc]")
			.forEach((toc) => {
				if (toc.dataset.enhanced === "true") return;
				toc.dataset.enhanced = "true";

				const links = Array.from(
					toc.querySelectorAll<HTMLAnchorElement>("[data-toc-link]"),
				);
				const ids = [
					...new Set(
						links.map((link) => decodeURIComponent(link.hash.slice(1))),
					),
				];
				const headings = ids
					.map((id) => document.getElementById(id))
					.filter((heading): heading is HTMLElement => Boolean(heading));
				const current = toc.querySelector<HTMLElement>("[data-toc-current]");
				const progress = toc.querySelector<HTMLElement>("[data-toc-progress]");
				const list = toc.querySelector<HTMLElement>("[data-toc-scroll]");
				const disclosure = toc.querySelector<HTMLDetailsElement>("details");
				const prefersReducedMotion = window.matchMedia(
					"(prefers-reduced-motion: reduce)",
				).matches;
				let activeId = "";

				if (!headings.length) return;

				const setActive = (id: string) => {
					if (id === activeId) return;
					activeId = id;

					links.forEach((link) => {
						const isActive = decodeURIComponent(link.hash.slice(1)) === id;
						link.toggleAttribute("data-active", isActive);
						if (isActive) link.setAttribute("aria-current", "location");
						else link.removeAttribute("aria-current");
					});

					const index = headings.findIndex((heading) => heading.id === id);
					current?.replaceChildren(headings[index]?.textContent?.trim() ?? "");
					const ratio =
						headings.length === 1 ? 1 : index / (headings.length - 1);
					progress?.style.setProperty("transform", `scaleX(${ratio})`);

					const activeLink = links.find(
						(link) => decodeURIComponent(link.hash.slice(1)) === id,
					);
					if (activeLink && list && list.offsetParent !== null) {
						const listRect = list.getBoundingClientRect();
						const linkRect = activeLink.getBoundingClientRect();
						const isOutsideView =
							linkRect.top < listRect.top + 8 ||
							linkRect.bottom > listRect.bottom - 8;

						if (isOutsideView) {
							const linkTop = linkRect.top - listRect.top + list.scrollTop;
							list.scrollTo({
								top: Math.max(
									0,
									linkTop - list.clientHeight / 2 + linkRect.height / 2,
								),
								behavior: prefersReducedMotion ? "auto" : "smooth",
							});
						}
					}
				};

				const updateActive = () => {
					const threshold = 128;
					const passed = headings.filter(
						(heading) => heading.getBoundingClientRect().top <= threshold,
					);
					const atEnd =
						window.innerHeight + window.scrollY >=
						document.documentElement.scrollHeight - 2;
					const active = atEnd
						? headings.at(-1)
						: (passed.at(-1) ?? headings[0]);
					if (active) setActive(active.id);
				};

				const updateFromHash = () => {
					const id = decodeURIComponent(window.location.hash.replace(/^#/, ""));
					const matchingHeading = headings.find((heading) => heading.id === id);
					if (matchingHeading) setActive(matchingHeading.id);
					else updateActive();
				};

				const observer = new IntersectionObserver(updateActive, {
					rootMargin: "-112px 0px -65% 0px",
					threshold: [0, 1],
				});
				headings.forEach((heading) => observer.observe(heading));
				window.addEventListener("scroll", updateActive, { passive: true });
				document.addEventListener("scroll", updateActive, { passive: true });
				window.addEventListener("hashchange", updateFromHash);
				links.forEach((link) =>
					link.addEventListener("click", () => {
						disclosure?.removeAttribute("open");
						const id = decodeURIComponent(link.hash.replace(/^#/, ""));
						if (headings.some((heading) => heading.id === id)) setActive(id);
					}),
				);
				updateFromHash();
			});
	};

	document.addEventListener("astro:page-load", setupArticleToc);
	setupArticleToc();
</script>

<style>
	.toc-scroll {
		scrollbar-color: color-mix(in srgb, var(--action) 38%, transparent)
			transparent;
		scrollbar-width: thin;
	}

	.toc-scroll::-webkit-scrollbar {
		width: 0.35rem;
	}

	.toc-scroll::-webkit-scrollbar-thumb {
		border-radius: 999px;
		background: color-mix(in srgb, var(--action) 38%, transparent);
	}

	[data-toc-link][data-active] .toc-link-indicator {
		display: block;
	}
</style>
