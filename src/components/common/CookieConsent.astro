---
import { Icon } from "astro-icon/components";
import DialogShell from "@/components/common/DialogShell.astro";
import { t, type Locale } from "@/i18n";

interface Props {
	locale?: Locale;
}

const { locale = "es" } = Astro.props as Props;
const privacyHref = `/${locale}/privacy`;
---

<section
	id="cookie-consent"
	class="cookie-consent"
	aria-label={t(locale, "cookies.bannerLabel")}
	hidden
>
	<div
		class="cookie-consent__banner"
		role="region"
		aria-live="polite"
		data-cookie-banner
	>
		<div class="cookie-consent__copy">
			<span class="cookie-consent__signal" aria-hidden="true">
				<Icon name="info" class="h-4 w-4" />
			</span>
			<div>
				<p class="cookie-consent__label">
					{t(locale, "cookies.bannerLabel")}
				</p>
				<p class="cookie-consent__text">
					{t(locale, "cookies.bannerText")}
					<a href={privacyHref}>{t(locale, "cookies.bannerPolicyLink")}</a>
					{t(locale, "cookies.bannerTextAfterLink")}
				</p>
			</div>
		</div>
		<div class="cookie-consent__actions">
			<button
				type="button"
				class="button-secondary"
				data-cookie-reject
				data-cookie-equal-action
			>
				{t(locale, "cookies.reject")}
			</button>
			<button type="button" class="button-secondary" data-cookie-configure>
				{t(locale, "cookies.configure")}
			</button>
			<button
				type="button"
				class="button-action"
				data-cookie-accept
				data-cookie-equal-action
			>
				{t(locale, "cookies.accept")}
			</button>
		</div>
	</div>

	<DialogShell
		id="cookie-settings-dialog"
		labelledBy="cookie-settings-title"
		describedBy="cookie-settings-description"
		size="standard"
		className="cookie-settings-dialog"
	>
		<div slot="header" class="dialog-shell__header-layout">
			<div>
				<p class="dialog-shell__eyebrow">
					{t(locale, "cookies.settingsEyebrow")}
				</p>
				<h2 id="cookie-settings-title" class="dialog-shell__title">
					{t(locale, "cookies.settingsTitle")}
				</h2>
				<p id="cookie-settings-description" class="dialog-shell__description">
					{t(locale, "cookies.settingsDescription")}
				</p>
			</div>
			<button
				type="button"
				class="dialog-shell__close"
				aria-label={t(locale, "cookies.close")}
				data-cookie-close
				data-cookie-close-icon
			>
				<Icon name="x" class="h-5 w-5" aria-hidden="true" />
			</button>
		</div>

		<div class="cookie-consent__options">
			<div class="cookie-consent__option">
				<div>
					<h3>{t(locale, "cookies.necessaryTitle")}</h3>
					<p>{t(locale, "cookies.necessaryDescription")}</p>
				</div>
				<span class="cookie-consent__status">
					<Icon name="check" class="h-4 w-4" aria-hidden="true" />
					{t(locale, "cookies.alwaysActive")}
				</span>
			</div>

			<label class="cookie-consent__option cookie-consent__option--toggle">
				<span>
					<span class="cookie-consent__option-title">
						{t(locale, "cookies.analyticsTitle")}
					</span>
					<span class="cookie-consent__option-copy">
						{t(locale, "cookies.analyticsDescription")}
					</span>
				</span>
				<input
					type="checkbox"
					name="analytics"
					class="cookie-consent__toggle"
					data-cookie-analytics
				/>
			</label>
		</div>

		<p class="cookie-consent__privacy">
			<a href={privacyHref}>{t(locale, "cookies.privacyLink")}</a>
		</p>

		<div slot="footer" class="cookie-consent__footer">
			<button type="button" class="button-secondary" data-cookie-close>
				{t(locale, "cookies.close")}
			</button>
			<button type="button" class="button-action" data-cookie-save>
				{t(locale, "cookies.save")}
			</button>
		</div>
	</DialogShell>
</section>

<script>
	import {
		CONSENT_STORAGE_KEY,
		buildConsentModeState,
		getInitialAnalyticsPreference,
		getShouldLoadAnalytics,
		parseStoredCookieConsent,
		serializeCookieConsent,
		type CookieConsentPreferences,
	} from "@/lib/cookie-consent";

	const root = document.getElementById("cookie-consent");
	const dialog = document.getElementById(
		"cookie-settings-dialog",
	) as HTMLDialogElement | null;
	const banner = root?.querySelector<HTMLElement>("[data-cookie-banner]");
	const analyticsInput = root?.querySelector<HTMLInputElement>(
		"[data-cookie-analytics]",
	);
	const measurementId = window.GA_MEASUREMENT_ID ?? "";
	let lastFocusedElement: HTMLElement | null = null;

	const getStoredPreferences = () =>
		parseStoredCookieConsent(localStorage.getItem(CONSENT_STORAGE_KEY));

	const updateConsentMode = (preferences: CookieConsentPreferences) => {
		window.gtag?.(
			"consent",
			"update",
			buildConsentModeState(preferences.analytics),
		);
	};

	const loadGoogleAnalytics = (
		preferences: CookieConsentPreferences | null,
	) => {
		if (
			!getShouldLoadAnalytics(preferences, measurementId) ||
			document.querySelector(`script[src*="googletagmanager.com/gtag/js"]`)
		) {
			return;
		}

		const script = document.createElement("script");
		script.async = true;
		script.src = `https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(
			measurementId,
		)}`;
		document.head.append(script);

		window.gtag?.("js", new Date());
		window.gtag?.("config", measurementId, { anonymize_ip: true });
	};

	const hideBanner = () => {
		if (!root || !banner) return;
		root.hidden = false;
		banner.hidden = true;
	};

	const showBanner = () => {
		if (!root || !banner) return;
		root.hidden = false;
		banner.hidden = false;
	};

	const syncDialogState = () => {
		if (!analyticsInput) return;
		analyticsInput.checked = getInitialAnalyticsPreference(
			getStoredPreferences(),
		);
	};

	const openSettings = () => {
		if (!dialog) return;
		const openDialog = document.querySelector("dialog[open]");
		if (openDialog && openDialog !== dialog) return;
		lastFocusedElement = document.activeElement as HTMLElement | null;
		syncDialogState();
		if (typeof dialog.showModal === "function") {
			dialog.showModal();
			return;
		}
		dialog.setAttribute("open", "");
	};

	const closeSettings = () => {
		if (!dialog) return;
		if (typeof dialog.close === "function") {
			dialog.close();
		} else {
			dialog.removeAttribute("open");
			lastFocusedElement?.focus();
		}
	};

	const savePreferences = (preferences: CookieConsentPreferences) => {
		localStorage.setItem(
			CONSENT_STORAGE_KEY,
			serializeCookieConsent(preferences),
		);
		updateConsentMode(preferences);
		loadGoogleAnalytics(preferences);
		hideBanner();
		closeSettings();
	};

	root?.querySelector("[data-cookie-accept]")?.addEventListener("click", () => {
		savePreferences({ analytics: true });
	});

	root?.querySelector("[data-cookie-reject]")?.addEventListener("click", () => {
		savePreferences({ analytics: false });
	});

	root
		?.querySelector("[data-cookie-configure]")
		?.addEventListener("click", openSettings);

	root?.querySelectorAll("[data-cookie-close]").forEach((button) => {
		button.addEventListener("click", closeSettings);
	});

	root?.querySelector("[data-cookie-save]")?.addEventListener("click", () => {
		savePreferences({ analytics: Boolean(analyticsInput?.checked) });
	});

	dialog?.addEventListener("click", (event) => {
		if (event.target === dialog) closeSettings();
	});

	dialog?.addEventListener("close", () => {
		lastFocusedElement?.focus();
		lastFocusedElement = null;
	});

	document.addEventListener("jomiferse:open-cookie-settings", openSettings);

	document
		.querySelectorAll("[data-cookie-settings-trigger]")
		.forEach((trigger) => {
			trigger.addEventListener("click", openSettings);
		});

	const storedPreferences = getStoredPreferences();
	if (storedPreferences) {
		updateConsentMode(storedPreferences);
		loadGoogleAnalytics(storedPreferences);
		hideBanner();
	} else {
		showBanner();
	}
</script>

<style>
	.cookie-consent {
		position: fixed;
		right: 0.75rem;
		bottom: 0.75rem;
		left: 0.75rem;
		z-index: 80;
		pointer-events: none;
	}

	.cookie-consent__banner {
		display: grid;
		gap: 1rem;
		max-width: 76rem;
		margin-inline: auto;
		padding: 1rem;
		border: 1px solid var(--surface-border);
		border-top: 3px solid var(--action);
		border-radius: 1rem;
		background: color-mix(in srgb, var(--surface) 96%, transparent);
		box-shadow: 0 18px 55px rgba(5, 12, 22, 0.2);
		pointer-events: auto;
		backdrop-filter: blur(18px);
	}

	.cookie-consent__banner[hidden] {
		display: none;
	}

	.cookie-consent__copy {
		display: flex;
		gap: 0.8rem;
		align-items: flex-start;
		min-width: 0;
	}

	.cookie-consent__signal {
		display: inline-grid;
		width: 2rem;
		height: 2rem;
		flex: 0 0 auto;
		place-items: center;
		border: 1px solid
			color-mix(in srgb, var(--action) 28%, var(--surface-border));
		border-radius: 0.65rem;
		background: color-mix(in srgb, var(--action) 7%, var(--surface));
		color: var(--action);
	}

	.cookie-consent__label {
		color: var(--home-navy);
		font-size: 0.72rem;
		font-weight: 900;
		letter-spacing: 0.15em;
		line-height: 1.4;
		text-transform: uppercase;
	}

	.cookie-consent__text {
		margin-top: 0.25rem;
		color: var(--text-muted);
		font-size: 0.86rem;
		line-height: 1.55;
	}

	.cookie-consent__text a,
	.cookie-consent__privacy a {
		color: var(--action);
		font-weight: 850;
		text-decoration: underline;
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.18em;
	}

	.cookie-consent__actions {
		display: grid;
		gap: 0.55rem;
	}

	.cookie-consent__actions button,
	.cookie-consent__footer button {
		min-height: 2.75rem;
		cursor: pointer;
	}

	.cookie-consent__options {
		display: grid;
		gap: 0.8rem;
	}

	.cookie-consent__option {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem;
		border: 1px solid var(--surface-border);
		border-radius: 0.9rem;
		background: var(--surface-strong);
	}

	.cookie-consent__option h3,
	.cookie-consent__option-title {
		display: block;
		color: var(--home-navy);
		font-size: 0.98rem;
		font-weight: 900;
	}

	.cookie-consent__option p,
	.cookie-consent__option-copy {
		display: block;
		margin-top: 0.35rem;
		color: var(--text-muted);
		font-size: 0.86rem;
		line-height: 1.55;
	}

	.cookie-consent__option--toggle {
		cursor: pointer;
	}

	.cookie-consent__option--toggle:has(input:focus-visible) {
		outline: 2px solid var(--action);
		outline-offset: 2px;
	}

	.cookie-consent__status {
		display: inline-flex;
		flex: none;
		gap: 0.35rem;
		align-items: center;
		color: var(--action);
		font-size: 0.75rem;
		font-weight: 850;
	}

	.cookie-consent__toggle {
		width: 1.35rem;
		height: 1.35rem;
		flex: none;
		accent-color: var(--action);
		cursor: pointer;
	}

	.cookie-consent__privacy {
		margin-top: 1rem;
		font-size: 0.84rem;
	}

	.cookie-consent__footer {
		display: grid;
		width: 100%;
		gap: 0.65rem;
	}

	:global(.cookie-settings-dialog) {
		pointer-events: auto;
	}

	@media (min-width: 40rem) {
		.cookie-consent__footer {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 58rem) {
		.cookie-consent {
			right: 1rem;
			bottom: 1rem;
			left: 1rem;
		}

		.cookie-consent__banner {
			grid-template-columns: minmax(0, 1fr) auto;
			gap: 1.5rem;
			align-items: center;
			padding: 1rem 1.15rem;
		}

		.cookie-consent__actions {
			grid-template-columns: repeat(3, minmax(7.2rem, auto));
		}
	}

	@media (max-width: 32rem) {
		.cookie-consent__option {
			align-items: flex-start;
			flex-direction: column;
		}

		.cookie-consent__toggle {
			align-self: flex-end;
		}
	}
</style>
