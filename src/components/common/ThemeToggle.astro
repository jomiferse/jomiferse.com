---
import { Icon } from "astro-icon/components";
import { t, type Locale } from "@/i18n";

interface Props {
	locale?: Locale;
}

const { locale = "es" } = Astro.props as Props;
---

<button
	type="button"
	class="theme-toggle header-utility inline-flex min-h-11 min-w-11 cursor-pointer items-center justify-center rounded-full p-2 text-slate-600 dark:text-slate-300"
	aria-label={t(locale, "theme.toggle")}
	data-label-dark={t(locale, "theme.switchToDark")}
	data-label-light={t(locale, "theme.switchToLight")}
>
	<span data-theme-icon="sun" class="hidden">
		<Icon name="sun" class="h-5 w-5" />
	</span>
	<span data-theme-icon="moon" class="hidden">
		<Icon name="moon" class="h-5 w-5" />
	</span>
</button>
