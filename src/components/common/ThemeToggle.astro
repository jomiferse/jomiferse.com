---
import { Icon } from "astro-icon/components";
import { t, type Locale } from "@/i18n";

interface Props {
	locale?: Locale;
}

const { locale = "en" } = Astro.props as Props;
---

<button
	type="button"
	class="theme-toggle inline-flex min-h-11 min-w-11 cursor-pointer items-center justify-center rounded-2xl border border-slate-200/70 bg-white/70 p-2 text-slate-700 shadow-sm hover:bg-white dark:border-slate-800/70 dark:bg-slate-950/35 dark:text-slate-200 dark:hover:bg-slate-900/70"
	aria-label={t(locale, "theme.toggle")}
	data-label-dark={t(locale, "theme.switchToDark")}
	data-label-light={t(locale, "theme.switchToLight")}
>
	<span data-theme-icon="sun" class="hidden">
		<Icon name="sun" class="h-5 w-5" />
	</span>
	<span data-theme-icon="moon" class="hidden">
		<Icon name="moon" class="h-5 w-5" />
	</span>
</button>
