---
import { Icon } from "astro-icon/components";
import { getTranslations, type Locale } from "@/i18n";

const {
	locale,
	serviceTitle,
	contactHref,
	whatsappHref,
	openContactModal = false,
} = Astro.props as {
	locale: Locale;
	serviceTitle?: string;
	contactHref: string;
	whatsappHref: string;
	openContactModal?: boolean;
};

const copy = getTranslations(locale).services.exitIntent;
const title = serviceTitle
	? copy.serviceTitle.replace("{service}", serviceTitle)
	: copy.title;
---

<dialog
	id="services-exit-intent"
	class="services-exit-dialog m-auto w-[min(640px,92vw)] rounded-[1.1rem] border border-[var(--accent-line)] bg-[var(--surface)] p-0 text-[var(--text)] shadow-[0_28px_90px_rgba(0,0,0,0.26)] backdrop:bg-slate-950/62 dark:backdrop:bg-black/76"
	aria-labelledby="services-exit-title"
	aria-describedby="services-exit-description"
	data-exit-intent-dialog
>
	<div class="relative overflow-hidden">
		<div class="services-exit-glow" aria-hidden="true"></div>
		<div class="services-exit-ruler" aria-hidden="true"></div>

		<section class="relative p-5 sm:p-7">
			<div class="flex items-start justify-between gap-4">
				<div>
					<div class="services-exit-badge">
						<span class="services-exit-pulse"></span>
						<span>{copy.signal}</span>
					</div>
					<p class="eyebrow mt-5">{copy.eyebrow}</p>
				</div>
				<form method="dialog">
					<button
						class="services-exit-close header-utility inline-flex min-h-11 min-w-11 items-center justify-center rounded-full"
						aria-label={copy.close}
					>
						<Icon name="x" class="h-5 w-5" />
					</button>
				</form>
			</div>

			<div class="mt-6 grid gap-6 lg:grid-cols-[1fr_0.74fr] lg:items-end">
				<div>
					<h2
						id="services-exit-title"
						class="max-w-lg text-4xl leading-tight font-black text-[var(--text)] sm:text-5xl"
					>
						{title}
					</h2>
					<p
						id="services-exit-description"
						class="muted-copy mt-5 max-w-xl text-base leading-7"
					>
						{copy.text}
					</p>
				</div>

				<div class="services-exit-note">
					<p class="text-5xl leading-none font-black text-[var(--text)]">15</p>
					<p class="mt-2 text-sm leading-6 font-bold text-[var(--text-muted)]">
						{copy.minutes}
					</p>
				</div>
			</div>

			<div class="mt-7 grid gap-3 sm:grid-cols-2">
				<div class="services-exit-chip">
					<Icon name="check" class="h-4 w-4" />
					<span>{copy.pointOne}</span>
				</div>
				<div class="services-exit-chip">
					<Icon name="check" class="h-4 w-4" />
					<span>{copy.pointTwo}</span>
				</div>
			</div>

			<div class="services-exit-actions mt-7 grid gap-3">
				<a
					href={contactHref}
					class="button-primary w-full justify-center"
					data-exit-contact-modal={openContactModal ? "true" : undefined}
					autofocus
				>
					<Icon name="arrow-right" class="h-4 w-4" />
					{copy.primary}
				</a>
				<div class="grid gap-3 sm:grid-cols-2">
					<a
						href={whatsappHref}
						target="_blank"
						rel="noopener noreferrer nofollow"
						class="button-secondary w-full justify-center"
					>
						<Icon name="message-square" class="h-4 w-4" />
						{copy.whatsapp}
					</a>
					<form method="dialog">
						<button
							class="services-exit-dismiss button-secondary w-full justify-center"
						>
							{copy.secondary}
						</button>
					</form>
				</div>
			</div>
		</section>
	</div>
</dialog>

<style>
	.services-exit-dialog::backdrop {
		backdrop-filter: blur(8px);
	}

	.services-exit-dialog[open] {
		animation: exit-dialog-in 220ms ease-out;
	}

	.services-exit-glow {
		position: absolute;
		inset: -28% -12% auto auto;
		width: 21rem;
		height: 21rem;
		border-radius: 999px;
		background: radial-gradient(
			circle,
			color-mix(in srgb, var(--accent) 22%, transparent),
			transparent 68%
		);
		pointer-events: none;
	}

	.services-exit-ruler {
		position: absolute;
		inset: 0 auto 0 0;
		width: 0.42rem;
		background: linear-gradient(
			180deg,
			var(--accent),
			color-mix(in srgb, var(--accent-strong) 64%, transparent)
		);
	}

	.services-exit-badge,
	.services-exit-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		border: 1px solid var(--accent-line);
		border-radius: var(--radius-pill);
		background: var(--accent-soft);
		color: var(--accent-strong);
		font-size: 0.73rem;
		font-weight: 900;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.services-exit-badge {
		padding: 0.45rem 0.72rem;
	}

	.services-exit-chip {
		justify-content: center;
		padding: 0.78rem 1rem;
		letter-spacing: 0;
		text-transform: none;
	}

	.dark .services-exit-badge,
	.dark .services-exit-chip {
		color: var(--accent);
	}

	.services-exit-note {
		border: 1px solid var(--surface-border);
		border-radius: 1rem;
		background:
			linear-gradient(
				135deg,
				color-mix(in srgb, var(--accent-soft) 76%, transparent),
				transparent 72%
			),
			color-mix(in srgb, var(--surface-strong) 82%, transparent);
		padding: 1.1rem;
	}

	.services-exit-actions {
		border-top: 1px solid var(--surface-border);
		padding-top: 1.4rem;
	}

	.services-exit-pulse {
		width: 0.62rem;
		height: 0.62rem;
		border-radius: 999px;
		background: var(--accent-strong);
		box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 45%, transparent);
		animation: exit-pulse 1.8s ease-out infinite;
	}

	.services-exit-close:hover,
	.services-exit-close:focus-visible {
		border-color: var(--accent-line);
		background: var(--accent-soft);
		color: var(--accent-strong);
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 16%, transparent);
	}

	.dark .services-exit-close:hover,
	.dark .services-exit-close:focus-visible {
		color: var(--accent);
	}

	.services-exit-dismiss:hover,
	.services-exit-dismiss:focus-visible {
		border-color: var(--accent-line);
		background: var(--accent-soft);
		color: var(--accent-strong);
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 14%, transparent);
	}

	.dark .services-exit-dismiss:hover,
	.dark .services-exit-dismiss:focus-visible {
		color: var(--accent);
	}

	@keyframes exit-dialog-in {
		from {
			opacity: 0;
			transform: translateY(12px) scale(0.98);
		}

		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	@keyframes exit-pulse {
		70% {
			box-shadow: 0 0 0 0.7rem transparent;
		}

		100% {
			box-shadow: 0 0 0 0 transparent;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.services-exit-dialog[open],
		.services-exit-pulse {
			animation: none;
		}
	}
</style>

<script>
	const exitDialog = document.querySelector("[data-exit-intent-dialog]");
	const exitStorageKey = "jomiferse-services-exit-intent-v1";
	let hasShownExitIntent = false;
	let hasScrolledEnough = false;

	const canShowExitIntent = () => {
		if (!(exitDialog instanceof HTMLDialogElement)) return false;
		if (hasShownExitIntent) return false;
		if (sessionStorage.getItem(exitStorageKey) === "shown") return false;
		if (document.querySelector("dialog[open]")) return false;

		return true;
	};

	const showExitIntent = () => {
		if (!canShowExitIntent()) return;
		if (!(exitDialog instanceof HTMLDialogElement)) return;

		hasShownExitIntent = true;
		sessionStorage.setItem(exitStorageKey, "shown");
		exitDialog.showModal();
	};

	document.addEventListener("mouseout", (event) => {
		if (event.clientY > 8 || event.relatedTarget) return;
		showExitIntent();
	});

	document.addEventListener(
		"scroll",
		() => {
			const scrollable =
				document.documentElement.scrollHeight - window.innerHeight;
			if (scrollable <= 0) return;

			hasScrolledEnough = window.scrollY / scrollable > 0.45;
		},
		{ passive: true },
	);

	window.setTimeout(() => {
		if (!window.matchMedia("(pointer: coarse)").matches) return;
		if (!hasScrolledEnough) return;

		showExitIntent();
	}, 18000);

	exitDialog?.addEventListener("click", (event) => {
		if (
			event.target === exitDialog &&
			exitDialog instanceof HTMLDialogElement
		) {
			exitDialog.close();
		}
	});

	document
		.querySelector("[data-exit-contact-modal]")
		?.addEventListener("click", (event) => {
			const contactDialog = document.getElementById("service-contact-dialog");

			if (!(contactDialog instanceof HTMLDialogElement)) return;
			if (!(exitDialog instanceof HTMLDialogElement)) return;

			event.preventDefault();
			exitDialog.close();
			window.setTimeout(() => contactDialog.showModal(), 80);
		});
</script>
