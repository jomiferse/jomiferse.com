---
import { Icon } from "astro-icon/components";
import type { Locale } from "@/i18n";
import type { ServiceArea, ServiceItem } from "@/lib/services";
import ServiceIconBadge from "@/components/services/ServiceIconBadge.astro";

interface Props {
	locale: Locale;
	areas: ServiceArea[];
	content: {
		eyebrow: string;
		title: string;
		intro: string;
		openLabel: string;
		servicesLabel: string;
	};
}

const { locale, areas, content } = Astro.props as Props;
const getHref = (service: ServiceItem) =>
	service.canonicalPath ?? `/${locale}/services/${service.slug}/`;
---

<section
	data-service-directory
	class="service-directory"
	aria-labelledby="service-directory-title"
>
	<header>
		<p class="eyebrow">{content.eyebrow}</p>
		<h2 id="service-directory-title">{content.title}</h2>
		<p>{content.intro}</p>
	</header>

	<div class="service-directory__groups">
		{
			areas.map((area, index) => (
				<details open={index === 0}>
					<summary>
						<ServiceIconBadge name={area.icon} size="sm" />
						<span>
							<strong>{area.title}</strong>
							<small>
								{String(area.services.length).padStart(2, "0")}{" "}
								{content.servicesLabel}
							</small>
						</span>
						<span class="service-directory__action">
							<span class="sr-only">{content.openLabel}</span>
							<Icon name="plus" class="h-5 w-5" aria-hidden="true" />
						</span>
					</summary>

					<ul>
						{area.services.map((service) => (
							<li>
								<a href={getHref(service)}>
									<span>
										<strong>{service.title}</strong>
										<small>{service.description}</small>
									</span>
									<Icon name="arrow-right" class="h-4 w-4" aria-hidden="true" />
								</a>
							</li>
						))}
					</ul>
				</details>
			))
		}
	</div>
</section>

<style>
	.service-directory {
		padding-block: clamp(4.5rem, 8vw, 7rem);
	}

	.service-directory > header {
		max-width: 58rem;
	}

	.service-directory .eyebrow {
		color: var(--action);
	}

	.service-directory h2 {
		margin-top: 0.9rem;
		color: var(--home-navy);
		font-size: clamp(2.2rem, 4.5vw, 4rem);
		font-weight: 950;
		letter-spacing: -0.055em;
		line-height: 1;
		text-wrap: balance;
	}

	.service-directory > header > p:last-child {
		max-width: 48rem;
		margin-top: 1.1rem;
		color: var(--text-muted);
		line-height: 1.7;
	}

	.service-directory__groups {
		margin-top: 3rem;
		border-top: 1px solid var(--surface-border);
	}

	.service-directory details {
		border-bottom: 1px solid var(--surface-border);
	}

	.service-directory summary {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) auto;
		gap: 1rem;
		align-items: center;
		min-height: 5.5rem;
		padding-block: 1rem;
		cursor: pointer;
		list-style: none;
	}

	.service-directory summary::-webkit-details-marker {
		display: none;
	}

	.service-directory summary:focus-visible {
		border-radius: 0.75rem;
		outline: 2px solid var(--action);
		outline-offset: 4px;
	}

	.service-directory summary strong,
	.service-directory summary small {
		display: block;
	}

	.service-directory summary strong {
		color: var(--text);
		font-size: clamp(1.1rem, 2vw, 1.4rem);
		font-weight: 900;
	}

	.service-directory summary small {
		margin-top: 0.2rem;
		color: var(--text-muted);
		font-size: 0.72rem;
		font-weight: 750;
	}

	.service-directory__action {
		display: flex;
		width: 2.5rem;
		height: 2.5rem;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--surface-border);
		border-radius: 999px;
		color: var(--action);
	}

	.service-directory details[open] .service-directory__action :global(svg) {
		transform: rotate(45deg);
	}

	.service-directory__action :global(svg) {
		transition: transform 180ms ease;
	}

	.service-directory ul {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0 2rem;
		padding: 0 0 1.5rem 4.5rem;
	}

	.service-directory li {
		border-top: 1px solid
			color-mix(in srgb, var(--surface-border) 72%, transparent);
	}

	.service-directory li a {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1rem;
		align-items: center;
		min-height: 5rem;
		padding-block: 0.9rem;
		color: var(--text);
	}

	.service-directory li a:hover strong,
	.service-directory li a:hover > :global(svg) {
		color: var(--action);
	}

	.service-directory li strong,
	.service-directory li small {
		display: block;
	}

	.service-directory li strong {
		font-size: 0.9rem;
		font-weight: 850;
	}

	.service-directory li small {
		display: -webkit-box;
		overflow: hidden;
		margin-top: 0.25rem;
		color: var(--text-muted);
		font-size: 0.75rem;
		line-height: 1.45;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
	}

	.service-directory li a > :global(svg) {
		color: var(--text-muted);
	}

	@media (max-width: 720px) {
		.service-directory ul {
			grid-template-columns: 1fr;
			padding-left: 0;
		}
	}
</style>
