---
import { Icon } from "astro-icon/components";

interface Model {
	key: string;
	number: string;
	title: string;
	text: string;
	price: string;
}

interface Props {
	content: {
		eyebrow: string;
		title: string;
		intro: string;
		models: Model[];
	};
	mostCommonLabel: string;
}

const { content, mostCommonLabel } = Astro.props as Props;
---

<section
	data-engagement-models
	class="engagement-models"
	aria-labelledby="engagement-title"
>
	<header class="engagement-models__heading">
		<div>
			<p class="eyebrow">{content.eyebrow}</p>
			<h2 id="engagement-title">{content.title}</h2>
		</div>
		<p>{content.intro}</p>
	</header>

	<ol class="engagement-models__list">
		{
			content.models.map((model) => {
				const featured = model.key === "project";

				return (
					<li class:list={{ "is-featured": featured }}>
						<div class="engagement-models__topline">
							<span aria-hidden="true">{model.number}</span>
							<Icon
								name={
									model.key === "intervention"
										? "lightbulb"
										: model.key === "project"
											? "briefcase-business"
											: "circle-check-big"
								}
								class="h-6 w-6"
								aria-hidden="true"
							/>
						</div>
						{featured ? (
							<p class="engagement-models__badge">{mostCommonLabel}</p>
						) : null}
						<h3>{model.title}</h3>
						<p>{model.text}</p>
						<strong>{model.price}</strong>
					</li>
				);
			})
		}
	</ol>
</section>

<style>
	.engagement-models {
		padding-block: clamp(4.5rem, 8vw, 7rem);
	}

	.engagement-models__heading {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.75fr);
		gap: 2rem 5rem;
		align-items: end;
	}

	.engagement-models .eyebrow {
		color: var(--action);
	}

	.engagement-models h2 {
		max-width: 16ch;
		margin-top: 0.9rem;
		color: var(--home-navy);
		font-size: clamp(2.25rem, 4.6vw, 4.25rem);
		font-weight: 950;
		letter-spacing: -0.06em;
		line-height: 0.98;
		text-wrap: balance;
	}

	.engagement-models__heading > p {
		color: var(--text-muted);
		line-height: 1.75;
	}

	.engagement-models__list {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		margin-top: 3.25rem;
		border-block: 1px solid var(--surface-border);
	}

	.engagement-models__list li {
		position: relative;
		min-height: 22rem;
		padding: clamp(1.5rem, 3vw, 2.5rem);
	}

	.engagement-models__list li + li {
		border-left: 1px solid var(--surface-border);
	}

	.engagement-models__list li.is-featured {
		background: color-mix(in srgb, var(--action) 6%, transparent);
		box-shadow: inset 0 0 0 1px
			color-mix(in srgb, var(--action) 16%, transparent);
	}

	.engagement-models__topline {
		display: flex;
		align-items: center;
		justify-content: space-between;
		color: var(--action);
	}

	.engagement-models__topline span {
		font-size: 0.7rem;
		font-weight: 900;
		letter-spacing: 0.18em;
	}

	.engagement-models__badge {
		width: fit-content;
		margin-top: 1.5rem;
		border: 1px solid color-mix(in srgb, var(--action) 35%, transparent);
		border-radius: 999px;
		padding: 0.35rem 0.65rem;
		background: color-mix(in srgb, var(--action) 11%, var(--surface));
		color: var(--action);
		font-size: 0.67rem;
		font-weight: 850;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.engagement-models h3 {
		margin-top: 2.5rem;
		color: var(--text);
		font-size: clamp(1.4rem, 2.3vw, 2rem);
		font-weight: 900;
		letter-spacing: -0.04em;
	}

	.engagement-models__badge + h3 {
		margin-top: 1.25rem;
	}

	.engagement-models li > p:not(.engagement-models__badge) {
		margin-top: 0.8rem;
		color: var(--text-muted);
		line-height: 1.65;
	}

	.engagement-models li > strong {
		display: block;
		margin-top: 2rem;
		color: var(--home-navy);
		font-size: 1.1rem;
		font-weight: 900;
	}

	@media (max-width: 800px) {
		.engagement-models__heading,
		.engagement-models__list {
			grid-template-columns: 1fr;
		}

		.engagement-models__heading {
			gap: 1.25rem;
		}

		.engagement-models__list li {
			min-height: 0;
			padding-inline: 0;
		}

		.engagement-models__list li + li {
			border-top: 1px solid var(--surface-border);
			border-left: 0;
		}

		.engagement-models__list li.is-featured {
			margin-inline: -1rem;
			padding-inline: 1rem;
		}
	}
</style>
