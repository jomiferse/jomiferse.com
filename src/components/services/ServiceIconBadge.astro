---
import { Icon } from "astro-icon/components";

interface Props {
	name: string;
	size?: "sm" | "md" | "lg";
	label?: string;
}

const { name, size = "md", label } = Astro.props as Props;
---

<span
	data-service-icon
	class:list={["service-icon-badge", `service-icon-badge--${size}`]}
	aria-hidden={label ? undefined : "true"}
	aria-label={label}
>
	<Icon name={name} aria-hidden="true" />
</span>

<style>
	.service-icon-badge {
		display: inline-flex;
		flex: none;
		align-items: center;
		justify-content: center;
		border: 1px solid
			color-mix(in srgb, var(--action) 24%, var(--surface-border));
		border-radius: 0.95rem;
		background:
			radial-gradient(
				circle at 80% 15%,
				color-mix(in srgb, var(--action) 17%, transparent),
				transparent 55%
			),
			var(--surface);
		color: var(--action);
		box-shadow: 0 10px 24px color-mix(in srgb, var(--home-navy) 8%, transparent);
	}

	.service-icon-badge--sm {
		width: 2.5rem;
		height: 2.5rem;
	}

	.service-icon-badge--md {
		width: 3.25rem;
		height: 3.25rem;
	}

	.service-icon-badge--lg {
		width: 4rem;
		height: 4rem;
		border-radius: 1.1rem;
	}

	.service-icon-badge--sm :global(svg) {
		width: 1.1rem;
		height: 1.1rem;
	}

	.service-icon-badge--md :global(svg) {
		width: 1.4rem;
		height: 1.4rem;
	}

	.service-icon-badge--lg :global(svg) {
		width: 1.75rem;
		height: 1.75rem;
	}
</style>
