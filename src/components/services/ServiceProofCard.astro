---
import { Icon } from "astro-icon/components";

interface Props {
	eyebrow: string;
	title: string;
	description: string;
	href: string;
	actionLabel: string;
	image?: {
		src: string;
		alt?: string;
	};
}

const { eyebrow, title, description, href, actionLabel, image } =
	Astro.props as Props;
---

<article data-service-proof class="service-proof-card group">
	<a href={href}>
		{
			image ? (
				<div class="service-proof-card__image">
					<img
						src={image.src}
						alt={image.alt ?? title}
						width="720"
						height="405"
						loading="lazy"
						decoding="async"
						sizes="(max-width: 48rem) calc(100vw - 2rem), 45rem"
					/>
				</div>
			) : (
				<div class="service-proof-card__illustration" aria-hidden="true">
					<Icon name="book-open" class="h-9 w-9" />
					<span />
				</div>
			)
		}

		<div class="service-proof-card__body">
			<p class="eyebrow">{eyebrow}</p>
			<h3>{title}</h3>
			<p>{description}</p>
			<span>
				{actionLabel}
				<Icon name="arrow-right" class="h-4 w-4" aria-hidden="true" />
			</span>
		</div>
	</a>
</article>

<style>
	.service-proof-card > a {
		display: grid;
		height: 100%;
		grid-template-columns: minmax(15rem, 0.8fr) minmax(0, 1.2fr);
		overflow: hidden;
		border: 1px solid var(--surface-border);
		border-radius: 1.2rem;
		background: var(--surface);
		box-shadow: var(--shadow-card);
		color: var(--text);
		transition:
			border-color 180ms ease,
			transform 180ms ease;
	}

	.service-proof-card > a:hover {
		transform: translateY(-0.2rem);
		border-color: color-mix(in srgb, var(--action) 40%, var(--surface-border));
	}

	.service-proof-card__image,
	.service-proof-card__illustration {
		min-height: 18rem;
		background: var(--bg-band);
	}

	.service-proof-card__image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 400ms ease;
	}

	.service-proof-card > a:hover .service-proof-card__image img {
		transform: scale(1.025);
	}

	.service-proof-card__illustration {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		color: var(--action);
	}

	.service-proof-card__illustration span {
		position: absolute;
		width: 12rem;
		height: 12rem;
		border: 1px solid color-mix(in srgb, var(--action) 18%, transparent);
		border-radius: 999px;
	}

	.service-proof-card__body {
		display: flex;
		min-width: 0;
		flex-direction: column;
		padding: clamp(1.5rem, 3.5vw, 3rem);
	}

	.service-proof-card .eyebrow {
		color: var(--action);
	}

	.service-proof-card h3 {
		margin-top: 1rem;
		color: var(--home-navy);
		font-size: clamp(1.6rem, 3vw, 2.5rem);
		font-weight: 950;
		letter-spacing: -0.045em;
		line-height: 1.05;
		text-wrap: balance;
	}

	.service-proof-card__body > p:not(.eyebrow) {
		margin-top: 1rem;
		color: var(--text-muted);
		line-height: 1.7;
	}

	.service-proof-card__body > span {
		display: flex;
		gap: 0.55rem;
		align-items: center;
		margin-top: auto;
		padding-top: 1.5rem;
		border-top: 1px solid var(--surface-border);
		color: var(--text);
		font-size: 0.86rem;
		font-weight: 900;
	}

	.service-proof-card > a:hover .service-proof-card__body > span {
		color: var(--action);
	}

	@media (max-width: 720px) {
		.service-proof-card > a {
			grid-template-columns: 1fr;
		}

		.service-proof-card__image,
		.service-proof-card__illustration {
			min-height: 12rem;
			aspect-ratio: 16 / 9;
		}

		.service-proof-card__body > span {
			margin-top: 1.5rem;
		}
	}
</style>
