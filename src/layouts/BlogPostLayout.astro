---
import { getLocaleFromPath, type Locale, t } from "@/i18n";

interface Frontmatter {
	title: string;
	description?: string;
	date: Date;
	tags?: string[];
	author?: string;
	readingTime?: string;
}

const locale: Locale = getLocaleFromPath(Astro.url.pathname);
const { frontmatter } = Astro.props as { frontmatter: Frontmatter };

const blogPath = `/${locale}/blog`;
const dateLocale = locale === "es" ? "es-ES" : "en-GB";
---

<article>
	<nav class="mb-10">
		<a
			href={blogPath}
			class="inline-flex items-center gap-2 text-sm font-semibold text-slate-600 hover:text-slate-950 dark:text-slate-300 dark:hover:text-slate-50"
		>
			{t(locale, "blog.post.back")}
		</a>
	</nav>

	<header class="max-w-4xl">
		<div
			class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-slate-500 dark:text-slate-400"
		>
			<time datetime={frontmatter.date.toISOString()}>
				{
					frontmatter.date.toLocaleDateString(dateLocale, {
						year: "numeric",
						month: "long",
						day: "numeric",
					})
				}
			</time>
			{frontmatter.readingTime ? <span>{frontmatter.readingTime}</span> : null}
			{frontmatter.author ? <span>{frontmatter.author}</span> : null}
		</div>

		<h1
			class="mt-6 text-4xl leading-tight font-semibold tracking-[-0.05em] text-slate-950 md:text-6xl dark:text-slate-50"
		>
			{frontmatter.title}
		</h1>

		{
			frontmatter.description && (
				<p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600 dark:text-slate-300">
					{frontmatter.description}
				</p>
			)
		}

		{
			frontmatter.tags?.length ? (
				<div class="mt-7 flex flex-wrap gap-2">
					{frontmatter.tags.map((tag) => (
						<span class="inline-flex items-center rounded-full bg-slate-200/65 px-3 py-1.5 text-xs font-semibold text-slate-700 dark:bg-slate-800/70 dark:text-slate-200">
							{tag}
						</span>
					))}
				</div>
			) : null
		}
	</header>

	<div class="mx-auto mt-14 max-w-3xl">
		<div class="prose-wrapper">
			<slot />
		</div>
	</div>

	<footer
		class="mt-20 border-t border-slate-200/70 pt-8 dark:border-slate-800/70"
	>
		<a
			href={blogPath}
			class="inline-flex items-center gap-2 text-sm font-semibold text-slate-950 hover:text-[var(--accent-strong)] dark:text-slate-50 dark:hover:text-[var(--accent-strong)]"
		>
			{t(locale, "blog.post.backToList")}
		</a>
	</footer>
</article>
