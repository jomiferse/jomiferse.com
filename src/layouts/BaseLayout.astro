---
import Footer from "@/components/common/Footer.astro";
import Header from "@/components/common/Header.astro";
import "@/styles/global.css";
import { getLocaleFromPath, t, type Locale } from "@/i18n";
import { getCv } from "@cv";
import Analytics from "@vercel/analytics/astro";

interface LayoutProps {
	title: string;
	description: string;
	image?: string;
	imageAlt?: string;
	noindex?: boolean;
	structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
	ogType?: "website" | "article";
	keywords?: string[];
	alternatePaths?: Partial<Record<Locale, string>>;
}

const {
	title,
	description,
	image = "/images/og/portfolio-og.svg",
	imageAlt = title,
	noindex = false,
	structuredData,
	ogType = "website",
	keywords = [],
	alternatePaths,
} = Astro.props as LayoutProps;

const locale: Locale = getLocaleFromPath(Astro.url.pathname);
const cv = getCv(locale);

const canonicalUrl = Astro.site
	? new URL(Astro.url.pathname, Astro.site).toString()
	: Astro.url.pathname;

const buildFallbackAlternatePath = (loc: Locale) => {
	const pathname = Astro.url.pathname.replace(/^\/(en|es)/, "");
	return `/${loc}${pathname || ""}`;
};

const buildAlternatePath = (loc: Locale) =>
	alternatePaths?.[loc] ?? buildFallbackAlternatePath(loc);
const buildAlternateUrl = (loc: Locale) => {
	const path = buildAlternatePath(loc);
	return Astro.site ? new URL(path, Astro.site).toString() : path;
};

const alternateEn = buildAlternateUrl("en");
const alternateEs = buildAlternateUrl("es");
const otherLocale: Locale = locale === "en" ? "es" : "en";
const languageHref = alternatePaths?.[otherLocale];
const ogImage = Astro.site ? new URL(image, Astro.site).toString() : image;
const robots = noindex ? "noindex,nofollow" : "index,follow";

const baseStructuredData = [
	{
		"@context": "https://schema.org",
		"@type": "Person",
		name: cv.name,
		jobTitle: cv.currentRole,
		description: cv.tagline,
		url: Astro.site
			? new URL(`/${locale}`, Astro.site).toString()
			: `/${locale}`,
		email: `mailto:${cv.email}`,
		address: {
			"@type": "PostalAddress",
			addressLocality: cv.location,
		},
		sameAs: [cv.links.linkedin, cv.links.github],
		knowsLanguage: locale === "es" ? ["es", "en"] : ["en", "es"],
		hasOccupation: {
			"@type": "Occupation",
			name:
				locale === "es"
					? "Desarrollador full-stack freelance"
					: "Freelance full-stack developer",
			occupationLocation: {
				"@type": "Country",
				name: locale === "es" ? "España" : "Spain",
			},
			skills:
				"Full-stack development, internal tools, workflow automation, API integrations, Java, Spring Boot, TypeScript, Astro",
		},
		makesOffer: [
			"Business websites",
			"Website redesign",
			"Custom web applications",
			"Internal tools",
			"Workflow automation",
			"API integrations",
			"Spring Boot backend development",
		],
		knowsAbout: [
			"Java",
			"Spring Boot",
			"Distributed Systems",
			"Product Engineering",
			"Systems Engineering",
			"Automation",
			"Internal Tooling",
			"Kubernetes",
			"Docker",
			"PostgreSQL",
			"CI/CD",
			"Backend Architecture",
		],
	},
	{
		"@context": "https://schema.org",
		"@type": "WebSite",
		name: cv.name,
		url: Astro.site?.toString() ?? "/",
		inLanguage: locale,
	},
];

const extraStructuredData = structuredData
	? Array.isArray(structuredData)
		? structuredData
		: [structuredData]
	: [];

const jsonLd = JSON.stringify([...baseStructuredData, ...extraStructuredData]);
---

<html lang={locale} class="min-h-screen scroll-smooth antialiased">
	<head>
		<!-- Google Tag Manager -->
		<script is:inline>
		(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
		new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
		j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
		'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
		})(window,document,'script','dataLayer','GTM-5FT27C7Z');
		</script>
		<!-- End Google Tag Manager -->

		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content={cv.name} />
		<meta name="robots" content={robots} />
		{
			keywords.length ? (
				<meta name="keywords" content={keywords.join(", ")} />
			) : null
		}
		<meta name="referrer" content="strict-origin-when-cross-origin" />

		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="en" href={alternateEn} />
		<link rel="alternate" hreflang="es" href={alternateEs} />
		<link rel="alternate" hreflang="x-default" href={alternateEn} />

		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content={cv.name} />
		<meta property="og:locale" content={locale === "es" ? "es_ES" : "en_US"} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:alt" content={imageAlt} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<meta name="twitter:image:alt" content={imageAlt} />

		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />

		<meta
			name="theme-color"
			content="#f5f7fb"
			media="(prefers-color-scheme: light)"
		/>
		<meta
			name="theme-color"
			content="#090d16"
			media="(prefers-color-scheme: dark)"
		/>

		<script is:inline>
			(function () {
				const stored = localStorage.getItem("theme");
				const theme = stored ?? "dark";
				document.documentElement.classList.toggle("dark", theme === "dark");
			})();
		</script>

		<script is:inline type="application/ld+json" set:html={jsonLd} />
	</head>

	<body class="relative flex min-h-screen flex-col">
		<a href="#main-content" class="skip-link"
			>{t(locale, "a11y.skipToContent")}</a
		>
		<Header locale={locale} languageHref={languageHref} />
		<main
			id="main-content"
			class="site-shell w-full flex-1 px-4 py-14 md:px-6 md:py-20"
		>
			<!-- Google Tag Manager (noscript) -->
			<noscript>
				<iframe
					src="https://www.googletagmanager.com/ns.html?id=GTM-5FT27C7Z"
					height="0"
					width="0"
					style="display:none;visibility:hidden">
				</iframe>
			</noscript>
			<!-- End Google Tag Manager (noscript) -->
			<slot />
			<Analytics />
		</main>
		<Footer locale={locale} />

		<script is:inline>
			(() => {
				const runWhenIdle = (callback) => {
					if ("requestIdleCallback" in window) {
						window.requestIdleCallback(callback, { timeout: 1200 });
						return;
					}

					window.setTimeout(callback, 1);
				};

				const initReveal = () => {
					runWhenIdle(() => {
						window.requestAnimationFrame(() => {
							const elements = document.querySelectorAll(
								".section-reveal, .stagger-children",
							);
							if (
								!elements.length ||
								window.matchMedia("(prefers-reduced-motion: reduce)").matches
							) {
								elements.forEach((element) =>
									element.classList.add("is-visible"),
								);
								return;
							}

							const observer = new IntersectionObserver(
								(entries) => {
									entries.forEach((entry) => {
										if (!entry.isIntersecting) return;
										entry.target.classList.add("is-visible");
										observer.unobserve(entry.target);
									});
								},
								{
									threshold: 0.12,
									rootMargin: "0px 0px -8% 0px",
								},
							);

							elements.forEach((element) => observer.observe(element));
						});
					});
				};

				if (document.readyState === "complete") {
					initReveal();
					return;
				}

				window.addEventListener("load", initReveal, { once: true });
			})();
		</script>
	</body>
</html>
