---
import Footer from "@/components/common/Footer.astro";
import CookieConsent from "@/components/common/CookieConsent.astro";
import GlobalExitIntent from "@/components/common/GlobalExitIntent.astro";
import GoogleAnalytics from "@/components/common/GoogleAnalytics.astro";
import Header from "@/components/common/Header.astro";
import "@/styles/global.css";
import { getLocaleFromPath, t, type Locale } from "@/i18n";
import {
	getExitIntentContext,
	isExitIntentRouteExcluded,
	type ExitIntentContext,
} from "@/lib/exit-intent";
import type { PricingKey } from "@/lib/service-commercial";
import {
	absolutePageUrl,
	buildPerson,
	buildStructuredDataGraph,
	buildWebPage,
	buildWebSite,
} from "@/lib/seo";
import { getCv } from "@cv";

type PopupContext = {
	kind?: ExitIntentContext;
	title?: string;
	service?: string;
	scope?: PricingKey;
};

interface LayoutProps {
	title: string;
	description: string;
	image?: string;
	imageAlt?: string;
	imageWidth?: number;
	imageHeight?: number;
	noindex?: boolean;
	structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
	ogType?: "website" | "article";
	alternatePaths?: Partial<Record<Locale, string>>;
	canonicalPath?: string;
	popupContext?: PopupContext;
}

const {
	title,
	description,
	image = "/images/og/portfolio-og.png",
	imageAlt = title,
	imageWidth = image === "/images/og/portfolio-og.png" ? 1200 : undefined,
	imageHeight = image === "/images/og/portfolio-og.png" ? 630 : undefined,
	noindex = false,
	structuredData,
	ogType = "website",
	alternatePaths,
	canonicalPath,
	popupContext,
} = Astro.props as LayoutProps;

const locale: Locale = getLocaleFromPath(Astro.url.pathname);
const cv = getCv(locale);
const schemaSite = Astro.site?.toString() ?? "https://www.jomiferse.com";
const showExitIntent = !isExitIntentRouteExcluded(Astro.url.pathname);
const resolvedPopupContext = {
	kind: popupContext?.kind ?? getExitIntentContext(Astro.url.pathname),
	title: popupContext?.title,
	service: popupContext?.service,
	scope: popupContext?.scope,
};

const pagePath = canonicalPath ?? Astro.url.pathname;
const canonicalUrl = absolutePageUrl(schemaSite, pagePath);

const buildFallbackAlternatePath = (loc: Locale) => {
	const pathname = Astro.url.pathname.replace(/^\/(en|es)/, "");
	return `/${loc}${pathname || ""}`;
};

const buildAlternatePath = (loc: Locale) =>
	alternatePaths?.[loc] ?? buildFallbackAlternatePath(loc);
const buildAlternateUrl = (loc: Locale) => {
	const path = buildAlternatePath(loc);
	return absolutePageUrl(schemaSite, path);
};

const alternateEn = buildAlternateUrl("en");
const alternateEs = buildAlternateUrl("es");
const defaultAlternate = alternateEs;
const otherLocale: Locale = locale === "en" ? "es" : "en";
const languageHref = alternatePaths?.[otherLocale];
const ogImage = Astro.site ? new URL(image, Astro.site).toString() : image;
const ogImageType = image.endsWith(".png")
	? "image/png"
	: image.endsWith(".webp")
		? "image/webp"
		: image.endsWith(".jpg") || image.endsWith(".jpeg")
			? "image/jpeg"
			: undefined;
const robots = noindex ? "noindex,follow" : "index,follow";
const seoTitle =
	title.length > 65
		? title.replace(/\s+\|\s+José Miguel Fernández$/, "")
		: title;

const baseStructuredData = [
	buildPerson(schemaSite, locale, {
		name: cv.name,
		jobTitle: cv.currentRole,
		description: cv.tagline,
		email: cv.email,
		location: cv.location,
		links: cv.links,
	}),
	buildWebSite(schemaSite, cv.name),
	buildWebPage(schemaSite, pagePath, locale, seoTitle, description),
];

const extraStructuredData = structuredData
	? Array.isArray(structuredData)
		? structuredData
		: [structuredData]
	: [];

const jsonLd = JSON.stringify(
	buildStructuredDataGraph([...baseStructuredData, ...extraStructuredData]),
);
---

<html lang={locale} class="min-h-screen scroll-smooth antialiased">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<title>{seoTitle}</title>
		<meta name="description" content={description} />
		<meta name="author" content={cv.name} />
		<meta name="robots" content={robots} />
		<meta name="referrer" content="strict-origin-when-cross-origin" />

		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="en" href={alternateEn} />
		<link rel="alternate" hreflang="es" href={alternateEs} />
		<link rel="alternate" hreflang="x-default" href={defaultAlternate} />

		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={seoTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content={cv.name} />
		<meta property="og:locale" content={locale === "es" ? "es_ES" : "en_US"} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:alt" content={imageAlt} />
		{
			ogImageType ? (
				<meta property="og:image:type" content={ogImageType} />
			) : null
		}
		{
			imageWidth ? (
				<meta property="og:image:width" content={String(imageWidth)} />
			) : null
		}
		{
			imageHeight ? (
				<meta property="og:image:height" content={String(imageHeight)} />
			) : null
		}

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={seoTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<meta name="twitter:image:alt" content={imageAlt} />

		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />

		<meta
			name="theme-color"
			content="#f5f7fb"
			media="(prefers-color-scheme: light)"
		/>
		<meta
			name="theme-color"
			content="#090d16"
			media="(prefers-color-scheme: dark)"
		/>

		<script is:inline>
			(function () {
				const stored = localStorage.getItem("theme");
				const theme = stored ?? "light";
				document.documentElement.classList.toggle("dark", theme === "dark");
			})();
		</script>

		<script is:inline type="application/ld+json" set:html={jsonLd} />
		<GoogleAnalytics />
	</head>

	<body id="top" class="relative flex min-h-screen flex-col">
		<a href="#main-content" class="skip-link"
			>{t(locale, "a11y.skipToContent")}</a
		>
		<Header locale={locale} languageHref={languageHref} />
		<main
			id="main-content"
			class="site-shell w-full flex-1 px-4 py-14 md:px-6 md:py-20"
		>
			<slot />
		</main>
		<Footer locale={locale} />
		{
			showExitIntent ? (
				<GlobalExitIntent
					locale={locale}
					context={resolvedPopupContext.kind}
					contextTitle={resolvedPopupContext.title}
					service={resolvedPopupContext.service}
					scope={resolvedPopupContext.scope}
				/>
			) : null
		}
		<CookieConsent locale={locale} />
	</body>
</html>
