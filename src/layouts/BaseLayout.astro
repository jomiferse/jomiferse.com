---
import Footer from "@/components/common/Footer.astro";
import Header from "@/components/common/Header.astro";
import "@/styles/global.css";
import { getLocaleFromPath, t, type Locale } from "@/i18n";
import { getCv } from "@cv";

interface LayoutProps {
	title: string;
	description: string;
	image?: string;
	imageAlt?: string;
	noindex?: boolean;
	structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
	ogType?: "website" | "article";
	keywords?: string[];
}

const {
	title,
	description,
	image = "/images/og/portfolio-og.svg",
	imageAlt = title,
	noindex = false,
	structuredData,
	ogType = "website",
	keywords = [],
} = Astro.props as LayoutProps;

const locale: Locale = getLocaleFromPath(Astro.url.pathname);
const cv = getCv(locale);

const canonicalUrl = Astro.site
	? new URL(Astro.url.pathname, Astro.site).toString()
	: Astro.url.pathname;

const buildAlternate = (loc: Locale) => {
	const pathname = Astro.url.pathname.replace(/^\/(en|es)/, "");
	const path = `/${loc}${pathname || ""}`;
	return Astro.site ? new URL(path, Astro.site).toString() : path;
};

const alternateEn = buildAlternate("en");
const alternateEs = buildAlternate("es");
const ogImage = Astro.site ? new URL(image, Astro.site).toString() : image;
const robots = noindex ? "noindex,nofollow" : "index,follow";

const baseStructuredData = [
	{
		"@context": "https://schema.org",
		"@type": "Person",
		name: cv.name,
		jobTitle: cv.currentRole,
		description: cv.tagline,
		url: Astro.site
			? new URL(`/${locale}`, Astro.site).toString()
			: `/${locale}`,
		email: `mailto:${cv.email}`,
		address: {
			"@type": "PostalAddress",
			addressLocality: cv.location,
		},
		sameAs: [cv.links.linkedin, cv.links.github],
		knowsAbout: [
			"Java",
			"Spring Boot",
			"Distributed Systems",
			"Product Engineering",
			"Systems Engineering",
			"Automation",
			"Internal Tooling",
			"Kubernetes",
			"Docker",
			"PostgreSQL",
			"CI/CD",
			"Backend Architecture",
		],
	},
	{
		"@context": "https://schema.org",
		"@type": "WebSite",
		name: cv.name,
		url: Astro.site?.toString() ?? "/",
		inLanguage: locale,
	},
];

const extraStructuredData = structuredData
	? Array.isArray(structuredData)
		? structuredData
		: [structuredData]
	: [];

const jsonLd = JSON.stringify([...baseStructuredData, ...extraStructuredData]);
---

<html lang={locale} class="min-h-screen scroll-smooth antialiased">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content={cv.name} />
		<meta name="robots" content={robots} />
		{
			keywords.length ? (
				<meta name="keywords" content={keywords.join(", ")} />
			) : null
		}
		<meta name="referrer" content="strict-origin-when-cross-origin" />

		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="en" href={alternateEn} />
		<link rel="alternate" hreflang="es" href={alternateEs} />
		<link rel="alternate" hreflang="x-default" href={alternateEn} />

		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content={cv.name} />
		<meta property="og:locale" content={locale === "es" ? "es_ES" : "en_US"} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:alt" content={imageAlt} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<meta name="twitter:image:alt" content={imageAlt} />

		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />

		<meta
			name="theme-color"
			content="#f5f7fb"
			media="(prefers-color-scheme: light)"
		/>
		<meta
			name="theme-color"
			content="#090d16"
			media="(prefers-color-scheme: dark)"
		/>

		<script is:inline>
			(function () {
				const stored = localStorage.getItem("theme");
				const prefersDark = window.matchMedia(
					"(prefers-color-scheme: dark)",
				).matches;
				const theme = stored ?? (prefersDark ? "dark" : "light");
				document.documentElement.classList.toggle("dark", theme === "dark");
			})();
		</script>

		<script is:inline type="application/ld+json" set:html={jsonLd} />
	</head>

	<body
		class="relative flex min-h-screen flex-col text-slate-950 dark:text-slate-50"
	>
		<a href="#main-content" class="skip-link"
			>{t(locale, "a11y.skipToContent")}</a
		>
		<Header locale={locale} />
		<main
			id="main-content"
			class="mx-auto w-full max-w-6xl flex-1 px-4 pt-8 pb-14 md:px-6 md:pt-10 md:pb-18"
		>
			<slot />
		</main>
		<Footer locale={locale} />

		<script is:inline>
			(() => {
				const elements = document.querySelectorAll(
					".section-reveal, .stagger-children",
				);
				if (
					!elements.length ||
					window.matchMedia("(prefers-reduced-motion: reduce)").matches
				) {
					elements.forEach((element) => element.classList.add("is-visible"));
					return;
				}

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) return;
							entry.target.classList.add("is-visible");
							observer.unobserve(entry.target);
						});
					},
					{
						threshold: 0.12,
						rootMargin: "0px 0px -8% 0px",
					},
				);

				elements.forEach((element) => observer.observe(element));
			})();
		</script>
	</body>
</html>
