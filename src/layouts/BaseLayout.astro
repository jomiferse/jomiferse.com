---
import Footer from "@/components/common/Footer.astro";
import CookieConsent from "@/components/common/CookieConsent.astro";
import GlobalContactDialog from "@/components/common/GlobalContactDialog.astro";
import GlobalExitIntent from "@/components/common/GlobalExitIntent.astro";
import GoogleAnalytics from "@/components/common/GoogleAnalytics.astro";
import Header from "@/components/common/Header.astro";
import "@/styles/global.css";
import { getLocaleFromPath, t, type Locale } from "@/i18n";
import {
	getExitIntentContext,
	isExitIntentRouteExcluded,
	type ExitIntentContext,
} from "@/lib/exit-intent";
import type { PricingKey } from "@/lib/service-commercial";
import { getCv } from "@cv";

type PopupContext = {
	kind?: ExitIntentContext;
	title?: string;
	service?: string;
	scope?: PricingKey;
};

interface LayoutProps {
	title: string;
	description: string;
	image?: string;
	imageAlt?: string;
	noindex?: boolean;
	structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
	ogType?: "website" | "article";
	keywords?: string[];
	alternatePaths?: Partial<Record<Locale, string>>;
	canonicalPath?: string;
	popupContext?: PopupContext;
}

const {
	title,
	description,
	image = "/images/og/portfolio-og.svg",
	imageAlt = title,
	noindex = false,
	structuredData,
	ogType = "website",
	keywords = [],
	alternatePaths,
	canonicalPath,
	popupContext,
} = Astro.props as LayoutProps;

const locale: Locale = getLocaleFromPath(Astro.url.pathname);
const cv = getCv(locale);
const showGlobalContact = !isExitIntentRouteExcluded(Astro.url.pathname);
const resolvedPopupContext = {
	kind: popupContext?.kind ?? getExitIntentContext(Astro.url.pathname),
	title: popupContext?.title,
	service: popupContext?.service,
	scope: popupContext?.scope,
};

const canonicalUrl = Astro.site
	? new URL(canonicalPath ?? Astro.url.pathname, Astro.site).toString()
	: (canonicalPath ?? Astro.url.pathname);

const buildFallbackAlternatePath = (loc: Locale) => {
	const pathname = Astro.url.pathname.replace(/^\/(en|es)/, "");
	return `/${loc}${pathname || ""}`;
};

const buildAlternatePath = (loc: Locale) =>
	alternatePaths?.[loc] ?? buildFallbackAlternatePath(loc);
const buildAlternateUrl = (loc: Locale) => {
	const path = buildAlternatePath(loc);
	return Astro.site ? new URL(path, Astro.site).toString() : path;
};

const alternateEn = buildAlternateUrl("en");
const alternateEs = buildAlternateUrl("es");
const defaultAlternate = alternateEs;
const otherLocale: Locale = locale === "en" ? "es" : "en";
const languageHref = alternatePaths?.[otherLocale];
const ogImage = Astro.site ? new URL(image, Astro.site).toString() : image;
const robots = noindex ? "noindex,follow" : "index,follow";

const baseStructuredData = [
	{
		"@context": "https://schema.org",
		"@type": "Person",
		name: cv.name,
		jobTitle: cv.currentRole,
		description: cv.tagline,
		url: Astro.site
			? new URL(`/${locale}`, Astro.site).toString()
			: `/${locale}`,
		email: `mailto:${cv.email}`,
		address: {
			"@type": "PostalAddress",
			addressLocality: cv.location,
		},
		sameAs: [cv.links.linkedin, cv.links.github],
		knowsLanguage: locale === "es" ? ["es", "en"] : ["en", "es"],
		hasOccupation: {
			"@type": "Occupation",
			name:
				locale === "es"
					? "Desarrollador full-stack freelance"
					: "Freelance full-stack developer",
			occupationLocation: {
				"@type": "Country",
				name: locale === "es" ? "España" : "Spain",
			},
			skills:
				"Full-stack development, internal tools, workflow automation, API integrations, Java, Spring Boot, TypeScript, Astro",
		},
		makesOffer: [
			"Business websites",
			"Website redesign",
			"Custom web applications",
			"Internal tools",
			"Workflow automation",
			"API integrations",
			"Spring Boot backend development",
		],
		knowsAbout: [
			"Java",
			"Spring Boot",
			"Distributed Systems",
			"Product Engineering",
			"Systems Engineering",
			"Automation",
			"Internal Tooling",
			"Kubernetes",
			"Docker",
			"PostgreSQL",
			"CI/CD",
			"Backend Architecture",
		],
	},
	{
		"@context": "https://schema.org",
		"@type": "WebSite",
		name: cv.name,
		url: Astro.site?.toString() ?? "/",
		inLanguage: locale,
	},
];

const extraStructuredData = structuredData
	? Array.isArray(structuredData)
		? structuredData
		: [structuredData]
	: [];

const jsonLd = JSON.stringify([...baseStructuredData, ...extraStructuredData]);
---

<html lang={locale} class="min-h-screen scroll-smooth antialiased">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content={cv.name} />
		<meta name="robots" content={robots} />
		{
			keywords.length ? (
				<meta name="keywords" content={keywords.join(", ")} />
			) : null
		}
		<meta name="referrer" content="strict-origin-when-cross-origin" />

		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="en" href={alternateEn} />
		<link rel="alternate" hreflang="es" href={alternateEs} />
		<link rel="alternate" hreflang="x-default" href={defaultAlternate} />

		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content={cv.name} />
		<meta property="og:locale" content={locale === "es" ? "es_ES" : "en_US"} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:alt" content={imageAlt} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<meta name="twitter:image:alt" content={imageAlt} />

		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />

		<meta
			name="theme-color"
			content="#f5f7fb"
			media="(prefers-color-scheme: light)"
		/>
		<meta
			name="theme-color"
			content="#090d16"
			media="(prefers-color-scheme: dark)"
		/>

		<script is:inline>
			(function () {
				const stored = localStorage.getItem("theme");
				const theme = stored ?? "light";
				document.documentElement.classList.toggle("dark", theme === "dark");
			})();
		</script>

		<script is:inline type="application/ld+json" set:html={jsonLd} />
		<GoogleAnalytics />
	</head>

	<body id="top" class="relative flex min-h-screen flex-col">
		<a href="#main-content" class="skip-link"
			>{t(locale, "a11y.skipToContent")}</a
		>
		<Header locale={locale} languageHref={languageHref} />
		<main
			id="main-content"
			class="site-shell w-full flex-1 px-4 py-14 md:px-6 md:py-20"
		>
			<slot />
		</main>
		<Footer locale={locale} />
		{
			showGlobalContact ? (
				<>
					<GlobalContactDialog
						locale={locale}
						sourcePath={Astro.url.pathname}
					/>
					<GlobalExitIntent
						locale={locale}
						context={resolvedPopupContext.kind}
						contextTitle={resolvedPopupContext.title}
						service={resolvedPopupContext.service}
						scope={resolvedPopupContext.scope}
					/>
				</>
			) : null
		}
		<CookieConsent locale={locale} />
	</body>
</html>
